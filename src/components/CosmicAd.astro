---
/**
 * CosmicAd.astro
 * A restrained product prompt for horoscope sales.
 */
import { Sparkles, TrendingUp, Zap } from 'lucide-astro';
import { getProductCopy, getProductPriceInEuros, type ProductKey } from '../lib/products';
import { getProductLandingPath } from '../lib/seo';

interface Props {
    type?: 'sidebar' | 'inline' | 'floating';
    productKey?: ProductKey;
    lang?: string;
}

const { type = 'inline', productKey = 'monthly', lang = 'en' } = Astro.props;

import { getTranslations, type SupportedLocale } from '../lib/i18n';
const t = getTranslations(lang as SupportedLocale);

const price = getProductPriceInEuros(productKey).toFixed(2);
const product = getProductCopy(productKey, lang as SupportedLocale, t);

const productData = {
    daily: { name: getProductCopy('daily', lang as SupportedLocale, t).name, icon: Zap },
    weekly: { name: getProductCopy('weekly', lang as SupportedLocale, t).name, icon: TrendingUp },
    monthly: { name: getProductCopy('monthly', lang as SupportedLocale, t).name, icon: Sparkles },
    partner: { name: getProductCopy('partner', lang as SupportedLocale, t).name, icon: Zap },
    lifetime: { name: product.name, icon: Sparkles }
};

const data = productData[productKey];
const Icon = data.icon;

const ctaLink = getProductLandingPath(lang as SupportedLocale, productKey);
---

{type === 'sidebar' && (
    <div class="glass-strong rounded-2xl p-6 border border-white/10 bg-slate-900/40 sticky top-24 overflow-hidden group">
        <div class="absolute top-0 left-0 w-full h-1 bg-amber-500/70"></div>
        <div class="relative z-10">
            <div class="flex items-center gap-2 mb-4">
                <Icon class="w-5 h-5 text-amber-400" />
                <span class="text-xs font-bold uppercase tracking-widest text-white/50">{t.promo?.delivery || 'Instant delivery'}</span>
            </div>
            <h4 class="text-xl font-black text-white mb-2 leading-tight">{data.name}</h4>
            <p class="text-white/60 text-sm mb-6">{product.description}</p>
            
            <div class="flex items-baseline gap-2 mb-6">
                <span class="text-3xl font-black text-white">€{price}</span>
            </div>
            
            <a href={ctaLink} class="flex items-center justify-center w-full py-3 px-6 bg-amber-500 text-black font-bold rounded-xl hover:bg-amber-400 transition-colors">
                {t.ads?.claim || 'Order Now'}
            </a>
        </div>
    </div>
)}

{type === 'floating' && (
    <div id="floating-ad" class="fixed bottom-6 right-6 z-[100] max-w-[320px] opacity-0 pointer-events-none transition-all duration-500 translate-y-4 hidden md:block">
        <div class="glass-strong rounded-2xl p-5 border border-white/10 bg-slate-900/90 relative overflow-hidden group">
            <button onclick="this.closest('#floating-ad').remove()" class="absolute top-2 right-2 text-white/20 hover:text-white transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-xl bg-amber-500/15 border border-amber-400/20 flex items-center justify-center shrink-0">
                    <Icon class="w-6 h-6 text-amber-400" />
                </div>
                <div>
                    <h5 class="text-sm font-bold text-white mb-1">{data.name}</h5>
                    <p class="text-[11px] text-white/50 mb-3">{product.description}</p>
                    <a href={ctaLink} class="text-xs font-bold text-amber-400 hover:text-amber-300 flex items-center gap-1">
                        {t.ads?.claim || t.cta.orderNow} · €{price} <span class="text-[10px] opacity-100">→</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script is:inline>
        setTimeout(() => {
            const ad = document.getElementById('floating-ad');
            // Don't show on homepage or if already hidden
            if (ad && window.location.pathname !== '/' && window.location.pathname !== '/sk' && window.location.pathname !== '/cs') {
                ad.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
            }
        }, 25000); // Show after 25 seconds
    </script>
)}
