---
import type { SupportedLocale } from '../lib/i18n';
import type { ProductKey } from '../lib/products';
import type { ZodiacSignSlug } from '../lib/zodiac';
import { getTranslations } from '../lib/i18n';
import { getZodiacLocaleCopy, zodiacSignSlugs, fillZodiacTemplate } from '../lib/zodiac';
import { getZodiacProductPath } from '../lib/seo';

interface Props {
    lang: SupportedLocale;
    type: ProductKey;
    currentSign?: ZodiacSignSlug;
}

const { lang, type, currentSign } = Astro.props;
const t = getTranslations(lang);
const zodiac = getZodiacLocaleCopy(lang);
const productName = t.products[type].name;
---

<section class="glass-strong rounded-3xl p-6 sm:p-8 border border-white/10">
    <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3">{zodiac.ui.browseTitle}</h2>
    <p class="text-white/70 leading-relaxed mb-6">{zodiac.ui.browseDescription}</p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {zodiacSignSlugs.map((signSlug) => {
            const sign = zodiac.signs[signSlug];
            const href = getZodiacProductPath(lang, type, signSlug);
            const isActive = currentSign === signSlug;
            const label = fillZodiacTemplate(zodiac.ui.browseItemLabel, {
                '{{PRODUCT}}': productName,
                '{{SIGN}}': sign.name,
            });

            return (
                <a
                    href={href}
                    class:list={[
                        'rounded-2xl border p-4 transition-all',
                        isActive
                            ? 'border-amber-400 bg-amber-500/10'
                            : 'border-white/10 bg-white/5 hover:border-amber-400/40 hover:bg-white/10',
                    ]}
                >
                    <div class="flex items-start gap-3">
                        <span class="text-2xl leading-none">{sign.emoji}</span>
                        <div>
                            <p class="text-white font-semibold">{sign.name}</p>
                            <p class="text-white/50 text-sm mb-2">{sign.dateRange}</p>
                            <p class="text-amber-300 text-sm">{label}</p>
                        </div>
                    </div>
                </a>
            );
        })}
    </div>
</section>
