---
import { MessageSquare, Send, ThumbsDown, ThumbsUp, X } from 'lucide-astro';
import { getFeedbackWidgetCopy, getHcaptchaLanguage } from '../lib/feedback-widget-copy';

interface Props {
    lang?: string;
}

const { lang = 'en' } = Astro.props;
const hcaptchaSiteKey = '9ece67fe-3494-49f8-a400-021e108e0138';
const copy = getFeedbackWidgetCopy(lang);
const hcaptchaLanguage = getHcaptchaLanguage(lang);
---

<div
    id="page-feedback"
    data-lang={lang}
    data-hcaptcha-sitekey={hcaptchaSiteKey}
    data-hcaptcha-language={hcaptchaLanguage}
    data-message-choose-rating={copy.chooseRating}
    data-message-negative-required={copy.negativeRequired}
    data-message-captcha-required={copy.captchaRequired}
    data-message-captcha-failed={copy.captchaFailed}
    data-message-success={copy.success}
    data-message-failure={copy.failure}
>
    <button
        id="page-feedback-open"
        type="button"
        class="fixed right-3 bottom-24 z-[70] flex h-12 max-w-[calc(100vw-1.5rem)] items-center justify-center gap-2 rounded-full border border-amber-300/50 bg-amber-500 px-4 text-black shadow-lg shadow-black/30 transition hover:bg-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-200 sm:bottom-auto sm:top-1/2 sm:-translate-y-1/2"
        aria-label={copy.buttonAriaLabel}
        aria-controls="page-feedback-dialog"
        aria-expanded="false"
        title={copy.buttonQuestion}
    >
        <MessageSquare class="h-5 w-5 shrink-0" />
        <span class="min-w-0 max-w-[14rem] truncate text-xs font-bold leading-tight">{copy.buttonQuestion}</span>
    </button>

    <div
        id="page-feedback-dialog"
        class="fixed inset-0 z-[9998] hidden items-center justify-center p-4"
        role="dialog"
        aria-modal="true"
        aria-labelledby="page-feedback-title"
    >
        <button
            type="button"
            class="absolute inset-0 bg-black/70 backdrop-blur-sm"
            data-feedback-close
            aria-label={copy.closeLabel}
        ></button>

        <div class="glass-strong relative z-10 w-full max-w-md rounded-2xl border border-white/10 p-5 shadow-2xl sm:p-7">
            <button
                type="button"
                class="absolute right-4 top-4 flex h-9 w-9 items-center justify-center rounded-full bg-white/10 text-white/70 transition hover:bg-white/20 hover:text-white focus:outline-none focus:ring-2 focus:ring-amber-300"
                data-feedback-close
                aria-label={copy.closeLabel}
            >
                <X class="h-5 w-5" />
            </button>

            <div class="pr-10">
                <p class="mb-2 text-sm font-semibold uppercase tracking-wide text-amber-300">{copy.eyebrow}</p>
                <h2 id="page-feedback-title" class="text-2xl font-bold text-white">{copy.title}</h2>
                <p class="mt-2 text-sm leading-relaxed text-white/65">
                    {copy.intro}
                </p>
            </div>

            <form id="page-feedback-form" class="mt-5 space-y-4">
                <input type="hidden" name="rating" id="page-feedback-rating" />
                <input type="hidden" name="openedAt" id="page-feedback-opened-at" />
                <div class="absolute left-[-10000px] top-auto h-px w-px overflow-hidden">
                    <label for="page-feedback-website">Website</label>
                    <input id="page-feedback-website" type="text" name="website" tabindex="-1" autocomplete="off" />
                </div>

                <div class="grid grid-cols-2 gap-2 sm:gap-3">
                    <button
                        type="button"
                        class="page-feedback-rating flex h-12 min-w-0 items-center justify-center gap-2 rounded-xl border border-white/15 bg-white/10 text-xs font-semibold text-white transition hover:border-amber-300/70 hover:bg-white/15 focus:outline-none focus:ring-2 focus:ring-amber-300 sm:text-sm"
                        data-rating="helpful"
                    >
                        <ThumbsUp class="h-4 w-4 shrink-0 text-amber-300" />
                        {copy.yes}
                    </button>
                    <button
                        type="button"
                        class="page-feedback-rating flex h-12 min-w-0 items-center justify-center gap-2 rounded-xl border border-white/15 bg-white/10 text-xs font-semibold text-white transition hover:border-amber-300/70 hover:bg-white/15 focus:outline-none focus:ring-2 focus:ring-amber-300 sm:text-sm"
                        data-rating="not_helpful"
                    >
                        <ThumbsDown class="h-4 w-4 shrink-0 text-amber-300" />
                        {copy.notReally}
                    </button>
                </div>

                <div>
                    <label for="page-feedback-text" class="mb-2 block text-sm font-medium text-white/90">
                        {copy.feedbackLabel}
                    </label>
                    <textarea
                        id="page-feedback-text"
                        name="feedback"
                        rows="4"
                        maxlength="1500"
                        class="input w-full resize-none p-4 text-base"
                        placeholder={copy.feedbackPlaceholder}
                    ></textarea>
                </div>

                <div>
                    <label for="page-feedback-email" class="mb-2 block text-sm font-medium text-white/90">
                        {copy.emailLabel}
                    </label>
                    <input
                        id="page-feedback-email"
                        name="email"
                        type="email"
                        autocomplete="email"
                        class="input w-full p-4 text-base"
                        placeholder={copy.emailPlaceholder}
                    />
                </div>

                <div class="flex justify-center overflow-hidden pt-1">
                    <div id="page-feedback-captcha" class="origin-top scale-[0.92] sm:scale-100"></div>
                </div>

                <p id="page-feedback-message" class="hidden text-sm font-medium"></p>

                <button
                    type="submit"
                    id="page-feedback-submit"
                    class="flex h-12 w-full items-center justify-center gap-2 rounded-xl bg-amber-500 px-5 font-bold text-black transition hover:bg-amber-400 disabled:cursor-not-allowed disabled:opacity-60"
                >
                    <Send class="h-4 w-4" />
                    <span>{copy.submit}</span>
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    type HcaptchaApi = {
        render: (container: HTMLElement, options: { sitekey: string; theme: string; hl?: string }) => string | number;
        getResponse: (widgetId?: string | number) => string;
        reset: (widgetId?: string | number) => void;
    };

    const root = document.getElementById('page-feedback');
    const openButton = document.getElementById('page-feedback-open') as HTMLButtonElement | null;
    const dialog = document.getElementById('page-feedback-dialog');
    const form = document.getElementById('page-feedback-form') as HTMLFormElement | null;
    const ratingInput = document.getElementById('page-feedback-rating') as HTMLInputElement | null;
    const openedAtInput = document.getElementById('page-feedback-opened-at') as HTMLInputElement | null;
    const message = document.getElementById('page-feedback-message');
    const submitButton = document.getElementById('page-feedback-submit') as HTMLButtonElement | null;
    const captchaContainer = document.getElementById('page-feedback-captcha');
    const hcaptchaSiteKey = root?.dataset.hcaptchaSitekey || '';
    const hcaptchaLanguage = root?.dataset.hcaptchaLanguage || 'en';
    let captchaWidgetId: string | number | null = null;
    let captchaLoading = false;

    function getHcaptcha(): HcaptchaApi | undefined {
        return (window as Window & { hcaptcha?: HcaptchaApi }).hcaptcha;
    }

    function setMessage(text: string, type: 'error' | 'success') {
        if (!message) return;

        message.textContent = text;
        message.className = type === 'success'
            ? 'text-sm font-medium text-green-300'
            : 'text-sm font-medium text-red-300';
        message.classList.remove('hidden');
    }

    function clearMessage() {
        if (!message) return;

        message.textContent = '';
        message.className = 'hidden text-sm font-medium';
    }

    function getMessage(key: string, fallback: string) {
        return root?.dataset[key] || fallback;
    }

    function renderCaptcha() {
        const hcaptcha = getHcaptcha();
        if (!hcaptcha || !captchaContainer || !hcaptchaSiteKey || captchaWidgetId !== null) return;

        captchaWidgetId = hcaptcha.render(captchaContainer, {
            sitekey: hcaptchaSiteKey,
            theme: 'dark',
            hl: hcaptchaLanguage,
        });
    }

    function loadCaptcha() {
        if (getHcaptcha()) {
            renderCaptcha();
            return;
        }

        if (captchaLoading) return;
        captchaLoading = true;

        const script = document.createElement('script');
        script.src = `https://js.hcaptcha.com/1/api.js?render=explicit&hl=${encodeURIComponent(hcaptchaLanguage)}`;
        script.async = true;
        script.defer = true;
        script.addEventListener('load', renderCaptcha, { once: true });
        document.head.appendChild(script);
    }

    function openDialog() {
        if (!dialog || !openButton || !openedAtInput) return;

        openedAtInput.value = String(Date.now());
        dialog.classList.remove('hidden');
        dialog.classList.add('flex');
        openButton.setAttribute('aria-expanded', 'true');
        clearMessage();
        loadCaptcha();
    }

    function closeDialog() {
        if (!dialog || !openButton) return;

        dialog.classList.add('hidden');
        dialog.classList.remove('flex');
        openButton.setAttribute('aria-expanded', 'false');
    }

    function selectRating(rating: string) {
        if (!ratingInput) return;

        ratingInput.value = rating;
        document.querySelectorAll<HTMLButtonElement>('.page-feedback-rating').forEach((button) => {
            const selected = button.dataset.rating === rating;
            button.classList.toggle('border-amber-300', selected);
            button.classList.toggle('bg-amber-400/20', selected);
            button.setAttribute('aria-pressed', String(selected));
        });
    }

    openButton?.addEventListener('click', openDialog);

    document.querySelectorAll('[data-feedback-close]').forEach((element) => {
        element.addEventListener('click', closeDialog);
    });

    document.querySelectorAll<HTMLButtonElement>('.page-feedback-rating').forEach((button) => {
        button.addEventListener('click', () => {
            selectRating(button.dataset.rating || '');
            clearMessage();
        });
    });

    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && dialog && !dialog.classList.contains('hidden')) {
            closeDialog();
        }
    });

    form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!form || !submitButton || !ratingInput) return;

        const feedbackText = (form.querySelector('[name="feedback"]') as HTMLTextAreaElement | null)?.value.trim() || '';
        if (!ratingInput.value) {
            setMessage(getMessage('messageChooseRating', 'Please choose yes or not really.'), 'error');
            return;
        }

        if (ratingInput.value === 'not_helpful' && !feedbackText) {
            setMessage(getMessage('messageNegativeRequired', 'Please tell us what you expected, wanted changed, or wanted added.'), 'error');
            return;
        }

        const hcaptcha = getHcaptcha();
        const hcaptchaToken = hcaptcha && captchaWidgetId !== null ? hcaptcha.getResponse(captchaWidgetId) : '';
        if (!hcaptchaToken) {
            setMessage(getMessage('messageCaptchaRequired', 'Please complete the captcha.'), 'error');
            return;
        }

        submitButton.disabled = true;
        clearMessage();

        const payload = {
            ...Object.fromEntries(new FormData(form).entries()),
            hcaptchaToken,
            pageUrl: window.location.href,
            pageTitle: document.title,
            lang: root?.dataset.lang || document.documentElement.lang || 'en',
            referrer: document.referrer,
        };

        try {
            const response = await fetch('/api/page-feedback', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
            });
            const data = await response.json().catch(() => ({}));

            if (!response.ok || !data.success) {
                const fallbackError = data.errorCode === 'captcha_failed'
                    ? getMessage('messageCaptchaFailed', 'Captcha verification failed. Please try again.')
                    : getMessage('messageFailure', 'Failed to send feedback.');
                throw new Error(fallbackError);
            }

            setMessage(getMessage('messageSuccess', 'Thanks - your feedback was sent.'), 'success');
            form.reset();
            selectRating('');
            if (captchaWidgetId !== null) {
                hcaptcha?.reset(captchaWidgetId);
            }
            setTimeout(closeDialog, 1800);
        } catch (error) {
            setMessage(error instanceof Error ? error.message : getMessage('messageFailure', 'Failed to send feedback.'), 'error');
            if (captchaWidgetId !== null) {
                hcaptcha?.reset(captchaWidgetId);
            }
        } finally {
            submitButton.disabled = false;
        }
    });
</script>
