---
/**
 * EmailCapture.astro
 * Popup/banner component to collect email subscribers
 * Appears after 30 seconds on any page
 */
import { getTranslations, type SupportedLocale } from '../lib/i18n';
import { buildSafeLeadSubtitle, hasUnsupportedSocialProof } from '../lib/marketing-copy';

interface Props {
  lang?: string;
  inline?: boolean; // If true, renders as inline banner instead of popup
}

const { lang = 'en', inline = false } = Astro.props;

const translations = getTranslations(lang as SupportedLocale);
const localizedEmailCapture = translations.emailCapture;
const fallbackSubtitle = buildSafeLeadSubtitle(
  localizedEmailCapture?.title || 'Get Your Free 7-Day Horoscope',
  translations.promo?.delivery || 'Instant delivery to your email'
);
const t = {
  title: localizedEmailCapture?.title || '✨ Get Your Free 7-Day Horoscope',
  subtitle: localizedEmailCapture?.subtitle && !hasUnsupportedSocialProof(localizedEmailCapture.subtitle)
    ? localizedEmailCapture.subtitle
    : fallbackSubtitle,
  placeholder: localizedEmailCapture?.placeholder || 'Enter your email',
  button: localizedEmailCapture?.button || 'Get My Free Horoscope',
  consent: localizedEmailCapture?.consent || 'I agree to receive cosmic insights and accept the privacy policy.',
  success: localizedEmailCapture?.success || '✨ Welcome! Your free 7-day horoscope is on the way.',
  error: localizedEmailCapture?.error || 'Something went wrong. Please try again.',
  validation: 'Please enter your email and accept consent.',
};
---

{inline ? (
  <!-- Inline Banner Version -->
  <div class="email-capture-inline my-12 glass-strong rounded-3xl p-8 sm:p-10 border border-purple-500/30 bg-gradient-to-br from-purple-500/10 via-slate-900/40 to-transparent shadow-2xl relative overflow-hidden">
    <div class="absolute -top-24 -right-24 w-48 h-48 bg-purple-500/20 blur-[80px] rounded-full"></div>
    <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-amber-500/10 blur-[80px] rounded-full"></div>
    
    <div class="relative z-10 text-center">
      <h3 class="text-3xl sm:text-4xl font-black text-white mb-3">{t.title}</h3>
      <p class="text-white/70 text-lg mb-6 max-w-xl mx-auto">{t.subtitle}</p>
      
      <form
        class="email-capture-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-4"
        data-lang={lang}
        data-button-text={t.button}
        data-success-message={t.success}
        data-error-message={t.error}
        data-validation-message={t.validation}
      >
        <input 
          type="email" 
          name="email"
          autocomplete="email"
          placeholder={t.placeholder}
          required
          class="flex-1 px-5 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30 text-lg"
        />
        <button 
          type="submit"
          class="px-8 py-4 bg-gradient-to-r from-purple-500 to-amber-500 text-white font-bold text-lg rounded-xl hover:opacity-90 transition-all hover:scale-105 shadow-lg whitespace-nowrap"
        >
          {t.button}
        </button>
      </form>
      
      <label class="flex items-center justify-center gap-2 text-white/50 text-sm cursor-pointer">
        <input type="checkbox" name="gdprConsent" checked class="w-4 h-4 rounded accent-purple-500" />
        <span>{t.consent}</span>
      </label>
      
      <p class="email-capture-message mt-4 text-lg font-medium hidden"></p>
    </div>
  </div>
) : (
  <!-- Popup Version -->
  <div id="email-capture-popup" class="fixed inset-0 z-[9999] flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" data-close-popup></div>
    
    <!-- Modal -->
    <div class="relative glass-strong rounded-3xl p-8 sm:p-10 max-w-lg w-full border border-purple-500/30 bg-gradient-to-br from-purple-600/20 via-slate-900/80 to-amber-600/10 shadow-2xl transform scale-95 transition-transform duration-300">
      <!-- Close button -->
      <button data-close-popup class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/10 flex items-center justify-center text-white/70 hover:text-white hover:bg-white/20 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      
      <!-- Decorative elements -->
      <div class="absolute -top-20 -right-20 w-40 h-40 bg-purple-500/30 blur-[60px] rounded-full"></div>
      <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-amber-500/20 blur-[60px] rounded-full"></div>
      
      <div class="relative z-10 text-center">
        <div class="text-6xl mb-4">✨</div>
        <h3 class="text-3xl sm:text-4xl font-black text-white mb-3">{t.title}</h3>
        <p class="text-white/70 text-lg mb-6">{t.subtitle}</p>
        
        <form
          class="email-capture-form flex flex-col gap-3 mb-4"
          data-lang={lang}
          data-button-text={t.button}
          data-success-message={t.success}
          data-error-message={t.error}
          data-validation-message={t.validation}
        >
          <input 
            type="email" 
            name="email"
            autocomplete="email"
            placeholder={t.placeholder}
            required
            class="w-full px-5 py-4 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-purple-400 focus:ring-2 focus:ring-purple-400/30 text-lg"
          />
          <button 
            type="submit"
            class="w-full px-8 py-4 bg-gradient-to-r from-purple-500 to-amber-500 text-white font-bold text-lg rounded-xl hover:opacity-90 transition-all hover:scale-[1.02] shadow-lg"
          >
            {t.button}
          </button>
        </form>
        
        <label class="flex items-center justify-center gap-2 text-white/50 text-sm cursor-pointer">
          <input type="checkbox" name="gdprConsent" checked class="w-4 h-4 rounded accent-purple-500" />
          <span>{t.consent}</span>
        </label>
        
        <p class="email-capture-message mt-4 text-lg font-medium hidden"></p>
      </div>
    </div>
  </div>
)}

<script>
  // Popup logic (only runs for popup version)
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('email-capture-popup');
    if (!popup) return;
    
    // Check if user has already dismissed or subscribed
    const dismissed = localStorage.getItem('emailCaptureHidden');
    if (dismissed) return;
    
    // Show popup after 30 seconds
    setTimeout(() => {
      popup.classList.remove('opacity-0', 'pointer-events-none');
      popup.querySelector('.relative')?.classList.remove('scale-95');
    }, 30000);
    
    // Close handlers
    popup.querySelectorAll('[data-close-popup]').forEach(el => {
      el.addEventListener('click', () => {
        popup.classList.add('opacity-0', 'pointer-events-none');
        localStorage.setItem('emailCaptureHidden', 'true');
      });
    });
  });
  
  // Form submission logic (works for both popup and inline)
  document.querySelectorAll('.email-capture-form').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formEl = e.target as HTMLFormElement;
      const emailInput = formEl.querySelector('input[name="email"]') as HTMLInputElement;
      const consentInput = formEl.closest('.email-capture-inline, #email-capture-popup')?.querySelector('input[name="gdprConsent"]') as HTMLInputElement;
      const messageEl = formEl.closest('.email-capture-inline, .relative')?.querySelector('.email-capture-message') as HTMLElement;
      const button = formEl.querySelector('button[type="submit"]') as HTMLButtonElement;
      const lang = formEl.dataset.lang || 'en';
      const captureSource = formEl.closest('.email-capture-inline') ? 'inline' : 'popup';
      const defaultButtonText = formEl.dataset.buttonText || button.textContent || 'Get My Free Horoscope';
      const successMessage = formEl.dataset.successMessage || '✨ Welcome! Your free 7-day horoscope is on the way.';
      const errorMessage = formEl.dataset.errorMessage || 'Something went wrong. Please try again.';
      const validationMessage = formEl.dataset.validationMessage || 'Please enter your email and accept consent.';
      
      if (!emailInput.value || !consentInput?.checked) {
        messageEl.textContent = validationMessage;
        messageEl.className = 'email-capture-message mt-4 text-lg font-medium text-red-400';
        messageEl.classList.remove('hidden');
        return;
      }
      
      button.disabled = true;
      button.textContent = '⏳';
      
      try {
        const response = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput.value,
            source: captureSource,
            lang,
            gdprConsent: true
          })
        });
        
        const data = await response.json();
        
        if (data.success) {
          const isNewSignup = data.message !== 'Already subscribed';
          const track = window['astraloTrack'];
          if (isNewSignup && typeof track === 'function') {
            track('sign_up', {
              method: 'email_capture',
              signup_surface: captureSource,
              language: lang,
            });
          }

          messageEl.textContent = successMessage;
          messageEl.className = 'email-capture-message mt-4 text-lg font-medium text-green-400';
          messageEl.classList.remove('hidden');
          formEl.reset();
          localStorage.setItem('emailCaptureHidden', 'true');
          
          // Close popup after success
          setTimeout(() => {
            document.getElementById('email-capture-popup')?.classList.add('opacity-0', 'pointer-events-none');
          }, 2000);
        } else {
          throw new Error(data.error);
        }
        } catch (err) {
          messageEl.textContent = errorMessage;
          messageEl.className = 'email-capture-message mt-4 text-lg font-medium text-red-400';
          messageEl.classList.remove('hidden');
          button.disabled = false;
          button.textContent = defaultButtonText;
        }
      });
  });
</script>
