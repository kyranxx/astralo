---
/**
 * BlogCTA.astro
 * High-conversion call-to-action component for blog articles
 */
import { Star, ArrowRight, Sparkles } from 'lucide-astro';
import { getProductPriceInEuros, getProductName, type ProductKey } from '../lib/products';
import { getProductLandingPath } from '../lib/seo';
import { buildInternalCampaignUrl } from '../lib/internal-campaign';
import { getTranslations, type SupportedLocale } from '../lib/i18n';

interface Props {
  productKey?: ProductKey;
  lang?: string;
  sourceSlug?: string;
  surface?: string;
}

const { productKey = 'monthly', lang = 'en', sourceSlug = 'blog_article', surface = 'mid_article_cta' } = Astro.props;
const price = getProductPriceInEuros(productKey);
const productName = getProductName(productKey, lang);
const t = getTranslations(lang as SupportedLocale);
const ctaHref = getProductLandingPath(lang as SupportedLocale, productKey);
const trackedCtaHref = buildInternalCampaignUrl(ctaHref, {
    source: 'blog',
    campaign: sourceSlug,
    content: surface,
});

// Selection of compelling CTA texts based on product
const productCTAs = {
    daily: {
        title: "Ready for your day?",
        description: "Get precise hourly guidance based on your birth chart."
    },
    weekly: {
        title: "Plan your week ahead",
        description: "Discover your lucky days and potential challenges."
    },
    monthly: {
        title: "Your month at a glance",
        description: "Our most detailed report including love, career, and finance."
    },
    partner: {
        title: "Is it written in the stars?",
        description: "Deep dive into your compatibility and shared future."
    },
    lifetime: {
        title: "Want the full life map?",
        description: "Get a deeper lifetime reading for long-term patterns and timing."
    }
};

const content = productCTAs[productKey as keyof typeof productCTAs];
---

<div class="my-12 glass-strong rounded-2xl p-8 sm:p-10 border border-white/10 relative overflow-hidden group">
  <div class="relative z-10 flex flex-col md:flex-row items-center gap-8">
    <div class="flex-1 text-center md:text-left">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold uppercase tracking-wider mb-4">
        <Sparkles class="w-3 h-3" />
        Most Accurate Reading
      </div>
      <h3 class="text-3xl sm:text-4xl font-bold text-white mb-3 tracking-tight">
        {content.title}
      </h3>
      <p class="text-white/70 text-lg mb-6 leading-relaxed">
        {content.description}
      </p>
      
      <div class="flex flex-wrap items-center justify-center md:justify-start gap-4 text-sm font-medium text-white/50">
        <span class="flex items-center gap-1.5"><Star class="w-4 h-4 text-amber-500 fill-amber-500" /> 15+ pages</span>
        <span class="flex items-center gap-1.5"><Star class="w-4 h-4 text-amber-500 fill-amber-500" /> Instant PDF</span>
        <span class="flex items-center gap-1.5"><Star class="w-4 h-4 text-amber-500 fill-amber-500" /> Secure payment</span>
      </div>
    </div>

    <div class="w-full md:w-auto flex flex-col items-center gap-4">
      <div class="text-center">
        <div class="text-4xl font-black text-white leading-none mb-1">€{price.toFixed(2)}</div>
        <div class="text-amber-500 text-xs font-bold uppercase tracking-wider">{t.promo.secure}</div>
      </div>

      <a
        href={trackedCtaHref}
        class="w-full md:w-64 inline-flex items-center justify-center gap-3 px-8 py-5 bg-amber-500 text-black font-bold text-lg rounded-xl hover:bg-amber-400 transition-colors"
        data-astralo-track-click="blog_product_click"
        data-blog-slug={sourceSlug}
        data-click-surface={surface}
        data-product-key={productKey}
        data-language={lang}
      >
        Get My {productName.split(' ')[0]}
        <ArrowRight class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
      </a>
      
      <p class="text-white/40 text-[10px] uppercase tracking-widest font-bold">{t.promo.delivery}</p>
    </div>
  </div>
</div>
