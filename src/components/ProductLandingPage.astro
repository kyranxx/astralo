---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import FAQ from './FAQ.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ZodiacSignGrid from './ZodiacSignGrid.astro';
import { ArrowLeft, BookOpen, Clock, Mail, Shield, Sparkles, Star, Zap } from 'lucide-astro';
import { getTranslations, type SupportedLocale } from '../lib/i18n';
import { getProductCopy, getProductPriceInEuros, type ProductKey } from '../lib/products';
import { buildProductLandingDescription, getProductLandingSeoContent } from '../lib/product-landing-seo';
import { blogUiTranslations } from '../lib/blog/ui-translations';
import {
    buildBreadcrumbSchema,
    buildFaqSchema,
    buildProductOfferSchema,
    buildProductServiceSchema,
    buildWebPageSchema,
    getFormPath,
    getFreeHoroscopePath,
    getGeneralFaqEntries,
    getHomePath,
    getProductLandingPath,
    siteUrl,
} from '../lib/seo';

interface Props {
    lang: SupportedLocale;
    type: ProductKey;
}

const { lang, type } = Astro.props;
const t = getTranslations(lang);
const ui = blogUiTranslations[lang] || blogUiTranslations.en;
const product = getProductCopy(type, lang, t);
const homePath = getHomePath(lang);
const formPath = getFormPath(lang, type);
const freeHoroscopePath = getFreeHoroscopePath(lang);
const landingPath = getProductLandingPath(lang, type);
const pageUrl = `${siteUrl}${landingPath}`;
const productPrice = getProductPriceInEuros(type);
const generalFaqs = getGeneralFaqEntries(t, lang);
const productSeoContent = getProductLandingSeoContent(lang, type);

const pageTitle = `${product.name} | ${t.header.badge} | Astralo`;
const seoDescription = buildProductLandingDescription(t, type, lang);
const seoKeywords = [
    product.name,
    t.header.badge,
    product.description,
    ...product.benefits.map((benefit) => benefit.replace(/^[^\s]+\s*/, '').trim()),
].join(', ');

const pageSchema = [
    buildWebPageSchema({
        url: pageUrl,
        title: pageTitle,
        description: seoDescription,
        lang,
    }),
    buildBreadcrumbSchema([
        { name: ui.home, url: `${siteUrl}${homePath === '/' ? '' : homePath.replace(/\/$/, '')}` || siteUrl },
        { name: product.name, url: pageUrl },
    ]),
    buildProductServiceSchema({
        lang,
        productKey: type,
        description: seoDescription,
        pageUrl,
    }),
    buildProductOfferSchema({
        lang,
        productKey: type,
        description: seoDescription,
        pageUrl,
        image: `${siteUrl}/pdf-sample-preview.webp`,
    }),
    buildFaqSchema([
        ...generalFaqs,
        ...(productSeoContent?.faqs || []),
    ]),
];

---

<Layout
    title={pageTitle}
    description={seoDescription}
    keywords={seoKeywords}
    lang={lang}
    schema={pageSchema}
>
    <div class="min-h-screen flex flex-col relative z-10">
        <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
            <div class="max-w-6xl mx-auto px-4 py-3">
                <div class="flex items-center justify-between">
                    <a href={homePath} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
                        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                        <span class="text-sm">{t.form.back || 'Home'}</span>
                    </a>
                    <a href={homePath} class="block hover:opacity-80 transition-opacity">
                        <img src="/logo.webp" alt="Astralo" class="h-10" style="aspect-ratio: 3.41;" />
                    </a>
                    <LanguageSwitcher lang={lang} />
                </div>
            </div>
        </header>

        <main class="flex-1 px-4 py-10 sm:py-14">
            <div class="max-w-6xl mx-auto space-y-10">
                <section class="glass-strong rounded-2xl p-6 sm:p-10 border border-white/10">
                    <div class="grid lg:grid-cols-[1.2fr_.8fr] gap-8 items-center">
                        <div>
                            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 border border-amber-400/20 text-amber-300 text-xs font-bold uppercase tracking-[0.2em] mb-5">
                                <Sparkles class="w-4 h-4" />
                                {t.header.badge}
                            </div>
                            <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">{product.name}</h1>
                            <p class="text-white/75 text-lg leading-relaxed max-w-3xl mb-6">{product.description}</p>

                            <div class="flex flex-wrap gap-3 mb-8">
                                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm">
                                    <Clock class="w-4 h-4 text-amber-400" />
                                    <span>{t.promo.delivery}</span>
                                </div>
                                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm">
                                    <Shield class="w-4 h-4 text-amber-400" />
                                    <span>{t.promo.secure}</span>
                                </div>
                            </div>

                            <div class="grid sm:grid-cols-2 gap-3">
                                {product.benefits.map((benefit) => (
                                    <div class="flex items-center gap-3 rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-white/85">
                                        <span class="text-lg leading-none">{benefit.split(' ')[0]}</span>
                                        <span>{benefit.split(' ').slice(1).join(' ')}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="rounded-2xl bg-white/5 border border-white/10 p-6 sm:p-8 text-center">
                            <p class="text-white/60 text-sm uppercase mb-2">{t.promo.delivery}</p>
                            <div class="flex items-end justify-center mb-6">
                                <span class="text-5xl font-black text-white leading-none">{productPrice.toFixed(2)} EUR</span>
                            </div>

                            <a
                                href={formPath}
                                class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-amber-500 px-6 py-4 text-black font-bold text-base hover:bg-amber-400 transition-colors"
                            >
                                <Zap class="w-5 h-5" />
                                <span>{t.form.submit}</span>
                            </a>
                            <a
                                href={freeHoroscopePath}
                                class="mt-3 inline-flex w-full items-center justify-center rounded-2xl border border-white/15 bg-white/5 px-6 py-3 text-white font-medium hover:border-amber-400/40 transition-colors"
                            >
                                {t.emailCapture?.button || 'Get My Free Horoscope'}
                            </a>

                            <div class="mt-6 pt-6 border-t border-white/10 space-y-3 text-left text-sm text-white/70">
                                <div class="flex items-center gap-2">
                                    <Mail class="w-4 h-4 text-amber-400" />
                                    <span>{t.pdfPreview?.footer || 'Instant PDF delivery to your email'}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <BookOpen class="w-4 h-4 text-amber-400" />
                                    <span>{product.wordCount}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <Star class="w-4 h-4 text-amber-400" />
                                    <span>{t.whyUs.professional.description}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                {productSeoContent && (
                    <section class="glass-strong rounded-2xl p-6 sm:p-8 border border-white/10">
                        <div class="max-w-3xl mb-8">
                            <p class="text-amber-300 text-xs font-bold uppercase mb-3">{productSeoContent.eyebrow}</p>
                            <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{productSeoContent.title}</h2>
                            <p class="text-white/70 leading-relaxed">{productSeoContent.intro}</p>
                        </div>

                        <div class="grid md:grid-cols-3 gap-5 mb-8">
                            {productSeoContent.points.map((point) => (
                                <article class="border-l border-amber-400/40 pl-4">
                                    <h3 class="text-lg font-bold text-white mb-2">{point.title}</h3>
                                    <p class="text-white/65 text-sm leading-relaxed">{point.body}</p>
                                </article>
                            ))}
                        </div>

                        <div class="grid md:grid-cols-3 gap-5 border-t border-white/10 pt-6">
                            {productSeoContent.faqs.map((faq) => (
                                <article>
                                    <h3 class="text-white font-bold mb-2">{faq.question}</h3>
                                    <p class="text-white/65 text-sm leading-relaxed">{faq.answer}</p>
                                </article>
                            ))}
                        </div>
                    </section>
                )}

                <section class="grid lg:grid-cols-[1fr_.9fr] gap-8">
                    <div class="glass-strong rounded-2xl p-6 sm:p-8 border border-white/10">
                        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{t.pdfPreview?.title || 'What You Will Receive'}</h2>
                        <p class="text-white/70 leading-relaxed mb-6">
                            {seoDescription}
                        </p>
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.pdfReport || 'Detailed PDF report'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.pages || '15+ pages of insight'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.personal || 'Personal analysis'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.birthTime || 'Based on exact birth time'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.predictions || 'Future predictions'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.transits || 'Transits and progressions'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.advice || 'Actionable advice'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.careerLove || 'For career and love'}</p>
                            </div>
                        </div>
                    </div>

                    <div class="glass-strong rounded-2xl p-6 sm:p-8 border border-white/10">
                        <div class="flex items-center justify-between gap-4 mb-5">
                            <h2 class="text-2xl sm:text-3xl font-bold text-white">{t.pdfPreview?.title || 'PDF Preview'}</h2>
                            <span class="rounded-full bg-amber-500/15 px-3 py-1 text-xs font-bold text-amber-300">PDF</span>
                        </div>
                        <div class="rounded-2xl bg-white/[0.04] border border-white/10 p-4">
                            <img
                                src="/pdf-sample-preview.webp"
                                alt={`${product.name} PDF`}
                                class="w-full rounded-xl border border-white/10"
                                loading="eager"
                                decoding="async"
                                width="574"
                                height="574"
                            />
                        </div>
                    </div>
                </section>

                {type !== 'lifetime' && <ZodiacSignGrid lang={lang} type={type} />}

                <FAQ lang={lang} />
            </div>
        </main>

        <Footer lang={lang} />
    </div>
</Layout>

<script
    is:inline
    define:vars={{
        type,
        lang,
        productName: product.name,
        productPrice,
    }}
>
    (function () {
        var track = window['astraloTrack'];
        if (typeof track !== 'function') return;

        var normalizedPrice = Number(Number(productPrice).toFixed(2));
        track('view_item', {
            currency: 'EUR',
            value: normalizedPrice,
            page_type: 'product_landing',
            language: lang,
            items: [
                {
                    item_id: type,
                    item_name: productName,
                    item_category: 'horoscope',
                    item_variant: lang,
                    price: normalizedPrice,
                    quantity: 1,
                },
            ],
        });
    })();
</script>
