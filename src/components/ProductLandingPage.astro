---
import Layout from '../layouts/Layout.astro';
import Footer from './Footer.astro';
import FAQ from './FAQ.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import ZodiacSignGrid from './ZodiacSignGrid.astro';
import { ArrowLeft, ArrowRight, BookOpen, Clock, Mail, Shield, Sparkles, Star, Zap } from 'lucide-astro';
import { getTranslations, type SupportedLocale } from '../lib/i18n';
import { getTestimonials } from '../lib/testimonials';
import { getArticleMeta, getArticleTranslation, getBlogUiTranslations } from '../lib/blog';
import { getProductOriginalPriceInEuros, getProductPriceInEuros, type ProductKey } from '../lib/products';
import {
    buildBreadcrumbSchema,
    buildFaqSchema,
    buildProductServiceSchema,
    buildWebPageSchema,
    getFormPath,
    getFreeHoroscopePath,
    getGeneralFaqEntries,
    getHomePath,
    getProductLandingPath,
    siteUrl,
} from '../lib/seo';

interface Props {
    lang: SupportedLocale;
    type: ProductKey;
}

const { lang, type } = Astro.props;
const t = getTranslations(lang);
const blogUi = getBlogUiTranslations(lang);
const product = t.products[type];
const testimonials = getTestimonials(lang).slice(0, 3);
const homePath = getHomePath(lang);
const formPath = getFormPath(lang, type);
const freeHoroscopePath = getFreeHoroscopePath(lang);
const landingPath = getProductLandingPath(lang, type);
const pageUrl = `${siteUrl}${landingPath}`;
const productPrice = getProductPriceInEuros(type);
const originalPrice = getProductOriginalPriceInEuros(type);
const generalFaqs = getGeneralFaqEntries(t);

const relatedArticleSlugs: Record<ProductKey, string[]> = {
    daily: ['daily-horoscope-guide', 'weekly-horoscope-predictions', 'mercury-retrograde-survival-guide'],
    weekly: ['weekly-horoscope-predictions', 'daily-horoscope-guide', 'mercury-retrograde-survival-guide'],
    monthly: ['monthly-horoscope-april-2026', 'birth-chart-reading-explained', 'daily-horoscope-guide'],
    partner: ['zodiac-compatibility-complete-guide', 'love-horoscope-relationship-advice', 'twin-flames-and-soulmates-astrology'],
};

const relatedArticles = relatedArticleSlugs[type]
    .map((slug) => {
        const meta = getArticleMeta(slug);
        const translation = getArticleTranslation(slug, lang);
        return meta && translation ? { slug, meta, translation } : null;
    })
    .filter((article): article is { slug: string; meta: NonNullable<ReturnType<typeof getArticleMeta>>; translation: NonNullable<ReturnType<typeof getArticleTranslation>> } => article !== null);

const pageTitle = `${product.name} | ${t.header.badge} | Astralo`;
const seoDescription = `${product.name} from Astralo. ${product.description}. ${t.promo.delivery}. ${t.promo.secure}.`;
const seoKeywords = [
    product.name,
    t.header.badge,
    product.description,
    ...product.benefits.map((benefit) => benefit.replace(/^[^\s]+\s*/, '').trim()),
].join(', ');

const pageSchema = [
    buildWebPageSchema({
        url: pageUrl,
        title: pageTitle,
        description: seoDescription,
        lang,
    }),
    buildBreadcrumbSchema([
        { name: 'Home', url: `${siteUrl}${homePath === '/' ? '' : homePath.replace(/\/$/, '')}` || siteUrl },
        { name: product.name, url: pageUrl },
    ]),
    buildProductServiceSchema({
        lang,
        productKey: type,
        description: seoDescription,
        pageUrl,
    }),
    buildFaqSchema(generalFaqs),
];

const checklist = type === 'partner'
    ? [t.form.name, t.form.email, t.form.birthDate, t.form.birthTime, t.form.birthPlace, t.form.partnerName, t.form.partnerBirthDate, t.form.partnerBirthTime, t.form.partnerBirthPlace]
    : [t.form.name, t.form.email, t.form.birthDate, t.form.birthTime, t.form.birthPlace];
---

<Layout
    title={pageTitle}
    description={seoDescription}
    keywords={seoKeywords}
    lang={lang}
    schema={pageSchema}
>
    <div class="min-h-screen flex flex-col relative z-10">
        <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
            <div class="max-w-6xl mx-auto px-4 py-3">
                <div class="flex items-center justify-between">
                    <a href={homePath} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
                        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
                        <span class="text-sm">{t.form.back || 'Home'}</span>
                    </a>
                    <a href={homePath} class="block hover:opacity-80 transition-opacity">
                        <img src="/logo.webp" alt="Astralo" class="h-10" style="aspect-ratio: 3.41;" />
                    </a>
                    <LanguageSwitcher lang={lang} />
                </div>
            </div>
        </header>

        <main class="flex-1 px-4 py-10 sm:py-14">
            <div class="max-w-6xl mx-auto space-y-10">
                <section class="glass-strong rounded-3xl p-6 sm:p-10 border border-white/10">
                    <div class="grid lg:grid-cols-[1.2fr_.8fr] gap-8 items-center">
                        <div>
                            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-amber-500/10 border border-amber-400/20 text-amber-300 text-xs font-bold uppercase tracking-[0.2em] mb-5">
                                <Sparkles class="w-4 h-4" />
                                {t.header.badge}
                            </div>
                            <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">{product.name}</h1>
                            <p class="text-white/75 text-lg leading-relaxed max-w-3xl mb-6">{product.description}</p>

                            <div class="flex flex-wrap gap-3 mb-8">
                                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm">
                                    <Clock class="w-4 h-4 text-amber-400" />
                                    <span>{t.promo.delivery}</span>
                                </div>
                                <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm">
                                    <Shield class="w-4 h-4 text-amber-400" />
                                    <span>{t.promo.secure}</span>
                                </div>
                            </div>

                            <div class="grid sm:grid-cols-2 gap-3">
                                {product.benefits.map((benefit) => (
                                    <div class="flex items-center gap-3 rounded-2xl bg-white/5 border border-white/10 px-4 py-3 text-white/85">
                                        <span class="text-lg leading-none">{benefit.split(' ')[0]}</span>
                                        <span>{benefit.split(' ').slice(1).join(' ')}</span>
                                    </div>
                                ))}
                            </div>
                        </div>

                        <div class="rounded-3xl bg-white/5 border border-white/10 p-6 sm:p-8 text-center">
                            <p class="text-white/60 text-sm uppercase tracking-[0.3em] mb-2">Today&apos;s Price</p>
                            <div class="flex items-end justify-center gap-3 mb-2">
                                <span class="text-white/40 text-xl line-through">{originalPrice.toFixed(2)} EUR</span>
                                <span class="text-5xl font-black text-white leading-none">{productPrice.toFixed(2)} EUR</span>
                            </div>
                            <p class="text-amber-400 font-bold uppercase tracking-[0.25em] text-xs mb-6">50% off</p>

                            <a
                                href={formPath}
                                class="inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-amber-500 px-6 py-4 text-black font-bold text-base hover:bg-amber-400 transition-colors"
                            >
                                <Zap class="w-5 h-5" />
                                <span>{t.form.submit}</span>
                            </a>
                            <a
                                href={freeHoroscopePath}
                                class="mt-3 inline-flex w-full items-center justify-center rounded-2xl border border-white/15 bg-white/5 px-6 py-3 text-white font-medium hover:border-amber-400/40 transition-colors"
                            >
                                {t.emailCapture?.button || 'Get My Free Horoscope'}
                            </a>

                            <div class="mt-6 pt-6 border-t border-white/10 space-y-3 text-left text-sm text-white/70">
                                <div class="flex items-center gap-2">
                                    <Mail class="w-4 h-4 text-amber-400" />
                                    <span>{t.pdfPreview?.footer || 'Instant PDF delivery to your email'}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <BookOpen class="w-4 h-4 text-amber-400" />
                                    <span>{product.wordCount}</span>
                                </div>
                                <div class="flex items-center gap-2">
                                    <Star class="w-4 h-4 text-amber-400" />
                                    <span>{t.whyUs.professional.description}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="grid lg:grid-cols-[1fr_.9fr] gap-8">
                    <div class="glass-strong rounded-3xl p-6 sm:p-8 border border-white/10">
                        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{t.pdfPreview?.title || 'What You Will Receive'}</h2>
                        <p class="text-white/70 leading-relaxed mb-6">
                            {seoDescription}
                        </p>
                        <div class="grid sm:grid-cols-2 gap-4">
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.pdfReport || 'Detailed PDF report'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.pages || '15+ pages of insight'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.personal || 'Personal analysis'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.birthTime || 'Based on exact birth time'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.predictions || 'Future predictions'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.transits || 'Transits and progressions'}</p>
                            </div>
                            <div class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <p class="text-white font-semibold mb-2">{t.benefits?.advice || 'Actionable advice'}</p>
                                <p class="text-white/60 text-sm">{t.benefits?.careerLove || 'For career and love'}</p>
                            </div>
                        </div>
                    </div>

                    <div class="glass-strong rounded-3xl p-6 sm:p-8 border border-white/10">
                        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-4">{t.form.title}</h2>
                        <p class="text-white/70 leading-relaxed mb-6">
                            {t.form.description}
                        </p>
                        <div class="space-y-3">
                            {checklist.map((item, index) => (
                                <div class="flex items-center gap-3 rounded-2xl bg-white/5 border border-white/10 px-4 py-3">
                                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-amber-500/15 text-amber-400 text-sm font-bold">
                                        {index + 1}
                                    </div>
                                    <span class="text-white/85">{item}</span>
                                </div>
                            ))}
                        </div>
                    </div>
                </section>

                <section class="glass-strong rounded-3xl p-6 sm:p-8 border border-white/10">
                    <div class="flex items-center gap-3 mb-6">
                        <Star class="w-6 h-6 text-amber-400" />
                        <h2 class="text-2xl sm:text-3xl font-bold text-white">{t.testimonials.title}</h2>
                    </div>
                    <div class="grid md:grid-cols-3 gap-4">
                        {testimonials.map((testimonial) => (
                            <article class="rounded-2xl bg-white/5 border border-white/10 p-5">
                                <div class="flex items-center gap-1 mb-3">
                                    {[...Array(testimonial.rating)].map(() => (
                                        <Star class="w-4 h-4 text-amber-400 fill-amber-400" />
                                    ))}
                                </div>
                                <p class="text-white/85 leading-relaxed mb-4">&quot;{testimonial.text}&quot;</p>
                                <p class="text-white font-semibold">{testimonial.name}</p>
                                <p class="text-white/50 text-sm">{testimonial.location}</p>
                            </article>
                        ))}
                    </div>
                </section>

                {relatedArticles.length > 0 && (
                    <section class="glass-strong rounded-3xl p-6 sm:p-8 border border-white/10">
                        <div class="flex items-center gap-3 mb-6">
                            <BookOpen class="w-6 h-6 text-amber-400" />
                            <h2 class="text-2xl sm:text-3xl font-bold text-white">{blogUi.blogTitle}</h2>
                        </div>
                        <div class="grid md:grid-cols-3 gap-4">
                            {relatedArticles.map((article) => (
                                <a href={lang === 'en' ? `/blog/${article.slug}` : `/${lang}/blog/${article.slug}`} class="rounded-2xl bg-white/5 border border-white/10 p-5 hover:border-amber-400/40 transition-colors">
                                    <div class="flex items-start gap-3 mb-3">
                                        <span class="text-2xl">{article.meta.emoji}</span>
                                        <div>
                                            <p class="text-amber-400 text-xs uppercase tracking-[0.2em] mb-1">{article.translation.category}</p>
                                            <h3 class="text-white font-semibold leading-snug">{article.translation.title}</h3>
                                        </div>
                                    </div>
                                    <p class="text-white/60 text-sm mb-4">{article.translation.excerpt}</p>
                                    <span class="inline-flex items-center gap-2 text-amber-400 text-sm font-medium">
                                        <span>{blogUi.readArticle || 'Read article'}</span>
                                        <ArrowRight class="w-4 h-4" />
                                    </span>
                                </a>
                            ))}
                        </div>
                    </section>
                )}

                <section class="glass-strong rounded-3xl p-8 sm:p-10 border border-amber-400/20 bg-gradient-to-br from-amber-500/10 to-transparent text-center">
                    <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">{product.name}</h2>
                    <p class="text-white/70 text-lg max-w-2xl mx-auto mb-6">
                        {product.description}
                    </p>
                    <a
                        href={formPath}
                        class="inline-flex items-center gap-2 rounded-2xl bg-amber-500 px-8 py-4 text-black font-bold text-base hover:bg-amber-400 transition-colors"
                    >
                        <Sparkles class="w-5 h-5" />
                        <span>{t.cta.orderNow}</span>
                    </a>
                </section>

                <ZodiacSignGrid lang={lang} type={type} />

                <FAQ lang={lang} />
            </div>
        </main>

        <Footer lang={lang} />
    </div>
</Layout>

<script
    is:inline
    define:vars={{
        type,
        lang,
        productName: product.name,
        productPrice,
    }}
>
    (function () {
        var track = window['astraloTrack'];
        if (typeof track !== 'function') return;

        var normalizedPrice = Number(Number(productPrice).toFixed(2));
        track('view_item', {
            currency: 'EUR',
            value: normalizedPrice,
            page_type: 'product_landing',
            language: lang,
            items: [
                {
                    item_id: type,
                    item_name: productName,
                    item_category: 'horoscope',
                    item_variant: lang,
                    price: normalizedPrice,
                    quantity: 1,
                },
            ],
        });
    })();
</script>
