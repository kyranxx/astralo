---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { Sparkles, Star, Heart, Calendar, TrendingUp, Zap, Clock, Sun, Moon } from 'lucide-astro';

// Original prices (before 50% discount)
const horoscopeTypes = [
  {
    id: "daily",
    name: "Daily Horoscope",
    description: "Your personal predictions for the next 24 hours",
    originalPrice: 3.99,
    price: 1.99,
    icon: "Sun",
    wordCount: "~200 words",
    benefits: [
      "🌅 Today's energy forecast",
      "🍀 Lucky number & color",
      "⭐ Personal daily advice"
    ]
  },
  {
    id: "weekly",
    name: "Weekly Horoscope",
    description: "Comprehensive 7-day outlook with key opportunities",
    originalPrice: 7.99,
    price: 3.99,
    icon: "Calendar",
    wordCount: "~400 words",
    popular: true,
    benefits: [
      "📅 Day-by-day breakdown",
      "🎯 Lucky day of the week",
      "💰 Financial forecast",
      "❤️ Love & relationship tips",
      "💼 Career guidance"
    ]
  },
  {
    id: "monthly",
    name: "Monthly Horoscope",
    description: "In-depth analysis with major events & opportunities",
    originalPrice: 19.99,
    price: 9.99,
    icon: "Moon",
    wordCount: "~1000 words",
    bestValue: true,
    benefits: [
      "🗓️ Week-by-week predictions",
      "🌟 Best days of the month",
      "💎 Lucky stones & crystals",
      "🌈 Energy cycles",
      "💰 Financial opportunities",
      "❤️ Relationship insights",
      "🎯 Goal-setting guidance"
    ]
  },
  {
    id: "partner",
    name: "Partner Horoscope",
    description: "Deep compatibility analysis through synastry",
    originalPrice: 29.99,
    price: 14.99,
    icon: "Heart",
    wordCount: "~1200 words",
    benefits: [
      "💕 Compatibility percentage",
      "🔮 Relationship dynamics",
      "💪 Your strengths together",
      "⚠️ Areas to work on",
      "💬 Communication styles",
      "❤️ Love language match",
      "💫 Future potential",
      "🌟 Synastry insights"
    ]
  },
];

const iconMap = {
  Calendar,
  Star,
  Sparkles,
  Heart,
  Clock,
  TrendingUp,
  Zap,
  Sun,
  Moon,
};

const testimonials = [
  {
    name: "Sarah Mitchell",
    location: "London, UK",
    text: "The most accurate horoscope I've ever received! Everything came true exactly as predicted. I recommend it to anyone looking for quality astrological guidance.",
    rating: 5,
  },
  {
    name: "James Wilson",
    location: "Manchester, UK",
    text: "The monthly horoscope helped me make the right career decision. An investment that paid off a hundredfold!",
    rating: 5,
  },
  {
    name: "Emma Thompson",
    location: "Dublin, Ireland",
    text: "Amazing accuracy and detail in the partner analysis. I finally understood the dynamics of our relationship. Thank you!",
    rating: 5,
  },
  {
    name: "Oliver Brown",
    location: "Edinburgh, UK",
    text: "Professional approach and fast delivery. The daily horoscope helps me make better decisions every day.",
    rating: 5,
  },
  {
    name: "Sophie Martin",
    location: "Paris, France",
    text: "After the monthly horoscope, I ordered a partner reading too. Both were accurate and very useful. I'll definitely be back!",
    rating: 5,
  },
  {
    name: "Lucas Anderson",
    location: "Stockholm, Sweden",
    text: "As a skeptic, I had to admit that this horoscope is different. Quality and professional approach at the highest level.",
    rating: 5,
  },
];
---

<Layout 
  title="Astralo - Professional Horoscopes | Accurate Astrological Predictions"
  lang="en"
>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Top Promo Banner -->
    <div class="bg-gradient-to-r from-amber-500 via-amber-400 to-amber-500 py-2 px-4 text-center">
      <div class="flex items-center justify-center gap-3 sm:gap-6 text-black/90 text-sm font-medium">
        <span class="flex items-center gap-2">
          <span class="animate-pulse">🔥</span>
          <span class="font-bold">50% OFF</span>
          <span class="hidden sm:inline">- Limited Time!</span>
        </span>
        <span class="hidden sm:flex items-center gap-2">
          <span>⚡</span>
          <span>Instant Email Delivery</span>
        </span>
        <span class="hidden md:flex items-center gap-2">
          <span>⭐</span>
          <span>50,000+ Happy Customers</span>
        </span>
        <span class="hidden lg:flex items-center gap-2">
          <img src="/Stripe wordmark - Blurple - Large.png" alt="Stripe" class="h-4 brightness-0" />
          <span>Secure</span>
        </span>
      </div>
    </div>

    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <!-- Logo -->
          <a href="/" class="flex items-center">
            <img src="/logo.png" alt="Astralo" class="h-9 sm:h-11" />
          </a>
          
          <!-- Center - Desktop -->
          <div class="hidden lg:flex items-center gap-3">
            <div class="flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-400/20">
              <Sparkles class="w-4 h-4 text-amber-400" />
              <span class="text-white/80 text-sm">Personalized Horoscopes</span>
            </div>
          </div>
          
          <!-- Language Switcher -->
          <LanguageSwitcher lang="en" />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-8 sm:py-12">
      <div class="max-w-7xl mx-auto">
        <!-- Hero Section -->
        <div class="text-center mb-10 sm:mb-12 animate-fade-in-up">
          <h1 class="text-3xl sm:text-5xl md:text-6xl font-bold text-white mb-4">
            Your Personal Horoscope
          </h1>
          <p class="text-lg sm:text-xl text-white/80 max-w-3xl mx-auto mb-4">
            Discover what the stars have in store for you
          </p>
          <p class="text-white/60 text-sm">
            ✨ Instant delivery • 🔒 Secure payments • ⭐ 50,000+ satisfied customers
          </p>
        </div>

        <!-- Horoscope Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-12 sm:mb-16 max-w-5xl mx-auto">
          {horoscopeTypes.map((type, index) => {
            const Icon = iconMap[type.icon as keyof typeof iconMap];
            return (
              <a
                href={`/form/${type.id}`}
                class="horoscope-card block glass-strong rounded-xl p-3 sm:p-5 hover:bg-white/5 transition-all duration-300 relative border border-white/10 hover:border-amber-400/30 hover:shadow-xl no-underline"
                style={`animation: fadeInUp 0.8s ease-out ${0.1 * index}s forwards; opacity: 0;`}
              >
                {type.popular && (
                  <div class="absolute -top-2 left-1/2 -translate-x-1/2 bg-gradient-to-r from-amber-400 to-amber-500 text-black text-xs font-bold px-3 py-0.5 rounded-full">
                    Popular
                  </div>
                )}
                {type.bestValue && (
                  <div class="absolute -top-2 left-1/2 -translate-x-1/2 bg-gradient-to-r from-green-400 to-emerald-500 text-black text-xs font-bold px-3 py-0.5 rounded-full">
                    Best Value
                  </div>
                )}
                <div class="flex flex-col h-full text-center">
                  <!-- Icon & Title -->
                  <div class="mb-3 sm:mb-4">
                    <div class="inline-flex items-center justify-center w-10 h-10 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-amber-400/20 to-amber-600/20 mb-2 sm:mb-3 mx-auto">
                      <Icon class="w-5 h-5 sm:w-7 sm:h-7 text-amber-400" />
                    </div>
                    <h3 class="text-sm sm:text-xl font-bold text-white mb-1">
                      {type.name}
                    </h3>
                    <p class="text-white/50 text-xs">{type.wordCount}</p>
                  </div>

                  <!-- Price with discount -->
                  <div class="mb-3 sm:mb-5">
                    <div class="text-white/40 text-sm line-through mb-1">
                      {type.originalPrice.toFixed(2)}€
                    </div>
                    <div class="text-xl sm:text-2xl font-bold text-amber-400">
                      {type.price.toFixed(2)}€
                    </div>
                  </div>

                  <!-- Benefits - Vertically aligned -->
                  <div class="hidden sm:flex flex-col gap-1.5 text-xs text-white/70 mb-4 flex-1 text-left pl-2">
                    {type.benefits.slice(0, 4).map((benefit) => (
                      <div class="flex items-start gap-1">
                        <span>{benefit}</span>
                      </div>
                    ))}
                    {type.benefits.length > 4 && (
                      <div class="text-amber-400/70 text-xs">
                        +{type.benefits.length - 4} more
                      </div>
                    )}
                  </div>

                  <!-- CTA Button -->
                  <div class="mt-auto">
                    <div class="bg-gradient-to-r from-amber-400 to-amber-500 text-black font-semibold px-3 sm:px-4 py-2 sm:py-3 rounded-lg text-xs sm:text-base shadow-lg shadow-amber-500/30 flex items-center justify-center gap-1 sm:gap-2 w-full">
                      <Sparkles class="w-3 h-3 sm:w-5 sm:h-5" />
                      <span>Order</span>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <!-- Trust Indicators -->
        <div class="glass-strong rounded-2xl p-6 sm:p-8 mb-12 sm:mb-16">
          <div class="grid grid-cols-3 gap-4 sm:gap-8 text-center">
            <div>
              <div class="text-2xl sm:text-4xl font-bold text-amber-400 mb-1 sm:mb-2">50,000+</div>
              <p class="text-white/70 text-xs sm:text-sm">Satisfied customers</p>
            </div>
            <div>
              <div class="flex items-center justify-center gap-0.5 sm:gap-1 mb-1 sm:mb-2">
                {[...Array(5)].map(() => (
                  <Star class="w-4 h-4 sm:w-6 sm:h-6 text-amber-400 fill-amber-400" />
                ))}
              </div>
              <p class="text-white/70 text-xs sm:text-sm">5-star ratings</p>
            </div>
            <div>
              <div class="text-2xl sm:text-4xl font-bold text-amber-400 mb-1 sm:mb-2">24/7</div>
              <p class="text-white/70 text-xs sm:text-sm">Instant delivery</p>
            </div>
          </div>
        </div>

        <!-- Testimonials -->
        <div class="mb-12 sm:mb-16">
          <h2 class="text-2xl sm:text-4xl font-bold text-white text-center mb-6 sm:mb-10">
            What Our Clients Say
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
            {testimonials.map((testimonial, index) => (
              <div 
                class="glass rounded-2xl p-5 sm:p-6 hover:bg-white/5 transition-all duration-300"
                style={`animation: fadeInUp 0.8s ease-out ${0.1 * index}s forwards; opacity: 0;`}
              >
                <div class="flex items-center gap-1 mb-3 sm:mb-4">
                  {[...Array(testimonial.rating)].map(() => (
                    <Star class="w-3 h-3 sm:w-4 sm:h-4 text-amber-400 fill-amber-400" />
                  ))}
                </div>
                <p class="text-white/90 text-sm mb-4 leading-relaxed italic">
                  "{testimonial.text}"
                </p>
                <div>
                  <p class="text-white font-semibold text-sm">{testimonial.name}</p>
                  <p class="text-white/60 text-xs">{testimonial.location}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Why Choose Us -->
        <div class="glass-strong rounded-2xl p-6 sm:p-10 mb-8 text-center">
          <h2 class="text-xl sm:text-3xl font-bold text-white mb-6">
            Why Choose Astralo?
          </h2>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-8">
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-amber-400/20 to-amber-600/20 mb-3 sm:mb-4">
                <Sparkles class="w-6 h-6 sm:w-7 sm:h-7 text-amber-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">Personalized</h3>
              <p class="text-white/60 text-xs sm:text-sm">Created just for you</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-green-400/20 to-green-600/20 mb-3 sm:mb-4">
                <Zap class="w-6 h-6 sm:w-7 sm:h-7 text-green-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">Instant</h3>
              <p class="text-white/60 text-xs sm:text-sm">Ready in minutes</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-blue-400/20 to-blue-600/20 mb-3 sm:mb-4">
                <Star class="w-6 h-6 sm:w-7 sm:h-7 text-blue-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">Professional</h3>
              <p class="text-white/60 text-xs sm:text-sm">Expert astrology</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-purple-400/20 to-purple-600/20 mb-3 sm:mb-4">
                <TrendingUp class="w-6 h-6 sm:w-7 sm:h-7 text-purple-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">Trusted</h3>
              <p class="text-white/60 text-xs sm:text-sm">50,000+ customers</p>
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <Footer lang="en" />
  </div>
</Layout>

<style>
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes gentle-pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.8;
    }
  }
  
  .animate-gentle-pulse {
    animation: gentle-pulse 3s ease-in-out infinite;
  }
</style>
