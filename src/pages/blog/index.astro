---
/**
 * Blog Index Page - SEO Optimized
 * Lists all blog posts for organic traffic
 */

import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { ArrowLeft, Calendar, ArrowRight, BookOpen, TrendingUp } from 'lucide-astro';

export const prerender = true;

// Blog posts data - keyword optimized for horoscope searches
const blogPosts = [
  {
    slug: 'daily-horoscope-guide',
    title: 'Daily Horoscope 2024: Complete Guide to Your Zodiac Predictions',
    excerpt: 'Discover what the stars have in store for you today. Our comprehensive daily horoscope guide covers all 12 zodiac signs with accurate predictions for love, career, and finances.',
    date: '2024-12-20',
    readTime: '8 min',
    category: 'Horoscopes',
    keywords: ['daily horoscope', 'horoscope today', 'zodiac predictions', 'astrology today'],
    featured: true
  },
  {
    slug: 'zodiac-compatibility-complete-guide',
    title: 'Zodiac Sign Compatibility: The Ultimate Love Match Guide 2024',
    excerpt: 'Find out which zodiac signs are most compatible with yours. Our in-depth compatibility guide reveals the best and worst love matches for every sign.',
    date: '2024-12-18',
    readTime: '12 min',
    category: 'Love & Relationships',
    keywords: ['zodiac compatibility', 'love horoscope', 'star sign compatibility', 'astrological compatibility']
  },
  {
    slug: 'birth-chart-reading-explained',
    title: 'Birth Chart Reading: How to Understand Your Natal Chart',
    excerpt: 'Learn how to read and interpret your birth chart. Discover the meaning of planets, houses, and aspects in your unique astrological blueprint.',
    date: '2024-12-15',
    readTime: '10 min',
    category: 'Astrology Basics',
    keywords: ['birth chart', 'natal chart', 'astrology chart', 'horoscope chart reading']
  },
  {
    slug: 'weekly-horoscope-predictions',
    title: 'Weekly Horoscope: What the Stars Predict for This Week',
    excerpt: 'Get your weekly horoscope forecast for all zodiac signs. Discover upcoming opportunities, challenges, and cosmic guidance for the week ahead.',
    date: '2024-12-22',
    readTime: '6 min',
    category: 'Horoscopes',
    keywords: ['weekly horoscope', 'horoscope this week', 'weekly zodiac', 'astrology weekly']
  },
  {
    slug: 'monthly-horoscope-january-2025',
    title: 'Monthly Horoscope January 2025: All Zodiac Sign Predictions',
    excerpt: 'Your complete monthly horoscope for January 2025. Detailed predictions for each zodiac sign covering love, career, health, and finances.',
    date: '2024-12-24',
    readTime: '15 min',
    category: 'Horoscopes',
    keywords: ['monthly horoscope', 'horoscope january 2025', 'zodiac monthly predictions', 'astrology forecast']
  },
  {
    slug: 'love-horoscope-relationship-advice',
    title: 'Love Horoscope 2024: Relationship Predictions for Every Sign',
    excerpt: 'Is love written in your stars? Get personalized love horoscope predictions and relationship advice based on your zodiac sign.',
    date: '2024-12-10',
    readTime: '9 min',
    category: 'Love & Relationships',
    keywords: ['love horoscope', 'relationship horoscope', 'romantic compatibility', 'love astrology']
  }
];

const categories = ['All', 'Horoscopes', 'Love & Relationships', 'Astrology Basics'];
---

<Layout 
  title="Astrology Blog - Daily Horoscope, Zodiac Compatibility & Predictions | Astralo"
  description="Explore our astrology blog for daily horoscopes, zodiac compatibility guides, birth chart readings, and expert astrological predictions. Free horoscope content updated weekly."
  lang="en"
>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href="/" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">Home</span>
          </a>
          <a href="/"><img src="/logo.png" alt="Astralo" class="h-9" /></a>
          <div class="w-16"></div>
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-12 sm:py-16">
      <div class="max-w-6xl mx-auto">
        
        <!-- Hero Section -->
        <div class="text-center mb-12">
          <div class="inline-flex items-center gap-2 px-4 py-2 glass rounded-full mb-4">
            <BookOpen class="w-5 h-5 text-amber-400" />
            <span class="text-amber-400 text-sm font-medium">Astrology Blog</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
            Daily Horoscope & Astrology Insights
          </h1>
          <p class="text-white/70 text-lg max-w-2xl mx-auto">
            Your trusted source for accurate horoscopes, zodiac compatibility guides, birth chart readings, and expert astrological predictions. Updated weekly.
          </p>
        </div>

        <!-- Featured Post -->
        {blogPosts.filter(p => p.featured).map(post => (
          <a href={`/blog/${post.slug}`} class="block mb-12 group">
            <div class="glass-strong rounded-3xl p-8 sm:p-10 border border-white/10 hover:border-amber-500/30 transition-all duration-300">
              <div class="flex items-center gap-4 mb-4">
                <span class="px-3 py-1 bg-amber-500/20 text-amber-400 text-xs font-semibold rounded-full">Featured</span>
                <span class="text-white/50 text-sm flex items-center gap-2">
                  <Calendar class="w-4 h-4" />
                  {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                </span>
                <span class="text-white/50 text-sm">{post.readTime} read</span>
              </div>
              <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 group-hover:text-amber-200 transition-colors">
                {post.title}
              </h2>
              <p class="text-white/70 text-lg mb-4">{post.excerpt}</p>
              <div class="flex items-center gap-2 text-amber-400 font-medium">
                <span>Read Article</span>
                <ArrowRight class="w-4 h-4 group-hover:translate-x-2 transition-transform" />
              </div>
            </div>
          </a>
        ))}

        <!-- Categories -->
        <div class="flex flex-wrap gap-3 mb-8 justify-center">
          {categories.map((cat, i) => (
            <button class={`px-4 py-2 rounded-full text-sm font-medium transition-all ${i === 0 ? 'bg-amber-500 text-black' : 'glass text-white/80 hover:text-white hover:border-amber-500/30'}`}>
              {cat}
            </button>
          ))}
        </div>

        <!-- Blog Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {blogPosts.filter(p => !p.featured).map(post => (
            <a href={`/blog/${post.slug}`} class="group">
              <article class="glass-strong rounded-2xl p-6 h-full border border-white/10 hover:border-amber-500/30 transition-all duration-300 flex flex-col">
                <div class="flex items-center gap-3 mb-4">
                  <span class="px-2 py-1 bg-white/10 text-white/70 text-xs rounded-full">{post.category}</span>
                  <span class="text-white/50 text-xs">{post.readTime}</span>
                </div>
                <h3 class="text-lg font-bold text-white mb-2 group-hover:text-amber-200 transition-colors line-clamp-2">
                  {post.title}
                </h3>
                <p class="text-white/60 text-sm mb-4 flex-1 line-clamp-3">{post.excerpt}</p>
                <div class="flex items-center justify-between text-sm">
                  <span class="text-white/40">{new Date(post.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                  <span class="text-amber-400 group-hover:underline">Read more →</span>
                </div>
              </article>
            </a>
          ))}
        </div>

        <!-- SEO Content Section -->
        <section class="mt-16 glass-strong rounded-2xl p-8 sm:p-10">
          <h2 class="text-2xl font-bold text-white mb-4">
            Free Daily Horoscope & Astrology Resources
          </h2>
          <div class="prose prose-invert max-w-none text-white/70">
            <p>
              Welcome to the Astralo astrology blog – your premier destination for <strong>daily horoscope predictions</strong>, 
              <strong>zodiac sign compatibility</strong> guides, and expert astrological insights. Whether you're looking for your 
              <strong>horoscope today</strong>, seeking <strong>love compatibility</strong> advice, or wanting to understand your 
              <strong>birth chart</strong>, we have comprehensive resources for every astrology enthusiast.
            </p>
            <p class="mt-4">
              Our team of experienced astrologers provides accurate <strong>weekly horoscopes</strong> and <strong>monthly horoscope 
              forecasts</strong> for all 12 zodiac signs: Aries, Taurus, Gemini, Cancer, Leo, Virgo, Libra, Scorpio, Sagittarius, 
              Capricorn, Aquarius, and Pisces. Get personalized <strong>horoscope readings</strong> based on your exact birth data 
              for the most accurate cosmic guidance.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a href="/" class="inline-flex items-center gap-2 px-4 py-2 bg-amber-500 text-black font-semibold rounded-full hover:bg-amber-400 transition-colors">
                <TrendingUp class="w-4 h-4" />
                Get Your Personalized Horoscope
              </a>
            </div>
          </div>
        </section>

      </div>
    </main>

    <Footer lang="en" />
  </div>
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
