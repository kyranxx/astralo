---
/**
 * Individual Blog Post Page - SEO Optimized
 * Dynamic route for all blog articles
 * Uses modular content from src/lib/blog
 */

import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { ArrowLeft, Calendar, Clock, Star, Twitter, Facebook, Linkedin, Link2, BookOpen } from 'lucide-astro';
import { getArticleTranslation, getArticleMeta, getAllArticleSlugs, getBlogDisplayTitle, getBlogSeoTitle, getArticleLanguageCodes, getBlogUiTranslations } from '../../lib/blog';
import BlogCTA from '../../components/BlogCTA.astro';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildLocaleUrl,
  getSuggestedProductForArticle,
  rewriteBlogOfferLinks,
  siteUrl,
} from '../../lib/seo';
import { isStaleMonthlyHoroscopeSlug } from '../../lib/indexing';

export const prerender = true;

export function getStaticPaths() {
  const slugs = getAllArticleSlugs();
  return slugs.map(slug => ({
    params: { slug }
  }));
}

const { slug } = Astro.params;
const blogSlug = slug as string;
const translation = getArticleTranslation(blogSlug, 'en');
const meta = getArticleMeta(blogSlug);

if (!translation || !meta) {
  return Astro.redirect('/blog');
}

const post = {
  ...translation,
  ...meta,
  displayTitle: getBlogDisplayTitle(translation.title)
};
const seoTitle = getBlogSeoTitle(post.displayTitle, post.seoTitle);

// Related posts (exclude current) - simplistic logic for now
const allSlugs = getAllArticleSlugs();
const relatedPosts = allSlugs
  .filter(s => s !== slug)
  .map(s => {
    const m = getArticleMeta(s);
    const t = getArticleTranslation(s, 'en');
    return { slug: s, ...m, ...t };
  })
  .filter(p => p.category === post.category)
  .slice(0, 2);

// Generate share URLs
const currentUrl = `${siteUrl}/blog/${slug}`;
const blogAlternateLanguageUrls = getArticleLanguageCodes(blogSlug).map((code) => ({
  code,
  hreflang: code,
  href: buildLocaleUrl(`/blog/${blogSlug}`, code),
}));
const shareText = encodeURIComponent(post.displayTitle);
const productKey = getSuggestedProductForArticle(blogSlug);
const ui = getBlogUiTranslations('en');
const renderedContent = rewriteBlogOfferLinks(post.content, 'en', blogSlug);
const noIndex = isStaleMonthlyHoroscopeSlug(blogSlug);

// Content splitting for mid-article CTA
const contentParts = renderedContent.split('</p>');
const injectionPoint = Math.min(3, Math.floor(contentParts.length / 2));
const firstHalf = contentParts.slice(0, injectionPoint).join('</p>') + (contentParts.length > injectionPoint ? '</p>' : '');
const secondHalf = contentParts.slice(injectionPoint).join('</p>');
const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(currentUrl)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`
};
const pageSchema = [
  buildArticleSchema({
    lang: 'en',
    url: currentUrl,
    translation,
    meta,
  }),
  buildBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Blog', url: `${siteUrl}/blog` },
    { name: post.displayTitle, url: currentUrl },
  ]),
];
---

<Layout 
  title={`${seoTitle} | Astralo`}
  description={post.metaDescription}
  keywords={post.keywords}
  lang="en"
  alternateLanguageUrls={blogAlternateLanguageUrls}
  schema={pageSchema}
  ogType="article"
  publishedTime={meta.date}
  modifiedTime={meta.date}
  noIndex={noIndex}
>
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 w-0 h-1 bg-gradient-to-r from-amber-400 to-amber-600 z-[100] transition-all duration-150"></div>

  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href="/blog" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">Back to Blog</span>
          </a>
          <a href="/"><img src="/logo.webp" alt="Astralo" class="h-9" style="aspect-ratio: 3.41;" fetchpriority="high" /></a>
          <div class="w-24"></div>
        </div>
      </div>
    </header>

    <!-- Article -->
    <main class="flex-1 px-4 py-12">
      <!-- Added glass-strong background panel for readability -->
      <article class="max-w-3xl mx-auto glass-strong p-6 md:p-12 rounded-3xl border border-white/10 bg-slate-900/60 backdrop-blur-xl shadow-2xl">
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
          <span class="px-3 py-1 bg-amber-500/20 text-amber-400 rounded-full font-medium tracking-wide">{post.category}</span>
          <span class="text-white/50 flex items-center gap-2">
            <Calendar class="w-4 h-4" />
            {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
          <span class="text-white/50 flex items-center gap-2">
            <Clock class="w-4 h-4" />
            {post.readTime} min read
          </span>
        </div>

        <!-- Title with Emoji -->
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-8 leading-tight tracking-tight">
          <span class="mr-3">{post.emoji}</span>{post.displayTitle}
        </h1>

        <!-- Author & Share -->
        <div class="flex items-center justify-between mb-10 pb-10 border-b border-white/10">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg hover:scale-105 transition-transform">
              <Star class="w-6 h-6 text-white" />
            </div>
            <div>
              <p class="text-white font-bold text-lg">{post.author}</p>
            </div>
          </div>
          
          <!-- Social Share Buttons -->
          <div class="flex items-center gap-3">
            <span class="text-white/50 text-sm hidden sm:inline font-medium">Share:</span>
            <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" 
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title="Share on Twitter">
              <Twitter class="w-5 h-5" />
            </a>
            <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer"
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title="Share on Facebook">
              <Facebook class="w-5 h-5" />
            </a>
            <a href={shareUrls.linkedin} target="_blank" rel="noopener noreferrer"
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title="Share on LinkedIn">
              <Linkedin class="w-5 h-5" />
            </a>
            <button id="copy-link" 
                    class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
                    title="Copy link">
              <Link2 class="w-5 h-5" />
            </button>
          </div>
        </div>

        <!-- Quick Summary Box -->
        {post.quickSummary && (
        <div class="glass-strong rounded-2xl p-8 mb-12 border border-amber-500/20 bg-amber-500/5">
          <div class="flex items-center gap-3 mb-6">
            <BookOpen class="w-6 h-6 text-amber-400" />
            <h3 class="text-xl font-bold text-white">📌 Quick Summary</h3>
          </div>
          <ul class="space-y-4">
            {post.quickSummary.map((point: string) => (
              <li class="flex items-start gap-3 text-white/90 leading-relaxed text-lg">
                <span class="text-amber-400 mt-1.5 font-bold">✓</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
        )}

        {post.tableOfContents?.length > 0 && (
          <details class="supporting-details rounded-2xl border border-white/10 bg-white mb-10">
            <summary>{ui.tableOfContents}</summary>
            <nav class="px-5 pb-5" aria-label={ui.tableOfContents}>
              <ol class="grid sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
                {post.tableOfContents.map((item: { id: string; title: string }) => (
                  <li><a href={`#${item.id}`} class="text-[#704000] hover:underline">{item.title}</a></li>
                ))}
              </ol>
            </nav>
          </details>
        )}

        <!-- Content -->
        <!-- Added prose-p:mb-10 relative to leading-loose for massive Medium-style gaps -->
        <div 
          class="article-content prose prose-xl prose-invert max-w-none
            prose-headings:text-white prose-headings:font-bold prose-headings:scroll-mt-32
            prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:pb-4 prose-h2:border-b prose-h2:border-white/10
            prose-h3:text-2xl prose-h3:mt-12 prose-h3:mb-6 prose-h3:text-amber-200
            prose-p:text-gray-100 prose-p:leading-8 prose-p:mb-10 prose-p:text-lg
            prose-strong:text-amber-300 prose-strong:font-bold
            prose-ul:text-gray-100 prose-li:mb-4 prose-ul:my-8 prose-li:leading-relaxed
            prose-ol:text-gray-100 prose-ol:my-8 prose-ol:list-decimal prose-ol:pl-6
            prose-a:text-amber-400 prose-a:no-underline hover:prose-a:text-amber-300 transition-colors
            prose-blockquote:border-l-4 prose-blockquote:border-amber-500 prose-blockquote:bg-white/5 prose-blockquote:p-6 prose-blockquote:rounded-r-lg prose-blockquote:italic"
        >
          <div set:html={firstHalf} />
          
          <BlogCTA productKey={productKey} lang="en" sourceSlug={blogSlug} />
          
          <div set:html={secondHalf} />
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-20 border-t border-white/10 pt-16">
            <h3 class="text-2xl font-bold text-white mb-8">📚 Related Articles</h3>
            <div class="grid md:grid-cols-2 gap-8">
              {relatedPosts.map((p) => (
                <a href={`/blog/${p.slug}`} class="glass rounded-2xl p-8 block hover:border-amber-500/30 border border-white/10 transition-all group hover:-translate-y-1">
                  <span class="text-3xl mb-4 inline-block">{p.emoji}</span>
                  <span class="text-amber-400 text-sm font-medium block mb-2 tracking-wide uppercase">{p.category}</span>
                  <h4 class="text-xl text-white font-bold group-hover:text-amber-200 transition-colors">{p.title}</h4>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </main>
    <Footer lang="en" />
  </div>
</Layout>

<style is:global>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }
  
  /* Reading progress bar animation */
  #reading-progress {
    transform-origin: left;
  }

  /* Force Spacing for Blog Content - overriding any potential prose conflicts */
  .article-content > p {
    margin-bottom: 2.5rem !important; /* Huge space between paragraphs */
    display: block !important;
  }
  
  .article-content > h2 {
    margin-top: 3.5rem !important;
    margin-bottom: 1.5rem !important;
  }
  
  .article-content > h3 {
    margin-top: 2.5rem !important;
    margin-bottom: 1rem !important;
  }
  
  .article-content ul, .article-content ol {
    margin-bottom: 2.5rem !important;
  }
</style>

<script>
  // Reading Progress Bar
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.getElementById('reading-progress');
    
    const updateProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;
      if (progressBar) {
        progressBar.style.width = `${Math.min(progress, 100)}%`;
      }
    };
    
    window.addEventListener('scroll', updateProgress);
    updateProgress(); // Initial call
  });
  
  // Copy Link Button
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const btn = document.getElementById('copy-link');
      if (btn) {
        btn.classList.add('!text-green-400');
        setTimeout(() => {
          btn.classList.remove('!text-green-400');
        }, 2000);
      }
    } catch (err) {
      console.error('Failed to copy link:', err);
    }
  });

  document.querySelectorAll('[data-astralo-track-click]').forEach((element) => {
    element.addEventListener('click', () => {
      const track = (window as Window & { astraloTrack?: (eventName: string, params?: Record<string, string>) => void }).astraloTrack;
      if (typeof track !== 'function') return;

      const target = element as HTMLElement;
      track(target.dataset.astraloTrackClick || 'internal_click', {
        blog_slug: target.dataset.blogSlug || '',
        click_surface: target.dataset.clickSurface || '',
        item_id: target.dataset.productKey || '',
        language: target.dataset.language || 'en',
        link_url: target.getAttribute('href') || '',
      });
    });
  });
</script>
