---
/**
 * Individual Blog Post Page - SEO Optimized
 * Dynamic route for all blog articles
 */

import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { ArrowLeft, Calendar, Clock, Share2, Star, ArrowRight } from 'lucide-astro';

export const prerender = true;

// Blog posts with full keyword-rich content
const blogPosts: Record<string, any> = {
  'daily-horoscope-guide': {
