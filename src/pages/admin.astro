  // Populate month dropdown with last 24 months
  function populateMonthDropdown() {
    if (!monthDropdown) return;
    
    const now = new Date();
    let html = '';
    
    for (let i = 0; i < 24; i++) {
      const date = new Date(now.getFullYear(), now.getMonth() - i, 1);
      const year = date.getFullYear();
      const month = date.getMonth();
      const label = `${monthNames[month]} ${year}`;
      html += `<button class="dropdown-item" data-year="${year}" data-month="${month}">${label}</button>`;
    }
    
    monthDropdown.innerHTML = html;
    
    // Add click handlers
    monthDropdown.querySelectorAll('.dropdown-item').forEach(item => {
      item.addEventListener('click', () => {
        const year = parseInt((item as HTMLElement).dataset.year || '2024');
        const month = parseInt((item as HTMLElement).dataset.month || '0');
        const range = getDateRangeForMonth(year, month);
        const label = `${monthNames[month]} ${year}`;
        applyDateFilter({ ...range, label }, 'monthDropdownBtn');
        monthDropdown.classList.add('hidden');
      });
    });
  }
  
  monthDropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    populateMonthDropdown();
    monthDropdown?.classList.toggle('hidden');
    yearDropdown?.classList.add('hidden');
  });
  
  // Year dropdown
  const yearDropdownBtn = document.getElementById('yearDropdownBtn');
  const yearDropdown = document.getElementById('yearDropdown');
  
  // Populate year dropdown with available years
  function populateYearDropdown() {
    if (!yearDropdown) return;
    
    const currentYear = new Date().getFullYear();
    let html = '';
    
    // Show current year and 4 previous years
    for (let year = currentYear; year >= currentYear - 4; year--) {
      html += `<button class="dropdown-item" data-year="${year}">${year}</button>`;
    }
    
    yearDropdown.innerHTML = html;
    
    // Add click handlers
    yearDropdown.querySelectorAll('.dropdown-item').forEach(item => {
      item.addEventListener('click', () => {
        const year = parseInt((item as HTMLElement).dataset.year || '2024');
        const range = getDateRangeForYear(year);
        applyDateFilter({ ...range, label: `${year}` }, 'yearDropdownBtn');
        yearDropdown.classList.add('hidden');
      });
    });
  }
  
  yearDropdownBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    populateYearDropdown();
    yearDropdown?.classList.toggle('hidden');
    monthDropdown?.classList.add('hidden');
  });
  
  // Close dropdowns when clicking outside
  document.addEventListener('click', () => {
    monthDropdown?.classList.add('hidden');
    yearDropdown?.classList.add('hidden');
  });
</script>
