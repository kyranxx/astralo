---
import Layout from '../layouts/Layout.astro';
import { DollarSign, ShoppingCart, Star, TrendingUp, RefreshCw, Search, ArrowLeft, ArrowRight, Globe } from 'lucide-astro';
---

<Layout title="Admin Dashboard - Astralo" backgroundImage="/background4.png">
  <div class="min-h-screen relative z-10">
    <!-- Header -->
    <header class="bg-black/60 backdrop-blur-xl border-b border-white/10">
      <div class="max-w-7xl mx-auto px-3 sm:px-4 py-3 sm:py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 sm:gap-3">
            <img src="/logo.png" alt="Astralo" class="h-8 sm:h-10" />
            <div class="border-l border-white/20 pl-2 sm:pl-3">
              <h1 class="text-sm sm:text-lg font-bold text-white">Admin</h1>
              <p class="text-xs text-white/60 hidden sm:block" id="lastUpdated">Loading...</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button id="refreshBtn" class="p-2 sm:px-3 sm:py-2 rounded-lg bg-white/10 text-white text-sm flex items-center gap-2 hover:bg-white/20 transition-colors">
              <RefreshCw class="w-4 h-4" />
              <span class="hidden sm:inline">Refresh</span>
            </button>
            <a href="/" class="p-2 sm:px-3 sm:py-2 rounded-lg bg-white/10 text-white text-sm hover:bg-white/20 transition-colors">
              <span class="hidden sm:inline">← Back</span>
              <ArrowLeft class="w-4 h-4 sm:hidden" />
            </a>
          </div>
        </div>
      </div>
    </header>

    <!-- Login Form -->
    <div id="loginContainer" class="max-w-sm mx-auto px-4 py-12 sm:py-20">
      <div class="bg-black/60 backdrop-blur-xl rounded-2xl p-6 sm:p-8 border border-white/10">
        <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-6">Admin Login</h2>
        <form id="loginForm">
          <input 
            type="password" 
            id="passwordInput" 
            placeholder="Enter password"
            class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-amber-400/50 mb-4 text-base"
          />
          <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 text-black font-semibold py-3 rounded-xl hover:from-amber-500 hover:to-amber-600 transition-all">
            Login
          </button>
          <p id="loginError" class="text-red-400 text-sm text-center mt-4 hidden">Invalid password</p>
        </form>
      </div>
    </div>

    <!-- Main Dashboard -->
    <main id="dashboardContainer" class="max-w-7xl mx-auto px-3 sm:px-4 py-4 sm:py-8 hidden">
      <!-- Stats Grid - 2x2 on mobile, 4 on desktop -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6 sm:mb-8">
        <!-- Total Revenue -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Revenue</p>
            <DollarSign class="w-4 h-4 sm:w-5 sm:h-5 text-green-500" />
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-white" id="totalRevenue">€0</h3>
          <p class="text-xs text-white/40 mt-1" id="refundedAmount">€0 refunded</p>
        </div>

        <!-- Orders -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Orders</p>
            <ShoppingCart class="w-4 h-4 sm:w-5 sm:h-5 text-blue-500" />
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-white" id="totalOrders">0</h3>
          <p class="text-xs text-white/40 mt-1">
            <span class="text-green-400" id="completedOrders">0</span> ✓ 
            <span class="text-red-400" id="refundedOrders">0</span> ↩
          </p>
        </div>

        <!-- Top Country -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Top Country</p>
            <Globe class="w-4 h-4 sm:w-5 sm:h-5 text-purple-500" />
          </div>
          <h3 class="text-lg sm:text-xl font-bold text-white truncate" id="topCountry">-</h3>
          <p class="text-xs text-white/40 mt-1" id="topCountryStats">-</p>
        </div>

        <!-- Top Product -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Best Seller</p>
            <Star class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500" />
          </div>
          <h3 class="text-sm sm:text-lg font-bold text-white truncate" id="topProduct">-</h3>
          <p class="text-xs text-white/40 mt-1" id="topProductStats">-</p>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
        <!-- Revenue Chart -->
        <div class="lg:col-span-2 bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-base sm:text-lg font-bold text-white">Revenue</h2>
              <p class="text-xs text-white/50">Last 12 months</p>
            </div>
            <TrendingUp class="w-5 h-5 text-green-500" />
          </div>
          <div class="space-y-2">
            <div class="flex items-end gap-1 sm:gap-2 h-32 sm:h-40" id="revenueChart">
              <div class="flex-1 bg-amber-500/20 rounded-t h-1/4"></div>
              <div class="flex-1 bg-amber-500/20 rounded-t h-1/3"></div>
              <div class="flex-1 bg-amber-500/20 rounded-t h-1/2"></div>
              <div class="flex-1 bg-amber-500/20 rounded-t h-1/4"></div>
              <div class="flex-1 bg-amber-500/20 rounded-t h-2/3"></div>
              <div class="flex-1 bg-amber-500/20 rounded-t h-3/4"></div>
              <div class="flex-1 bg-amber-500/30 rounded-t h-full"></div>
            </div>
            <div class="flex justify-between text-[10px] sm:text-xs text-white/40 overflow-x-auto" id="revenueLabels">
              <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span>
              <span>May</span><span>Jun</span><span>Jul</span><span>Aug</span>
              <span>Sep</span><span>Oct</span><span>Nov</span><span>Dec</span>
            </div>
          </div>
        </div>

        <!-- Countries -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10">
          <h2 class="text-base sm:text-lg font-bold text-white mb-4">By Country</h2>
          <div class="space-y-3" id="countryList">
            <p class="text-white/50 text-sm">No data yet</p>
          </div>
        </div>
      </div>

      <!-- Orders Table -->
      <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 gap-3">
          <h2 class="text-base sm:text-lg font-bold text-white">Orders</h2>
          
          <!-- Search & Filter - stacked on mobile -->
          <div class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <div class="relative flex-1 sm:flex-none">
              <Search class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/50" />
              <input 
                type="text" 
                id="searchInput"
                placeholder="Search..."
                class="w-full sm:w-40 pl-9 pr-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-amber-400/50 text-sm"
              />
            </div>
            <select id="statusFilter" class="flex-1 sm:flex-none px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none text-sm">
              <option value="all">All</option>
              <option value="completed">Completed</option>
              <option value="refunded">Refunded</option>
            </select>
          </div>
        </div>
        
        <!-- Mobile Cards View -->
        <div class="sm:hidden space-y-3" id="ordersMobileCards">
          <div class="text-center text-white/50 py-4">Loading...</div>
        </div>

        <!-- Desktop Table -->
        <div class="hidden sm:block overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">ID</th>
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">Customer</th>
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">Product</th>
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">Country</th>
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">Date</th>
                <th class="text-left text-white/60 text-xs font-medium pb-3 pr-3">Status</th>
                <th class="text-right text-white/60 text-xs font-medium pb-3 pr-3">Amount</th>
                <th class="text-center text-white/60 text-xs font-medium pb-3">Actions</th>
              </tr>
            </thead>
            <tbody id="ordersTableBody" class="text-sm">
              <tr>
                <td colspan="8" class="py-6 text-center text-white/50">Loading...</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-white/10">
          <p class="text-white/50 text-xs sm:text-sm" id="paginationInfo">0 orders</p>
          <div class="flex items-center gap-1 sm:gap-2">
            <button id="prevPage" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20 transition-colors disabled:opacity-30">
              <ArrowLeft class="w-4 h-4" />
            </button>
            <span class="text-white/70 text-xs sm:text-sm px-2" id="pageNumber">1</span>
            <button id="nextPage" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20 transition-colors disabled:opacity-30">
              <ArrowRight class="w-4 h-4" />
            </button>
          </div>
        </div>
      </div>
    </main>

    <!-- Refund Modal -->
    <div id="refundModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden p-4">
      <div class="bg-[#1a1a2e] rounded-2xl p-6 max-w-sm w-full border border-white/10">
        <h3 class="text-lg font-bold text-white mb-3">Confirm Refund</h3>
        <p class="text-white/70 text-sm mb-2">Refund order <span id="refundOrderId" class="text-amber-400 font-semibold"></span>?</p>
        <p class="text-white/70 text-sm mb-4">Amount: <span id="refundAmount" class="text-white font-semibold"></span></p>
        <textarea 
          id="refundReason"
          placeholder="Reason (optional)"
          class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none mb-4 h-20 resize-none text-sm"
        ></textarea>
        <div class="flex gap-2">
          <button id="cancelRefund" class="flex-1 px-4 py-2 rounded-lg bg-white/10 text-white text-sm hover:bg-white/20">Cancel</button>
          <button id="confirmRefund" class="flex-1 px-4 py-2 rounded-lg bg-red-500 text-white text-sm hover:bg-red-600 font-semibold">Refund</button>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  select option {
    background-color: #1a1a2e;
    color: white;
  }
</style>

<script>
  let adminPassword = '';
  let currentPage = 1;
  const limit = 10;
  
  const loginContainer = document.getElementById('loginContainer') as HTMLElement;
  const dashboardContainer = document.getElementById('dashboardContainer') as HTMLElement;
  const loginForm = document.getElementById('loginForm') as HTMLFormElement;
  const passwordInput = document.getElementById('passwordInput') as HTMLInputElement;
  const loginError = document.getElementById('loginError') as HTMLElement;
  const refreshBtn = document.getElementById('refreshBtn') as HTMLButtonElement;
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const statusFilter = document.getElementById('statusFilter') as HTMLSelectElement;
  const prevPageBtn = document.getElementById('prevPage') as HTMLButtonElement;
  const nextPageBtn = document.getElementById('nextPage') as HTMLButtonElement;
  
  // Check saved password (session only - cleared when browser closes)
  const savedPassword = sessionStorage.getItem('astralo_admin_session');
  if (savedPassword) {
    adminPassword = savedPassword;
    showDashboard();
  }
  
  loginForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const password = passwordInput.value;
    
    try {
      const response = await fetch(`/api/admin?action=stats&password=${encodeURIComponent(password)}`);
      if (response.ok) {
        adminPassword = password;
        sessionStorage.setItem('astralo_admin_session', password);
        showDashboard();
      } else {
        loginError.classList.remove('hidden');
      }
    } catch (error) {
      loginError.classList.remove('hidden');
    }
  });
  
  function showDashboard() {
    loginContainer.classList.add('hidden');
    dashboardContainer.classList.remove('hidden');
    loadDashboardData();
  }
  
  async function loadDashboardData() {
    await Promise.all([loadStats(), loadOrders()]);
  }
  
  async function loadStats() {
    try {
      const response = await fetch(`/api/admin?action=stats&password=${encodeURIComponent(adminPassword)}`);
      if (!response.ok) throw new Error('Failed');
      
      const stats = await response.json();
      
      document.getElementById('totalRevenue')!.textContent = `€${stats.totalRevenue.toFixed(2)}`;
      document.getElementById('refundedAmount')!.textContent = `€${stats.refundedAmount.toFixed(2)} refunded`;
      document.getElementById('totalOrders')!.textContent = stats.totalOrders.toString();
      document.getElementById('completedOrders')!.textContent = stats.completedOrders.toString();
      document.getElementById('refundedOrders')!.textContent = stats.refundedOrders.toString();
      
      if (stats.revenueByCountry.length > 0) {
        const top = stats.revenueByCountry[0];
        document.getElementById('topCountry')!.textContent = top.country;
        document.getElementById('topCountryStats')!.textContent = `€${top.revenue.toFixed(0)} · ${top.orders}`;
      }
      
      if (stats.revenueByProduct.length > 0) {
        const top = stats.revenueByProduct[0];
        document.getElementById('topProduct')!.textContent = top.product;
        document.getElementById('topProductStats')!.textContent = `€${top.revenue.toFixed(0)} · ${top.orders}`;
      }
      
      const lastUpdated = document.getElementById('lastUpdated');
      if (lastUpdated) {
        lastUpdated.textContent = new Date(stats.lastUpdated).toLocaleTimeString();
      }
      
      // Chart
      const chartContainer = document.getElementById('revenueChart')!;
      const labelsContainer = document.getElementById('revenueLabels')!;
      
      if (stats.monthlyData.length > 0) {
        const maxRevenue = Math.max(...stats.monthlyData.map((m: any) => m.revenue), 1);
        
        chartContainer.innerHTML = stats.monthlyData.map((m: any) => {
          const height = Math.max((m.revenue / maxRevenue) * 100, 5);
          return `<div class="flex-1 bg-amber-500/20 hover:bg-amber-500/30 rounded-t transition-colors cursor-pointer" style="height: ${height}%" title="€${m.revenue.toFixed(0)}"></div>`;
        }).join('');
        
        const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        labelsContainer.innerHTML = stats.monthlyData.map((m: any) => {
          const month = parseInt(m.month.split('-')[1]) - 1;
          return `<span>${monthNames[month]}</span>`;
        }).join('');
      }
      
      // Countries
      const countryList = document.getElementById('countryList')!;
      if (stats.revenueByCountry.length > 0) {
        countryList.innerHTML = stats.revenueByCountry.slice(0, 5).map((c: any) => `
          <div class="flex items-center justify-between">
            <div>
              <p class="text-white text-sm">${c.country}</p>
              <p class="text-white/40 text-xs">${c.orders} orders</p>
            </div>
            <div class="text-amber-400 font-bold text-sm">€${c.revenue.toFixed(0)}</div>
          </div>
        `).join('');
      }
    } catch (error) {
      console.error('Stats error:', error);
    }
  }
  
  async function loadOrders() {
    try {
      const search = searchInput?.value || '';
      const status = statusFilter?.value || 'all';
      
      const response = await fetch(
        `/api/admin?action=orders&password=${encodeURIComponent(adminPassword)}&page=${currentPage}&limit=${limit}&status=${status}&search=${encodeURIComponent(search)}`
      );
      
      if (!response.ok) throw new Error('Failed');
      
      const data = await response.json();
      
      // Desktop table
      const tbody = document.getElementById('ordersTableBody')!;
      // Mobile cards
      const mobileCards = document.getElementById('ordersMobileCards')!;
      
      if (data.orders.length === 0) {
        tbody.innerHTML = '<tr><td colspan="8" class="py-6 text-center text-white/50">No orders</td></tr>';
        mobileCards.innerHTML = '<div class="text-center text-white/50 py-4">No orders found</div>';
      } else {
        // Desktop rows
        tbody.innerHTML = data.orders.map((order: any) => {
          const statusClass = order.status === 'completed' ? 'text-green-400' : order.status === 'refunded' ? 'text-red-400' : 'text-amber-400';
          const date = new Date(order.createdAt).toLocaleDateString();
          const amount = (order.amount / 100).toFixed(2);
          
          return `
            <tr class="border-b border-white/5 hover:bg-white/5">
              <td class="py-3 pr-3 text-white/60 text-xs font-mono">${order.id.slice(-8)}</td>
              <td class="py-3 pr-3">
                <p class="text-white text-sm">${order.customerName}</p>
                <p class="text-white/40 text-xs">${order.customerEmail}</p>
              </td>
              <td class="py-3 pr-3 text-white/80 text-sm">${order.productName}</td>
              <td class="py-3 pr-3 text-white/60 text-sm">${order.country || '-'}</td>
              <td class="py-3 pr-3 text-white/50 text-sm">${date}</td>
              <td class="py-3 pr-3"><span class="${statusClass} text-sm">${order.status}</span></td>
              <td class="py-3 pr-3 text-right text-white font-medium">€${amount}</td>
              <td class="py-3 text-center">
                ${order.status === 'completed' ? `
                  <button onclick="openRefundModal('${order.id}', '€${amount}')" class="p-1.5 rounded bg-red-500/10 text-red-400 hover:bg-red-500/20 text-xs">↩</button>
                ` : '-'}
              </td>
            </tr>
          `;
        }).join('');
        
        // Mobile cards
        mobileCards.innerHTML = data.orders.map((order: any) => {
          const statusClass = order.status === 'completed' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400';
          const date = new Date(order.createdAt).toLocaleDateString();
          const amount = (order.amount / 100).toFixed(2);
          
          return `
            <div class="bg-white/5 rounded-lg p-3 border border-white/10">
              <div class="flex justify-between items-start mb-2">
                <div>
                  <p class="text-white font-medium text-sm">${order.customerName}</p>
                  <p class="text-white/40 text-xs">${order.productName}</p>
                </div>
                <span class="${statusClass} text-xs px-2 py-0.5 rounded">${order.status}</span>
              </div>
              <div class="flex justify-between items-center">
                <span class="text-white/50 text-xs">${date} · ${order.country || '-'}</span>
                <div class="flex items-center gap-2">
                  <span class="text-amber-400 font-bold">€${amount}</span>
                  ${order.status === 'completed' ? `
                    <button onclick="openRefundModal('${order.id}', '€${amount}')" class="p-1 rounded bg-red-500/20 text-red-400 text-xs">↩</button>
                  ` : ''}
                </div>
              </div>
            </div>
          `;
        }).join('');
      }
      
      document.getElementById('paginationInfo')!.textContent = `${data.total} orders`;
      document.getElementById('pageNumber')!.textContent = currentPage.toString();
      prevPageBtn.disabled = currentPage <= 1;
      nextPageBtn.disabled = currentPage >= data.totalPages;
      
    } catch (error) {
      console.error('Orders error:', error);
    }
  }
  
  refreshBtn?.addEventListener('click', loadDashboardData);
  
  let searchTimeout: ReturnType<typeof setTimeout>;
  searchInput?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
      currentPage = 1;
      loadOrders();
    }, 500);
  });
  
  statusFilter?.addEventListener('change', () => {
    currentPage = 1;
    loadOrders();
  });
  
  prevPageBtn?.addEventListener('click', () => {
    if (currentPage > 1) {
      currentPage--;
      loadOrders();
    }
  });
  
  nextPageBtn?.addEventListener('click', () => {
    currentPage++;
    loadOrders();
  });
  
  // Refund modal
  let currentRefundOrderId = '';
  
  (window as any).openRefundModal = (orderId: string, amount: string) => {
    currentRefundOrderId = orderId;
    document.getElementById('refundOrderId')!.textContent = orderId;
    document.getElementById('refundAmount')!.textContent = amount;
    (document.getElementById('refundReason') as HTMLTextAreaElement).value = '';
    document.getElementById('refundModal')!.classList.remove('hidden');
  };
  
  document.getElementById('cancelRefund')?.addEventListener('click', () => {
    document.getElementById('refundModal')!.classList.add('hidden');
  });
  
  document.getElementById('confirmRefund')?.addEventListener('click', async () => {
    const reason = (document.getElementById('refundReason') as HTMLTextAreaElement).value;
    const btn = document.getElementById('confirmRefund') as HTMLButtonElement;
    
    btn.disabled = true;
    btn.textContent = 'Processing...';
    
    try {
      const response = await fetch('/api/admin', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'refund',
          password: adminPassword,
          orderId: currentRefundOrderId,
          reason
        })
      });
      
      if (response.ok) {
        alert('Refund processed!');
        document.getElementById('refundModal')!.classList.add('hidden');
        loadDashboardData();
      } else {
        const result = await response.json();
        alert(`Error: ${result.error}`);
      }
    } catch (error) {
      alert('Failed to process refund');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Refund';
    }
  });
</script>
