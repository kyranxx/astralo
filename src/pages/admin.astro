  async function loadStats() {
    try {
      // Build URL with date filter parameters
      let url = `/api/admin?action=stats&password=${encodeURIComponent(adminPassword)}`;
      if (currentDateFilter.startDate) {
        url += `&startDate=${encodeURIComponent(currentDateFilter.startDate)}`;
      }
      if (currentDateFilter.endDate) {
        url += `&endDate=${encodeURIComponent(currentDateFilter.endDate)}`;
      }
      
      const response = await fetch(url);
      if (!response.ok) throw new Error('Failed');
      
      const stats = await response.json();
      
      document.getElementById('totalRevenue')!.textContent = `€${stats.totalRevenue.toFixed(2)}`;
      document.getElementById('refundedAmount')!.textContent = `€${stats.refundedAmount.toFixed(2)} refunded`;
      document.getElementById('totalOrders')!.textContent = stats.totalOrders.toString();
      document.getElementById('completedOrders')!.textContent = stats.completedOrders.toString();
      document.getElementById('refundedOrders')!.textContent = stats.refundedOrders.toString();
      
      if (stats.revenueByCountry.length > 0) {
        const top = stats.revenueByCountry[0];
        document.getElementById('topCountry')!.textContent = top.country;
        document.getElementById('topCountryStats')!.textContent = `€${top.revenue.toFixed(0)} · ${top.orders}`;
        allCountriesData = stats.revenueByCountry;
      }
      
      if (stats.revenueByProduct.length > 0) {
        const top = stats.revenueByProduct[0];
        document.getElementById('topProduct')!.textContent = top.product;
        document.getElementById('topProductStats')!.textContent = `€${top.revenue.toFixed(0)} · ${top.orders}`;
        allProductsData = stats.revenueByProduct;
      }
      
      const lastUpdated = document.getElementById('lastUpdated');
      if (lastUpdated) {
        const updateDate = new Date(stats.lastUpdated);
        const formattedDate = updateDate.toLocaleDateString('en-GB', { 
          day: '2-digit', 
          month: '2-digit', 
          year: 'numeric' 
        });
        const formattedTime = updateDate.toLocaleTimeString('en-GB', { 
          hour: '2-digit', 
          minute: '2-digit', 
          second: '2-digit' 
        });
        lastUpdated.textContent = `Last updated: ${formattedDate} ${formattedTime}`;
        lastUpdated.classList.remove('hidden');
        lastUpdated.classList.add('sm:block');
      }
      
      // Chart
      const chartContainer = document.getElementById('revenueChart')!;
      const labelsContainer = document.getElementById('revenueLabels')!;
      
      if (stats.monthlyData.length > 0) {
        const maxRevenue = Math.max(...stats.monthlyData.map((m: any) => m.revenue), 1);
        
        // Update Y-axis labels
        const yMax = document.getElementById('yMax');
        const yMid = document.getElementById('yMid');
        if (yMax) yMax.textContent = `€${Math.round(maxRevenue)}`;
        if (yMid) yMid.textContent = `€${Math.round(maxRevenue / 2)}`;
        
        const monthNames = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
        
        chartContainer.innerHTML = stats.monthlyData.map((m: any, i: number) => {
          const height = Math.max((m.revenue / maxRevenue) * 100, 5);
          const month = parseInt(m.month.split('-')[1]) - 1;
          return `<div class="chart-bar flex-1 bg-gradient-to-t from-amber-500/30 to-amber-400/50 hover:from-amber-500/50 hover:to-amber-400/70 rounded-t cursor-pointer" style="height: ${height}%" data-revenue="€${m.revenue.toFixed(2)}" data-month="${monthNames[month]} ${m.month.split('-')[0]}"></div>`;
        }).join('');
        
        labelsContainer.innerHTML = stats.monthlyData.map((m: any) => {
          const month = parseInt(m.month.split('-')[1]) - 1;
          return `<span>${monthNames[month]}</span>`;
        }).join('');
        
        // Add tooltip functionality
        const tooltip = document.getElementById('chartTooltip');
        chartContainer.querySelectorAll('.chart-bar').forEach(bar => {
          bar.addEventListener('mouseenter', (e) => {
            const target = e.target as HTMLElement;
            if (tooltip) {
              tooltip.textContent = `${target.dataset.month}: ${target.dataset.revenue}`;
              tooltip.classList.remove('hidden');
            }
          });
          bar.addEventListener('mousemove', (e) => {
            const event = e as MouseEvent;
            if (tooltip) {
              const rect = chartContainer.getBoundingClientRect();
              tooltip.style.left = `${event.clientX - rect.left + 10}px`;
              tooltip.style.top = `${event.clientY - rect.top - 30}px`;
            }
          });
          bar.addEventListener('mouseleave', () => {
            if (tooltip) tooltip.classList.add('hidden');
          });
        });
      }
      
      // Countries - with improved styling
      const countryList = document.getElementById('countryList')!;
      if (stats.revenueByCountry.length > 0) {
        countryList.innerHTML = stats.revenueByCountry.slice(0, 5).map((c: any, i: number) => `
          <div class="flex items-center justify-between p-2 rounded-lg ${i === 0 ? 'bg-amber-500/10 border border-amber-500/20' : 'hover:bg-white/5'} transition-colors">
            <div class="flex items-center gap-2">
              <span class="text-white/40 text-xs w-4">${i + 1}.</span>
              <div>
                <p class="text-white text-sm font-medium">${c.country}</p>
                <p class="text-white/40 text-xs">${c.orders} orders</p>
              </div>
            </div>
            <div class="text-green-400 font-bold text-sm">€${c.revenue.toFixed(0)}</div>
          </div>
        `).join('');
      } else {
        countryList.innerHTML = '<p class="text-white/50 text-sm text-center py-4">No data yet</p>';
      }
    } catch (error) {
      console.error('Stats error:', error);
    }
  }
  
