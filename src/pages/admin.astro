---
import Layout from '../layouts/Layout.astro';
import { DollarSign, ShoppingCart, Star, TrendingUp, RefreshCw, Search, ArrowLeft, ArrowRight, Globe, LogOut, Calendar, ChevronDown } from 'lucide-astro';
---

<Layout title="Admin Dashboard - Astralo" backgroundImage="/background4.png">
  <div class="min-h-screen relative z-10">
    <!-- Header -->
    <header class="bg-black/60 backdrop-blur-xl border-b border-white/10">
      <div class="max-w-7xl mx-auto px-3 sm:px-4 py-3 sm:py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2 sm:gap-3">
            <img src="/logo.png" alt="Astralo" class="h-8 sm:h-10" />
            <div class="border-l border-white/20 pl-2 sm:pl-3">
              <h1 class="text-sm sm:text-lg font-bold text-white">Admin</h1>
              <p class="text-xs text-white/60 hidden" id="lastUpdated"></p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button id="refreshBtn" class="p-2 sm:px-3 sm:py-2 rounded-lg bg-white/10 text-white text-sm flex items-center gap-2 hover:bg-white/20 transition-colors hidden">
              <RefreshCw class="w-4 h-4" />
              <span class="hidden sm:inline">Refresh</span>
            </button>
            <button id="logoutBtn" class="p-2 sm:px-3 sm:py-2 rounded-lg bg-red-500/20 text-red-400 text-sm flex items-center gap-2 hover:bg-red-500/30 transition-colors hidden">
              <LogOut class="w-4 h-4" />
              <span class="hidden sm:inline">Logout</span>
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- Login Form -->
    <div id="loginContainer" class="max-w-sm mx-auto px-4 py-12 sm:py-20">
      <div class="bg-black/60 backdrop-blur-xl rounded-2xl p-6 sm:p-8 border border-white/10">
        <h2 class="text-xl sm:text-2xl font-bold text-white text-center mb-6">Admin Login</h2>
        <form id="loginForm">
          <input 
            type="password" 
            id="passwordInput" 
            placeholder="Enter password"
            class="w-full px-4 py-3 rounded-xl bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-amber-400/50 mb-4 text-base"
          />
          <button type="submit" class="w-full bg-gradient-to-r from-amber-400 to-amber-500 text-black font-semibold py-3 rounded-xl hover:from-amber-500 hover:to-amber-600 transition-all">
            Login
          </button>
          <p id="loginError" class="text-red-400 text-sm text-center mt-4 hidden">Invalid password</p>
        </form>
      </div>
    </div>

    <!-- Main Dashboard -->
    <main id="dashboardContainer" class="max-w-7xl mx-auto px-3 sm:px-4 py-4 sm:py-8 hidden">
      <!-- Date Filter Buttons -->
      <div class="bg-black/50 backdrop-blur-xl rounded-xl p-3 sm:p-4 border border-white/10 mb-4 sm:mb-6">
        <div class="flex flex-wrap items-center gap-2">
          <div class="flex items-center gap-1 sm:gap-2 mr-2">
            <Calendar class="w-4 h-4 text-amber-400" />
            <span class="text-white/60 text-xs sm:text-sm font-medium hidden sm:inline">Date Range:</span>
          </div>
          
          <!-- Quick filters -->
          <button id="filterToday" class="date-filter-btn px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
            Today
          </button>
          <button id="filter7Days" class="date-filter-btn px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
            Last 7 Days
          </button>
          <button id="filter30Days" class="date-filter-btn px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
            Last 30 Days
          </button>
          <button id="filterYTD" class="date-filter-btn px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
            YTD
          </button>
          <button id="filterAllTime" class="date-filter-btn active px-2 sm:px-3 py-1.5 rounded-lg bg-amber-500/20 text-amber-400 text-xs sm:text-sm border border-amber-500/30">
            All Time
          </button>
          
          <!-- Month dropdown -->
          <div class="relative">
            <button id="monthDropdownBtn" class="date-filter-btn flex items-center gap-1 px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
              <span>Month</span>
              <ChevronDown class="w-3 h-3" />
            </button>
            <div id="monthDropdown" class="absolute top-full left-0 mt-1 bg-[#1a1a2e] border border-white/20 rounded-lg shadow-xl z-30 hidden min-w-[140px] max-h-60 overflow-y-auto">
              <!-- Months will be populated dynamically -->
            </div>
          </div>
          
          <!-- Year dropdown -->
          <div class="relative">
            <button id="yearDropdownBtn" class="date-filter-btn flex items-center gap-1 px-2 sm:px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs sm:text-sm hover:bg-amber-500/20 hover:text-amber-400 transition-all border border-transparent hover:border-amber-500/30">
              <span>Year</span>
              <ChevronDown class="w-3 h-3" />
            </button>
            <div id="yearDropdown" class="absolute top-full left-0 mt-1 bg-[#1a1a2e] border border-white/20 rounded-lg shadow-xl z-30 hidden min-w-[100px]">
              <!-- Years will be populated dynamically -->
            </div>
          </div>
        </div>
        
        <!-- Active filter display -->
        <div id="activeFilterDisplay" class="mt-2 text-xs text-white/50 hidden">
          Showing: <span id="activeFilterText" class="text-amber-400">All Time</span>
        </div>
      </div>

      <!-- Stats Grid - 2x2 on mobile, 4 on desktop -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-6 sm:mb-8">
        <!-- Total Revenue -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Revenue</p>
            <DollarSign class="w-4 h-4 sm:w-5 sm:h-5 text-green-500" />
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-white" id="totalRevenue">€0</h3>
          <p class="text-xs text-white/40 mt-1" id="refundedAmount">€0 refunded</p>
        </div>

        <!-- Orders -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Orders</p>
            <ShoppingCart class="w-4 h-4 sm:w-5 sm:h-5 text-blue-500" />
          </div>
          <h3 class="text-xl sm:text-2xl font-bold text-white" id="totalOrders">0</h3>
          <p class="text-xs text-white/40 mt-1">
            <span class="text-green-400" id="completedOrders">0</span> ✓ 
            <span class="text-red-400" id="refundedOrders">0</span> ↩
          </p>
        </div>

        <!-- Top Country - Clickable -->
        <div id="topCountryCard" class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10 cursor-pointer hover:bg-black/60 hover:border-amber-500/30 transition-all group">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Top Country</p>
            <Globe class="w-4 h-4 sm:w-5 sm:h-5 text-purple-500" />
          </div>
          <h3 class="text-lg sm:text-xl font-bold text-white truncate" id="topCountry">-</h3>
          <p class="text-xs text-white/40 mt-1" id="topCountryStats">-</p>
          <p class="text-[10px] text-amber-400/70 group-hover:text-amber-400 mt-1 transition-colors">Click for all →</p>
        </div>

        <!-- Top Product - Clickable -->
        <div id="topProductCard" class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-5 border border-white/10 cursor-pointer hover:bg-black/60 hover:border-amber-500/30 transition-all group">
          <div class="flex items-center justify-between mb-2">
            <p class="text-white/60 text-xs sm:text-sm">Best Seller</p>
            <Star class="w-4 h-4 sm:w-5 sm:h-5 text-amber-500" />
          </div>
          <h3 class="text-sm sm:text-lg font-bold text-white truncate" id="topProduct">-</h3>
          <p class="text-xs text-white/40 mt-1" id="topProductStats">-</p>
          <p class="text-[10px] text-amber-400/70 group-hover:text-amber-400 mt-1 transition-colors">Click for all →</p>
        </div>
      </div>

      <!-- Charts Row -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6 mb-6 sm:mb-8">
        <!-- Revenue Chart -->
        <div class="lg:col-span-2 bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10 relative overflow-hidden">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-base sm:text-lg font-bold text-white">Revenue</h2>
              <p class="text-xs text-white/50">Last 12 months</p>
            </div>
            <TrendingUp class="w-5 h-5 text-green-500" />
          </div>
          <div class="flex gap-3 relative z-10">
            <!-- Y-axis labels -->
            <div class="flex flex-col justify-between text-[10px] sm:text-xs text-white/50 h-32 sm:h-40 py-1 min-w-[45px] text-right" id="yAxisLabels">
              <span id="yMax">€0</span>
              <span id="yMid">€0</span>
              <span>€0</span>
            </div>
            <!-- Chart bars -->
            <div class="flex-1 flex items-end gap-1 sm:gap-2 h-32 sm:h-40 border-l border-b border-white/10 pl-2 pb-1" id="revenueChart">
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
              <div class="chart-bar-skeleton"></div>
            </div>
          </div>
          <div class="flex pl-[52px] sm:pl-[56px] justify-between text-[10px] sm:text-xs text-white/40 mt-2" id="revenueLabels">
            <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span>
            <span>May</span><span>Jun</span><span>Jul</span><span>Aug</span>
            <span>Sep</span><span>Oct</span><span>Nov</span><span>Dec</span>
          </div>
          <!-- Tooltip for chart -->
          <div id="chartTooltip" class="absolute hidden bg-black/90 text-white text-xs px-2 py-1 rounded pointer-events-none z-20 border border-amber-500/30"></div>
        </div>

        <!-- Countries -->
        <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10">
          <h2 class="text-base sm:text-lg font-bold text-white mb-4">By Country</h2>
          <div class="space-y-3" id="countryList">
            <!-- Loading skeleton -->
            <div class="country-skeleton"></div>
            <div class="country-skeleton"></div>
            <div class="country-skeleton"></div>
          </div>
        </div>
      </div>

      <!-- Orders Table -->
      <div class="bg-black/50 backdrop-blur-xl rounded-xl p-4 sm:p-6 border border-white/10">
        <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between mb-4 gap-3">
          <h2 class="text-base sm:text-lg font-bold text-white">Orders</h2>
          
          <!-- Search & Filter - stacked on mobile -->
          <div class="flex flex-wrap items-center gap-2 w-full sm:w-auto">
            <div class="relative flex-1 sm:flex-none">
              <Search class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/50" />
              <input 
                type="text" 
                id="searchInput"
                placeholder="Search..."
                class="w-full sm:w-40 pl-9 pr-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none focus:border-amber-400/50 text-sm"
              />
            </div>
            <select id="statusFilter" class="flex-1 sm:flex-none px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none text-sm">
              <option value="all">All</option>
              <option value="completed">Completed</option>
              <option value="refunded">Refunded</option>
            </select>
          </div>
        </div>
        
        <!-- Mobile Cards View -->
        <div class="sm:hidden space-y-3" id="ordersMobileCards">
          <div class="text-center text-white/50 py-4">Loading...</div>
        </div>

        <!-- Desktop Table -->
        <div class="hidden sm:block overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-white/10">
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">ID</th>
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Customer</th>
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Product</th>
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Country</th>
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Date</th>
                <th class="text-left text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Status</th>
                <th class="text-right text-white/60 text-xs font-medium uppercase tracking-wider pb-3 pr-3">Amount</th>
                <th class="text-center text-white/60 text-xs font-medium uppercase tracking-wider pb-3">Actions</th>
              </tr>
            </thead>
            <tbody id="ordersTableBody" class="text-sm">
              <!-- Loading skeleton rows -->
              <tr class="border-b border-white/5"><td colspan="8" class="py-4"><div class="table-skeleton"></div></td></tr>
              <tr class="border-b border-white/5"><td colspan="8" class="py-4"><div class="table-skeleton"></div></td></tr>
              <tr class="border-b border-white/5"><td colspan="8" class="py-4"><div class="table-skeleton"></div></td></tr>
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-4 pt-4 border-t border-white/10">
          <p class="text-white/50 text-xs sm:text-sm" id="paginationInfo">0 orders</p>
          <div class="flex items-center gap-1 sm:gap-2">
            <button id="prevPage" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20 transition-colors disabled:opacity-30">
              <ArrowLeft class="w-4 h-4" />
            </button>
            <span class="text-white/70 text-xs sm:text-sm px-2" id="pageNumber">1</span>
            <button id="nextPage" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20 transition-colors disabled:opacity-30">
              <ArrowRight class="w-4 h-4" />
            </button>
          </div>
        </div>
      </div>
    </main>

    <!-- Refund Modal -->
    <div id="refundModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden p-4">
      <div class="bg-[#1a1a2e] rounded-2xl p-6 max-w-sm w-full border border-white/10">
        <h3 class="text-lg font-bold text-white mb-3">Confirm Refund</h3>
        <p class="text-white/70 text-sm mb-2">Refund order <span id="refundOrderId" class="text-amber-400 font-semibold"></span>?</p>
        <p class="text-white/70 text-sm mb-4">Amount: <span id="refundAmount" class="text-white font-semibold"></span></p>
        <textarea 
          id="refundReason"
          placeholder="Reason (optional)"
          class="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white placeholder-white/50 focus:outline-none mb-4 h-20 resize-none text-sm"
        ></textarea>
        <div class="flex gap-2">
          <button id="cancelRefund" class="flex-1 px-4 py-2 rounded-lg bg-white/10 text-white text-sm hover:bg-white/20">Cancel</button>
          <button id="confirmRefund" class="flex-1 px-4 py-2 rounded-lg bg-red-500 text-white text-sm hover:bg-red-600 font-semibold">Refund</button>
        </div>
      </div>
    </div>

    <!-- Order Detail Modal -->
    <div id="orderDetailModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden p-4 overflow-y-auto">
      <div class="bg-[#1a1a2e] rounded-2xl p-6 max-w-2xl w-full border border-white/10 my-8">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-white">Order Details</h3>
          <button id="closeOrderDetail" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20">✕</button>
        </div>
        <div id="orderDetailContent" class="space-y-4">
          <div class="grid grid-cols-2 gap-4 text-sm">
            <div><span class="text-white/50">Order ID:</span> <span id="detailOrderId" class="text-white font-mono"></span></div>
            <div><span class="text-white/50">Status:</span> <span id="detailStatus" class="font-semibold"></span></div>
            <div><span class="text-white/50">Customer:</span> <span id="detailCustomer" class="text-white"></span></div>
            <div><span class="text-white/50">Email:</span> <span id="detailEmail" class="text-white"></span></div>
            <div><span class="text-white/50">Product:</span> <span id="detailProduct" class="text-amber-400"></span></div>
            <div><span class="text-white/50">Amount:</span> <span id="detailAmount" class="text-green-400 font-bold"></span></div>
            <div><span class="text-white/50">Country:</span> <span id="detailCountry" class="text-white"></span></div>
            <div><span class="text-white/50">Date:</span> <span id="detailDate" class="text-white"></span></div>
            <div><span class="text-white/50">Birth Date:</span> <span id="detailBirth" class="text-white"></span></div>
            <div><span class="text-white/50">Language:</span> <span id="detailLang" class="text-white uppercase"></span></div>
          </div>
          <div class="border-t border-white/10 pt-4">
            <h4 class="text-white font-bold mb-2">Horoscope Content</h4>
            <div id="detailHoroscope" class="bg-black/30 rounded-lg p-4 max-h-64 overflow-y-auto text-white/80 text-sm whitespace-pre-wrap"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Countries Modal -->
    <div id="countriesModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden p-4">
      <div class="bg-[#1a1a2e] rounded-2xl p-6 max-w-lg w-full border border-white/10 max-h-[80vh] overflow-y-auto">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-white">All Countries</h3>
          <button id="closeCountries" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20">✕</button>
        </div>
        <div id="allCountriesList" class="space-y-3"></div>
      </div>
    </div>

    <!-- Products Modal -->
    <div id="productsModal" class="fixed inset-0 bg-black/80 flex items-center justify-center z-50 hidden p-4">
      <div class="bg-[#1a1a2e] rounded-2xl p-6 max-w-lg w-full border border-white/10">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-bold text-white">All Products</h3>
          <button id="closeProducts" class="p-2 rounded-lg bg-white/10 text-white/70 hover:bg-white/20">✕</button>
        </div>
        <div id="allProductsList" class="space-y-3"></div>
      </div>
    </div>
  </div>
</Layout>

<style>
  select option {
    background-color: #1a1a2e;
    color: white;
  }
  
  /* Loading skeleton animations */
  .chart-bar-skeleton {
    flex: 1;
    background: linear-gradient(90deg, rgba(251, 191, 36, 0.1) 0%, rgba(251, 191, 36, 0.2) 50%, rgba(251, 191, 36, 0.1) 100%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 4px 4px 0 0;
    height: 40%;
  }
  
  .country-skeleton {
    height: 48px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.1) 50%, rgba(255, 255, 255, 0.05) 100%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 8px;
  }
  
  .table-skeleton {
    height: 20px;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.1) 50%, rgba(255, 255, 255, 0.05) 100%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
    border-radius: 4px;
  }
  
  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
  
  /* Chart bar hover effect */
  .chart-bar {
    transition: all 0.2s ease;
    position: relative;
  }
  
  .chart-bar:hover {
    filter: brightness(1.3);
    transform: scaleY(1.02);
    transform-origin: bottom;
  }
  
  /* Status badges */
  .status-badge {
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    border-radius: 9999px;
    font-size: 11px;
    font-weight: 500;
    text-transform: capitalize;
  }
  
  .status-completed {
    background: rgba(34, 197, 94, 0.15);
    color: #4ade80;
    border: 1px solid rgba(34, 197, 94, 0.3);
  }
  
  .status-refunded {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.3);
  }
  
  .status-pending {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
    border: 1px solid rgba(251, 191, 36, 0.3);
  }
  
  /* Date filter buttons */
  .date-filter-btn.active {
    background: rgba(251, 191, 36, 0.2);
    color: #fbbf24;
    border-color: rgba(251, 191, 36, 0.3);
  }
  
  .dropdown-item {
    display: block;
    width: 100%;
    padding: 0.5rem 0.75rem;
    text-align: left;
    font-size: 0.75rem;
    color: white;
    transition: all 0.15s;
    cursor: pointer;
    border: none;
    background: transparent;
  }
  
  .dropdown-item:hover {
    background: rgba(251, 191, 36, 0.2);
    color: #fbbf24;
  }
  
  .dropdown-item.active {
    background: rgba(251, 191, 36, 0.3);
    color: #fbbf24;
  }
</style>

<script>
  let adminPassword = '';
  let currentPage = 1;
  const limit = 10;
  
  // Store data for detail modals
  let allCountriesData: any[] = [];
  let allProductsData: any[] = [];
  
  // Date filter state
  let currentDateFilter: { startDate?: string; endDate?: string; label: string } = { label: 'All Time' };
  
  // Date filter helper functions
  function getStartOfDay(date: Date): Date {
    return new Date(date.getFullYear(), date.getMonth(), date.getDate(), 0, 0, 0, 0);
  }
  
  function getEndOfDay(date: Date): Date {
    return new Date(date.getFullYear(), date.getMonth(), date.getDate(), 23, 59, 59, 999);
  }
  
  function getDateRangeForToday(): { startDate: string; endDate: string } {
    const now = new Date();
    return {
      startDate: getStartOfDay(now).toISOString(),
      endDate: getEndOfDay(now).toISOString()
    };
  }
  
  function getDateRangeForLast7Days(): { startDate: string; endDate: string } {
    const now = new Date();
    const start = new Date(now);
    start.setDate(start.getDate() - 6); // 6 days ago + today = 7 days
    return {
      startDate: getStartOfDay(start).toISOString(),
      endDate: getEndOfDay(now).toISOString()
    };
  }
  
  function getDateRangeForLast30Days(): { startDate: string; endDate: string } {
    const now = new Date();
    const start = new Date(now);
    start.setDate(start.getDate() - 29); // 29 days ago + today = 30 days
    return {
      startDate: getStartOfDay(start).toISOString(),
      endDate: getEndOfDay(now).toISOString()
    };
  }
  
  function getDateRangeForYTD(): { startDate: string; endDate: string } {
    const now = new Date();
    const start = new Date(now.getFullYear(), 0, 1); // Jan 1st of current year
    return {
      startDate: getStartOfDay(start).toISOString(),
      endDate: getEndOfDay(now).toISOString()
    };
  }
  
  function getDateRangeForMonth(year: number, month: number): { startDate: string; endDate: string } {
    const start = new Date(year, month, 1);
    const end = new Date(year, month + 1, 0); // Last day of the month
    return {
      startDate: getStartOfDay(start).toISOString(),
      endDate: getEndOfDay(end).toISOString()
    };
  }
  
  function getDateRangeForYear(year: number): { startDate: string; endDate: string } {
    const start = new Date(year, 0, 1);
    const end = new Date(year, 11, 31);
    return {
      startDate: getStartOfDay(start).toISOString(),
      endDate: getEndOfDay(end).toISOString()
    };
  }
  
