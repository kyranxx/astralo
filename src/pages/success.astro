// Get translations for current lang, fallback to English
const st = successT[currentLang as keyof typeof successT] || successT.en;

const horoscopeTypes = [
  { id: "daily", name: t.products.daily.name },
  { id: "weekly", name: t.products.weekly.name },
  { id: "monthly", name: t.products.monthly.name },
  { id: "partner", name: t.products.partner.name },
];

const sessionId = Astro.url.searchParams.get('session_id');

if (!sessionId) {
  return Astro.redirect(currentLang === 'en' ? '/' : `/${currentLang}/`);
}

const homeUrl = currentLang === 'en' ? '/' : `/${currentLang}/`;
---

<Layout title={`${t.success.title} - Astralo`} lang={currentLang} noIndex={true}>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={homeUrl} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ChevronLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">{st.backHome}</span>
          </a>
          <a href={homeUrl} class="flex items-center">
            <img src="/logo.webp" alt="Astralo" class="h-9" style="aspect-ratio: 3.41;" />
          </a>
          <div class="w-24"></div> <!-- Spacer for balance -->
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <!-- Background Elements -->
      <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/20 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-amber-500/20 rounded-full blur-[100px]"></div>
      </div>

      <div class="w-full max-w-2xl relative z-10">
        <div class="glass-strong rounded-2xl p-6 sm:p-10 animate-fade-in border border-white/10">
          
          <!-- Loading State -->
          <div id="loading-state" class="text-center py-8">
            <div class="relative inline-flex items-center justify-center w-20 h-20 mb-6">
              <div class="absolute inset-0 bg-amber-400/20 rounded-full animate-ping"></div>
              <div class="relative w-20 h-20 rounded-full bg-gradient-to-br from-amber-400/20 to-purple-500/20 border border-white/10 flex items-center justify-center">
                <Sparkles class="w-8 h-8 text-amber-400 animate-pulse" />
              </div>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-3">
              {st.preparing}
            </h1>
            <p id="loading-stage" class="text-white/60 text-base max-w-md mx-auto mb-6">
              {st.analyzing}
            </p>
            
            <!-- Progress Bar -->
            <div class="max-w-xs mx-auto">
              <div class="w-full bg-white/10 rounded-full h-2 mb-2">
                <div id="progress-bar" class="bg-gradient-to-r from-amber-400 to-amber-500 h-2 rounded-full transition-all duration-500" style="width: 10%"></div>
              </div>
              <p id="progress-text" class="text-amber-400/80 text-sm font-medium">10%</p>
            </div>
          </div>

          <!-- Success State -->
          <div id="success-state" class="hidden text-center">
            <!-- Success Icon -->
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gradient-to-br from-green-400/20 to-emerald-600/20 border border-white/10 mb-6">
              <CheckCircle class="w-10 h-10 text-green-400" />
            </div>

            <!-- Title -->
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">
              {st.generated}
            </h1>
            
            <!-- Product Name -->
            <div class="flex items-center justify-center gap-2 text-amber-400 font-medium uppercase tracking-wider mb-6">
              <Star class="w-4 h-4 fill-current" />
              <span id="product-name"></span>
              <Star class="w-4 h-4 fill-current" />
            </div>

            <!-- Email Box -->
            <div class="relative mb-8">
              <div class="glass rounded-2xl p-6 sm:p-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-amber-400/20 to-purple-500/20 border border-white/10 mb-4">
                  <Mail class="w-8 h-8 text-amber-400" />
                </div>
                
                <h2 class="text-xl sm:text-2xl font-bold text-white mb-3">
                  {st.checkEmail}
                </h2>
                
                <p id="email-delivery-status" class="text-white/80 mb-3">
                  {st.sendingTo || 'Your personalized reading is being sent to:'}
                </p>
                
                <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/5 border border-white/10 mb-4">
                  <Mail class="w-4 h-4 text-amber-400" />
                  <span id="customer-email" class="text-white font-medium"></span>
                </div>


              </div>
            </div>

            <!-- Email Status with Progress -->
            <div id="email-status" class="mb-6 hidden">
              <div class="max-w-xs mx-auto">
                <div class="flex items-center justify-center gap-2 mb-3">
                  <div class="w-3 h-3 rounded-full bg-amber-400 animate-pulse"></div>
                  <span id="email-status-text" class="text-white/80 text-sm">{st.sending}</span>
                </div>
                <div class="w-full bg-white/10 rounded-full h-2 mb-2">
                  <div id="email-progress-bar" class="bg-gradient-to-r from-amber-400 to-amber-500 h-2 rounded-full transition-all duration-300" style="width: 0%"></div>
                </div>
                <p id="email-progress-text" class="text-amber-400/80 text-sm font-medium text-center">0%</p>
              </div>
            </div>

            <div id="email-success" class="mb-6 hidden">
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm">
                <CheckCircle class="w-4 h-4" />
                <span>{st.emailSent}</span>
              </div>
            </div>

            <!-- Back Button -->
            <a href={homeUrl} class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 transition-colors">
              <Home class="w-5 h-5" />
              <span>{st.backHome}</span>
            </a>

            <p class="text-white/40 text-xs mt-6">
              {st.didntReceive}<br />
              <a href="mailto:apollotechsro@gmail.com" class="text-amber-400 hover:underline">apollotechsro@gmail.com</a>
            </p>
          </div>

          <!-- Error State -->
          <div id="error-state" class="hidden text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/10 mb-4 border border-red-500/20">
              <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-white mb-2">{st.error}</h1>
            <p id="error-description" class="text-white/70 mb-2 text-sm">{st.errorDesc}</p>
            <p id="error-details" class="text-red-400/60 mb-6 text-xs italic font-mono break-all px-4"></p>
            <a href={homeUrl} class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-amber-500 text-black font-semibold">
              <Home class="w-4 h-4" />
              {st.backHome}
            </a>
          </div>

        </div>
      </div>
    </main>

    <Footer lang={currentLang} />
  </div>
</Layout>

<script is:inline define:vars={{ sessionId, horoscopeTypes, st }}>
  let horoscopeData = null;

  // Progress stages
  const stages = [
    { percent: 10, text: st.analyzing || 'Analyzing your birth chart...' },
    { percent: 30, text: st.generating || 'Generating your horoscope...' },
    { percent: 60, text: st.creatingPdf || 'Creating your PDF...' },
    { percent: 80, text: st.sendingEmail || 'Sending to your email...' },
    { percent: 100, text: st.complete || 'Complete!' }
  ];
  let currentStage = 0;

  function updateProgress(percent, text) {
    const bar = document.getElementById('progress-bar');
    const textEl = document.getElementById('progress-text');
    const stageEl = document.getElementById('loading-stage');
    if (bar) bar.style.width = percent + '%';
    if (textEl) textEl.textContent = percent + '%';
    if (stageEl && text) stageEl.textContent = text;
  }

  function animateProgress() {
    if (currentStage < stages.length - 1) {
      currentStage++;
      const stage = stages[currentStage];
      updateProgress(stage.percent, stage.text);
      
      // Schedule next update (slower for later stages)
      const delay = currentStage < 2 ? 2000 : 4000;
      setTimeout(animateProgress, delay);
    }
  }

  async function fetchHoroscope() {
    console.log('🚀 fetchHoroscope started for session:', sessionId);
    
    // Start progress animation
    setTimeout(animateProgress, 1500);
    
    try {
      const response = await fetch('/api/horoscope', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId }),
      });

      console.log('🚀 API Response status:', response.status);

      if (!response.ok) {
        const errorData = await response.json().catch(() => ({ error: 'Unknown error' }));
        const errorMsg = errorData.error || `HTTP error ${response.status}`;
        const errorDetails = errorData.details || '';
        
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('error-state').classList.remove('hidden');
        document.getElementById('error-details').textContent = errorDetails || errorMsg;
        return;
      }

      const data = await response.json();
      console.log('🚀 Horoscope data received');
      
      // Check if horoscope was already generated for this session (prevents duplicate on page reload)
      if (data.error === 'already_processed') {
        console.log('🚀 Horoscope already generated, showing success state');
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('success-state').classList.remove('hidden');
        document.getElementById('product-name').textContent = 'Horoscope';
        document.getElementById('customer-email').textContent = 'your email';
        document.getElementById('email-status').textContent = st.emailSent;
        document.getElementById('email-status').classList.remove('text-white/60');
        document.getElementById('email-status').classList.add('text-green-400');
        return;
      }
      
      horoscopeData = data;
      
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('success-state').classList.remove('hidden');
      
      const product = horoscopeTypes.find(t => t.id === data.product);
      const productName = product ? product.name : 'Your Horoscope';
      document.getElementById('product-name').textContent = productName;
      document.getElementById('customer-email').textContent = data.email;

      sendEmail(data, productName);

    } catch (error) {
      console.error('❌ Horoscope fetch failed:', error);
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-state').classList.remove('hidden');
      document.getElementById('error-details').textContent = error.message;
    }
  }

  async function sendEmail(data, productName) {
    const statusDiv = document.getElementById('email-status');
    const successDiv = document.getElementById('email-success');
    const progressBar = document.getElementById('email-progress-bar');
    const progressText = document.getElementById('email-progress-text');
    statusDiv.classList.remove('hidden');
    
    // Real progress tracking - estimate ~25 seconds for PNG generation + email
    const startTime = Date.now();
    const estimatedDuration = 25000; // 25 seconds estimate
    let emailProgress = 0;
    
    const progressInterval = setInterval(() => {
      const elapsed = Date.now() - startTime;
      // Calculate progress proportionally, cap at 95% until complete
      emailProgress = Math.min((elapsed / estimatedDuration) * 95, 95);
      if (progressBar) progressBar.style.width = emailProgress + '%';
      if (progressText) progressText.textContent = Math.round(emailProgress) + '%';
    }, 200);
    
    try {
      // Debug: log what we're sending to the email API
      const emailPayload = {
        email: data.email,
        customerName: data.name,
        horoscopeContent: data.horoscope,
        productName: productName,
        lang: data.lang || 'en',
        birthDate: data.birthDate || '',
        birthPlace: data.birthPlace || '',
        birthTime: data.birthTime || ''
      };
      console.log('📧 Email payload - hasEmail:', !!emailPayload.email, '| hasHoroscope:', !!emailPayload.horoscopeContent, '| length:', emailPayload.horoscopeContent?.length || 0, '| lang:', emailPayload.lang);
      
      const response = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(emailPayload)
      });
      
      clearInterval(progressInterval);
      
      if (!response.ok) throw new Error('Failed to send email');

      // Complete the progress to 100%
      if (progressBar) progressBar.style.width = '100%';
      if (progressText) progressText.textContent = '100%';
      
      // Update status text
      const statusText = document.getElementById('email-delivery-status');
      if (statusText) statusText.textContent = st.sentTo || 'Your personalized reading has been sent to:';

      // Hold at 100% for 3 seconds so user sees completion before transition
      setTimeout(() => {
        statusDiv.classList.add('hidden');
        successDiv.classList.remove('hidden');
      }, 3000);
    } catch (e) {
      console.error('Email failed', e);
      clearInterval(progressInterval);
      statusDiv.innerHTML = `
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
          <span>${st.emailFailed}</span>
        </div>
      `;
    }
  }

  fetchHoroscope();
</script>
