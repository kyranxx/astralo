// Get translations for current lang, fallback to English
const st = successT[currentLang as keyof typeof successT] || successT.en;

const horoscopeTypes = [
  { id: "daily", name: t.products.daily.name },
  { id: "weekly", name: t.products.weekly.name },
  { id: "monthly", name: t.products.monthly.name },
  { id: "partner", name: t.products.partner.name },
];

const sessionId = Astro.url.searchParams.get('session_id');

if (!sessionId) {
  return Astro.redirect(currentLang === 'en' ? '/' : `/${currentLang}/`);
}

const homeUrl = currentLang === 'en' ? '/' : `/${currentLang}/`;
---

<Layout title={`${t.success.title} - Astralo`} lang={currentLang}>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={homeUrl} class="flex items-center">
            <img src="/logo.png" alt="Astralo" class="h-9" />
          </a>
          <LanguageSwitcher lang={currentLang} />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <!-- Background Elements -->
      <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-purple-500/20 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-amber-500/20 rounded-full blur-[100px]"></div>
      </div>

      <div class="w-full max-w-2xl relative z-10">
        <div class="glass-strong rounded-2xl p-6 sm:p-10 animate-fade-in border border-white/10">
          
          <!-- Loading State -->
          <div id="loading-state" class="text-center py-8">
            <div class="relative inline-flex items-center justify-center w-20 h-20 mb-6">
              <div class="absolute inset-0 bg-amber-400/20 rounded-full animate-ping"></div>
              <div class="relative w-20 h-20 rounded-full bg-gradient-to-br from-amber-400/20 to-purple-500/20 border border-white/10 flex items-center justify-center">
                <Sparkles class="w-8 h-8 text-amber-400 animate-pulse" />
              </div>
            </div>
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-3">
              {st.preparing}
            </h1>
            <p class="text-white/60 text-base max-w-md mx-auto">
              {st.analyzing}
            </p>
          </div>

          <!-- Success State -->
          <div id="success-state" class="hidden text-center">
            <!-- Success Icon -->
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-gradient-to-br from-green-400/20 to-emerald-600/20 border border-white/10 mb-6">
              <CheckCircle class="w-10 h-10 text-green-400" />
            </div>

            <!-- Title -->
            <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">
              {st.generated}
            </h1>
            
            <!-- Product Name -->
            <div class="flex items-center justify-center gap-2 text-amber-400 font-medium uppercase tracking-wider mb-6">
              <Star class="w-4 h-4 fill-current" />
              <span id="product-name"></span>
              <Star class="w-4 h-4 fill-current" />
            </div>

            <!-- Email Box -->
            <div class="relative mb-8">
              <div class="glass rounded-2xl p-6 sm:p-8">
                <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gradient-to-br from-amber-400/20 to-purple-500/20 border border-white/10 mb-4">
                  <Mail class="w-8 h-8 text-amber-400" />
                </div>
                
                <h2 class="text-xl sm:text-2xl font-bold text-white mb-3">
                  {st.checkEmail}
                </h2>
                
                <p class="text-white/80 mb-3">
                  {st.sentTo}
                </p>
                
                <div class="inline-flex items-center gap-2 px-5 py-2 rounded-full bg-white/5 border border-white/10 mb-4">
                  <Mail class="w-4 h-4 text-amber-400" />
                  <span id="customer-email" class="text-white font-medium"></span>
                </div>

                <div class="text-white/60 text-sm space-y-1">
                  <p>✨ {st.inEmail}</p>
                  <p>📄 {st.docsAttached}</p>
                </div>
              </div>
            </div>

            <!-- Email Status -->
            <div id="email-status" class="mb-6 hidden">
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/5 border border-white/10 text-white/80 text-sm">
                <div class="w-3 h-3 rounded-full bg-amber-400 animate-pulse"></div>
                <span>{st.sending}</span>
              </div>
            </div>

            <div id="email-success" class="mb-6 hidden">
              <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-500/10 border border-green-500/20 text-green-400 text-sm">
                <CheckCircle class="w-4 h-4" />
                <span>{st.emailSent}</span>
              </div>
            </div>

            <!-- Back Button -->
            <a href={homeUrl} class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-white/5 border border-white/10 text-white font-medium hover:bg-white/10 transition-colors">
              <Home class="w-5 h-5" />
              <span>{st.backHome}</span>
            </a>

            <p class="text-white/40 text-xs mt-6">
              {st.didntReceive}<br />
              <a href="mailto:info@astralo.online" class="text-amber-400 hover:underline">info@astralo.online</a>
            </p>
          </div>

          <!-- Error State -->
          <div id="error-state" class="hidden text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-red-500/10 mb-4 border border-red-500/20">
              <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h1 class="text-xl font-bold text-white mb-2">{st.error}</h1>
            <p class="text-white/70 mb-6 text-sm">{st.errorDesc}</p>
            <a href={homeUrl} class="inline-flex items-center gap-2 px-5 py-2 rounded-lg bg-amber-500 text-black font-semibold">
              <Home class="w-4 h-4" />
              {st.backHome}
            </a>
          </div>

        </div>
      </div>
    </main>

    <Footer lang={currentLang} />
  </div>
</Layout>

<script is:inline define:vars={{ sessionId, horoscopeTypes, st }}>
  let horoscopeData = null;

  async function fetchHoroscope() {
    try {
      const response = await fetch('/api/horoscope', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sessionId }),
      });

      if (!response.ok) throw new Error('Failed to fetch horoscope');

      const data = await response.json();
      horoscopeData = data;
      
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('success-state').classList.remove('hidden');
      
      const product = horoscopeTypes.find(t => t.id === data.product);
      const productName = product ? product.name : 'Your Horoscope';
      document.getElementById('product-name').textContent = productName;
      document.getElementById('customer-email').textContent = data.email;

      sendEmail(data, productName);

    } catch (error) {
      console.error(error);
      document.getElementById('loading-state').classList.add('hidden');
      document.getElementById('error-state').classList.remove('hidden');
    }
  }

  async function sendEmail(data, productName) {
    const statusDiv = document.getElementById('email-status');
    const successDiv = document.getElementById('email-success');
    statusDiv.classList.remove('hidden');
    
    try {
      const response = await fetch('/api/send-email', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          email: data.email,
          customerName: data.name,
          horoscopeContent: data.horoscope,
          productName: productName,
          lang: data.lang || 'en'
        })
      });
      
      if (!response.ok) throw new Error('Failed to send email');

      statusDiv.classList.add('hidden');
      successDiv.classList.remove('hidden');
    } catch (e) {
      console.error('Email failed', e);
      statusDiv.innerHTML = `
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-500/10 border border-red-500/20 text-red-400 text-sm">
          <span>${st.emailFailed}</span>
        </div>
      `;
    }
  }

  fetchHoroscope();
</script>
