---
/**
 * Localized Individual Blog Post Page - SEO Optimized
 * Dynamic route for all blog articles in all languages
 * Uses modular content from src/lib/blog
 */

import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { ArrowLeft, Calendar, Clock, Star, Twitter, Facebook, Linkedin, Link2, BookOpen } from 'lucide-astro';
import { isValidLocale, getTranslations, type SupportedLocale } from '../../../lib/i18n';
import {
  getArticleTranslation,
  getExactArticleTranslation,
  getArticleMeta,
  getAllArticleSlugs,
  getArticleLanguageCodes,
  getArticleSlugsForLang,
  getBlogDisplayTitle,
  getBlogUiTranslations,
  getBlogSeoTitle,
} from '../../../lib/blog';
import { buildInternalCampaignUrl } from '../../../lib/internal-campaign';
import {
  buildArticleSchema,
  buildBreadcrumbSchema,
  buildLocaleUrl,
  getProductLandingPath,
  getSuggestedProductForArticle,
  rewriteBlogOfferLinks,
  siteUrl,
} from '../../../lib/seo';
import { isStaleMonthlyHoroscopeSlug } from '../../../lib/indexing';
import { getProductCopy } from '../../../lib/products';

export const prerender = true;

// Generate all paths: lang × slug combinations
export function getStaticPaths() {
  const slugs = getAllArticleSlugs();
  
  const paths = [];
  for (const slug of slugs) {
    for (const lang of getArticleLanguageCodes(slug)) {
      if (lang !== 'en') {
        paths.push({ params: { lang, slug } });
      }
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;
const blogSlug = slug as string;
const t = getTranslations(currentLang);
const ui = getBlogUiTranslations(currentLang);

const meta = getArticleMeta(blogSlug);
const localizedPost = getExactArticleTranslation(blogSlug, currentLang);

if (!meta || !localizedPost) {
  return Astro.redirect(`/${currentLang}/blog`);
}

const displayTitle = getBlogDisplayTitle(localizedPost.title);
const post = {
  ...localizedPost,
  ...meta,
  displayTitle
};
const seoTitle = getBlogSeoTitle(displayTitle, localizedPost.seoTitle);

// Related posts (exclude current)
const allSlugs = getArticleSlugsForLang(currentLang);
// Simple related posts logic: same category or just next ones
const relatedPosts = allSlugs
  .filter(s => s !== slug)
  .map(s => {
    const m = getArticleMeta(s);
    const p = getArticleTranslation(s, currentLang);
    if (!m || !p) return null;
    return { ...m, ...p, displayTitle: getBlogDisplayTitle(p.title) };
  })
  .filter(p => p && p.category === post.category)
  .slice(0, 2);

// Generate share URLs
const currentUrl = `${siteUrl}/${currentLang}/blog/${slug}`;
const blogAlternateLanguageUrls = getArticleLanguageCodes(blogSlug).map((code) => ({
  code,
  hreflang: code,
  href: buildLocaleUrl(`/${currentLang}/blog/${blogSlug}`, code),
}));
const safeEncode = (str: string) => {
  try {
    return encodeURIComponent(str);
  } catch {
    return encodeURIComponent(String(str).replace(/[\uD800-\uDFFF]/g, ''));
  }
};
const shareText = safeEncode(displayTitle || '');
const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${shareText}&url=${safeEncode(currentUrl)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${safeEncode(currentUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${safeEncode(currentUrl)}`
};
const productKey = getSuggestedProductForArticle(blogSlug);
const suggestedProduct = getProductCopy(productKey, currentLang, t);
const landingPath = getProductLandingPath(currentLang, productKey);
const renderedContent = rewriteBlogOfferLinks(post.content, currentLang, blogSlug);
const noIndex = isStaleMonthlyHoroscopeSlug(blogSlug);
const contentParts = renderedContent.split('</p>');
const injectionPoint = Math.min(3, Math.floor(contentParts.length / 2));
const firstHalf = contentParts.slice(0, injectionPoint).join('</p>') + (contentParts.length > injectionPoint ? '</p>' : '');
const secondHalf = contentParts.slice(injectionPoint).join('</p>');
const pageSchema = [
  buildArticleSchema({
    lang: currentLang,
    url: currentUrl,
    translation: localizedPost,
    meta,
  }),
  buildBreadcrumbSchema([
    { name: ui.home, url: `${siteUrl}/${currentLang}` },
    { name: ui.blogTitle, url: `${siteUrl}/${currentLang}/blog` },
    { name: displayTitle, url: currentUrl },
  ]),
];
---

<Layout 
  title={`${seoTitle} | Astralo`}
  description={post.metaDescription}
  keywords={post.keywords}
  lang={currentLang}
  alternateLanguageUrls={blogAlternateLanguageUrls}
  schema={pageSchema}
  ogType="article"
  publishedTime={meta.date}
  modifiedTime={meta.date}
  floatingProductKey={productKey}
  noIndex={noIndex}
>
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 w-0 h-1 bg-gradient-to-r from-amber-400 to-amber-600 z-[100] transition-all duration-150"></div>

  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-4xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={`/${currentLang}/blog`} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">{ui.backToBlog}</span>
          </a>
          <a href={`/${currentLang}`}><img src="/logo.webp" alt="Astralo" class="h-9" style="aspect-ratio: 3.41;" fetchpriority="high" /></a>
          <div class="w-24"></div>
        </div>
      </div>
    </header>

    <!-- Article -->
    <main class="flex-1 px-4 py-12">
      <!-- Added glass-strong background panel for readability -->
      <article class="max-w-4xl mx-auto glass-strong p-6 md:p-12 rounded-3xl border border-white/10 bg-slate-900/60 backdrop-blur-xl shadow-2xl">
        <!-- Meta -->
        <div class="flex flex-wrap items-center gap-4 mb-8 text-sm">
          <span class="px-3 py-1 bg-amber-500/20 text-amber-400 rounded-full font-medium tracking-wide">{post.category}</span>
          <span class="text-white/50 flex items-center gap-2">
            <Calendar class="w-4 h-4" />
            {new Date(post.date).toLocaleDateString(currentLang, { month: 'long', day: 'numeric', year: 'numeric' })}
          </span>
          <span class="text-white/50 flex items-center gap-2">
            <Clock class="w-4 h-4" />
            {post.readTime} {ui.minRead}
          </span>
        </div>

        <!-- Title with Emoji -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-8 leading-tight tracking-tight">
          <span class="mr-3 inline-block transform hover:scale-110 transition-transform duration-300">{post.emoji}</span>{displayTitle}
        </h1>

        <!-- Author & Share -->
        <div class="flex items-center justify-between mb-10 pb-10 border-b border-white/10">
          <div class="flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center shadow-lg hover:scale-105 transition-transform">
              <Star class="w-6 h-6 text-white" />
            </div>
            <div>
              <p class="text-white font-bold text-lg">{post.author}</p>
            </div>
          </div>
          
          <!-- Social Share Buttons -->
          <div class="flex items-center gap-3">
            <span class="text-white/50 text-sm hidden sm:inline font-medium">{ui.share}:</span>
            <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" 
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title={ui.share} aria-label={`${ui.share} Twitter`}>
              <Twitter class="w-5 h-5" />
            </a>
            <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer"
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title={ui.share} aria-label={`${ui.share} Facebook`}>
              <Facebook class="w-5 h-5" />
            </a>
            <a href={shareUrls.linkedin} target="_blank" rel="noopener noreferrer"
               class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
               title={ui.share} aria-label={`${ui.share} LinkedIn`}>
              <Linkedin class="w-5 h-5" />
            </a>
            <button id="copy-link" 
                    class="w-10 h-10 rounded-full glass flex items-center justify-center text-white/70 hover:text-amber-400 hover:bg-white/10 transition-all hover:scale-110"
                    title={ui.share} aria-label={ui.share}>
              <Link2 class="w-5 h-5" />
            </button>
          </div>
        </div>

        <!-- Quick Summary Box -->
        {post.quickSummary && (
        <div class="glass-strong rounded-2xl p-8 mb-12 border border-amber-500/20 bg-amber-500/5">
          <div class="flex items-center gap-3 mb-6">
            <BookOpen class="w-6 h-6 text-amber-400" />
            <h3 class="text-xl font-bold text-white">{ui.quickSummary}</h3>
          </div>
          <ul class="space-y-4">
            {post.quickSummary.map((point: string) => (
              <li class="flex items-start gap-3 text-white/90 leading-relaxed text-lg">
                <span class="text-amber-400 mt-1.5 font-bold">✓</span>
                <span>{point}</span>
              </li>
            ))}
          </ul>
        </div>
        )}

        <!-- Content -->
        <div 
          class="article-content prose prose-xl prose-invert max-w-none
            prose-headings:text-white prose-headings:font-bold prose-headings:scroll-mt-32
            prose-h2:text-3xl prose-h2:mt-16 prose-h2:mb-8 prose-h2:pb-4 prose-h2:border-b prose-h2:border-white/10
            prose-h3:text-2xl prose-h3:mt-12 prose-h3:mb-6 prose-h3:text-amber-200
            prose-p:text-gray-100 prose-p:leading-8 prose-p:mb-10 prose-p:text-lg
            prose-strong:text-amber-300 prose-strong:font-bold
            prose-ul:text-gray-100 prose-li:mb-4 prose-ul:my-8 prose-li:leading-relaxed
            prose-ol:text-gray-100 prose-ol:my-8 prose-ol:list-decimal prose-ol:pl-6
            prose-a:text-amber-400 prose-a:no-underline hover:prose-a:text-amber-300 transition-colors
            prose-blockquote:border-l-4 prose-blockquote:border-amber-500 prose-blockquote:bg-white/5 prose-blockquote:p-6 prose-blockquote:rounded-r-lg prose-blockquote:italic"
        >
          <div set:html={firstHalf} />

          <div class="my-12 glass-strong rounded-3xl p-8 sm:p-10 border border-amber-500/30 bg-gradient-to-br from-amber-500/10 via-slate-900/40 to-transparent shadow-2xl relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-amber-500/10 blur-[80px] rounded-full"></div>
            <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-sky-500/10 blur-[80px] rounded-full"></div>

            <div class="relative z-10 text-center md:text-left md:flex md:items-center md:justify-between md:gap-8">
              <div class="md:flex-1">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-amber-500/20 text-amber-400 text-xs font-bold uppercase tracking-wider mb-4">
                  {t.header.badge}
                </div>
                <h3 class="text-3xl sm:text-4xl font-black text-white mb-3 tracking-tight">{ui.getPersonalized}</h3>
                <p class="text-white/70 text-lg leading-relaxed">{suggestedProduct.description}</p>
              </div>

              <a
                href={buildInternalCampaignUrl(landingPath, {
                  source: 'blog',
                  campaign: blogSlug,
                  content: 'mid_article_cta',
                })}
                class="mt-6 md:mt-0 inline-flex items-center justify-center gap-3 px-8 py-4 bg-amber-500 text-black font-bold text-lg rounded-2xl hover:bg-amber-400 transition-all hover:scale-105 shadow-xl hover:shadow-amber-500/20 whitespace-nowrap"
                data-astralo-track-click="blog_product_click"
                data-blog-slug={blogSlug}
                data-click-surface="mid_article_cta"
                data-product-key={productKey}
                data-language={currentLang}
              >
                <Star class="w-5 h-5" />
                {t.cta.orderNow}
              </a>
            </div>
          </div>

          <div set:html={secondHalf} />
        </div>

        <!-- Related Posts -->
        {relatedPosts.length > 0 && (
          <div class="mt-20 border-t border-white/10 pt-16">
            <h3 class="text-2xl font-bold text-white mb-8">{ui.relatedArticles}</h3>
            <div class="grid md:grid-cols-2 gap-8">
              {relatedPosts.map((p: any) => (
                <a href={`/${currentLang}/blog/${p.slug}`} class="glass rounded-2xl p-8 block hover:border-amber-500/30 border border-white/10 transition-all group hover:-translate-y-1">
                  <span class="text-3xl mb-4 inline-block">{p.emoji}</span>
                  <span class="text-amber-400 text-sm font-medium block mb-2 tracking-wide uppercase">{p.category}</span>
                  <h4 class="text-xl text-white font-bold group-hover:text-amber-200 transition-colors">{p.displayTitle}</h4>
                </a>
              ))}
            </div>
          </div>
        )}
      </article>
    </main>
    <Footer lang={currentLang} />
  </div>
</Layout>

<style is:global>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }
  
  /* Reading progress bar animation */
  #reading-progress {
    transform-origin: left;
  }

  /* Force Spacing for Blog Content - overriding any potential prose conflicts */
  .article-content > p {
    margin-bottom: 2.5rem !important; /* Huge space between paragraphs */
    display: block !important;
  }
  
  .article-content > h2 {
    margin-top: 3.5rem !important;
    margin-bottom: 1.5rem !important;
  }
  
  .article-content > h3 {
    margin-top: 2.5rem !important;
    margin-bottom: 1rem !important;
  }
  
  .article-content ul, .article-content ol {
    margin-bottom: 2.5rem !important;
  }
</style>

<script>
  // Reading Progress Bar
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.getElementById('reading-progress');
    
    const updateProgress = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = (scrollTop / docHeight) * 100;
      if (progressBar) {
        progressBar.style.width = `${Math.min(progress, 100)}%`;
      }
    };
    
    window.addEventListener('scroll', updateProgress);
    updateProgress(); // Initial call
  });
  
  // Copy Link Button
  document.getElementById('copy-link')?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      const btn = document.getElementById('copy-link');
      if (btn) {
        btn.classList.add('!text-green-400');
        setTimeout(() => {
          btn.classList.remove('!text-green-400');
        }, 2000);
      }
    } catch (err) {
      console.error('Failed to copy link:', err);
    }
  });

  document.querySelectorAll('[data-astralo-track-click]').forEach((element) => {
    element.addEventListener('click', () => {
      const track = window['astraloTrack'];
      if (typeof track !== 'function') return;

      const target = element;
      track(target.dataset.astraloTrackClick || 'internal_click', {
        blog_slug: target.dataset.blogSlug || '',
        click_surface: target.dataset.clickSurface || '',
        item_id: target.dataset.productKey || '',
        language: target.dataset.language || '',
        link_url: target.getAttribute('href') || '',
      });
    });
  });
</script>
