// Generate all paths: lang × slug combinations
export function getStaticPaths() {
  // Hardcode locales to avoid import issues during static generation
  const locales = ['sk', 'cs', 'de', 'fr', 'es', 'it', 'pt', 'nl', 'pl', 'hu', 'ro', 'bg', 'hr', 'sl', 'sr', 'uk', 'ru', 'el', 'tr', 'ar', 'hi', 'bn', 'th', 'vi', 'id', 'ja', 'ko', 'zh', 'sv', 'da', 'no', 'fi', 'he'];
  const slugs = Object.keys(blogPosts);
  
  const paths = [];
  for (const lang of locales) {
    for (const slug of slugs) {
      paths.push({ params: { lang, slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;
const t = getTranslations(currentLang);
const ui = getUiTranslations(currentLang);
const post = blogPosts[slug as string];

// This should never happen since getStaticPaths only generates valid paths
// But just in case, provide a fallback
if (!post) {
  throw new Error(`Blog post not found: ${slug}`);
}

// Related posts (exclude current)
const relatedPosts = Object.entries(blogPosts)
  .filter(([s, p]) => s !== slug && p.category === post.category)
  .slice(0, 2);

// Generate share URLs
const currentUrl = `https://astralo.online/${currentLang}/blog/${slug}`;
const shareText = encodeURIComponent(post.displayTitle);
const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(currentUrl)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(currentUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`
};
