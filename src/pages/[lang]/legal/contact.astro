---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { ArrowLeft, Mail, User, MessageSquare, Send } from 'lucide-astro';
import { getSupportedLocales, isValidLocale, type SupportedLocale } from '../../../lib/i18n';
import { getContactTranslations } from '../../../locales/contact';

export const prerender = true;

export function getStaticPaths() {
  // Exclude 'en' - English legal pages are served at /legal/ without language prefix
  const locales = getSupportedLocales().filter(lang => lang !== 'en');
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;

// Get translations for current language, fallback to English
const text = getContactTranslations(currentLang);
---

<Layout title={`${text.title} - Astralo`} lang={currentLang}>
  <!-- hCaptcha Script - must load before captcha widget -->
  <script is:inline src="https://js.hcaptcha.com/1/api.js" async defer></script>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">{text.back}</span>
          </a>
          <a href={`/${currentLang}/`} class="block hover:opacity-80 transition-opacity">
            <img src="/logo.png" alt="Astralo" class="h-10" />
          </a>
          <LanguageSwitcher lang={currentLang} />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-12 sm:py-16">
      <div class="max-w-xl mx-auto">
        
        <!-- Title -->
        <div class="text-center mb-10 animate-fade-in-up">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br from-amber-400/20 to-purple-500/20 border border-white/10 mb-4">
            <MessageSquare class="w-8 h-8 text-amber-400" />
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-white mb-3">{text.title}</h1>
          <p class="text-white/70 text-lg max-w-md mx-auto">
            {text.subtitle}
          </p>
        </div>

        <!-- Contact Form -->
        <div class="glass-strong rounded-2xl p-6 sm:p-8 animate-fade-in-up" style="animation-delay: 0.1s;">
          <form id="contact-form" class="space-y-5">
            <div>
              <label for="name" class="flex items-center gap-2 text-white/90 text-base font-medium mb-2">
                <User class="w-5 h-5 text-amber-400" />
                {text.name}
              </label>
              <input 
                id="name" 
                name="name" 
                type="text" 
                placeholder={text.namePlaceholder}
                required
                class="input w-full text-lg p-4"
              />
            </div>

            <div>
              <label for="email" class="flex items-center gap-2 text-white/90 text-base font-medium mb-2">
                <Mail class="w-5 h-5 text-amber-400" />
                {text.email}
              </label>
              <input 
                id="email" 
                name="email" 
                type="email" 
                placeholder={text.emailPlaceholder}
                required
                class="input w-full text-lg p-4"
              />
            </div>

            <div>
              <label for="subject" class="flex items-center gap-2 text-white/90 text-base font-medium mb-2">
                <MessageSquare class="w-5 h-5 text-amber-400" />
                {text.subject}
              </label>
              <select 
                id="subject" 
                name="subject" 
                required
                class="input w-full text-lg p-4"
              >
                <option value="">{text.subjectPlaceholder}</option>
                <option value="general">{text.general}</option>
                <option value="order">{text.order}</option>
                <option value="refund">{text.refund}</option>
                <option value="technical">{text.technical}</option>
                <option value="other">{text.other}</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-white/90 text-base font-medium mb-2">
                {text.message}
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows="5" 
                placeholder={text.messagePlaceholder}
                required
                class="input w-full text-lg p-4 resize-none"
              ></textarea>
            </div>

            <!-- hCaptcha -->
            <div class="pt-2 flex justify-center">
              <div class="h-captcha" data-sitekey="c012a504-016e-41f0-82b6-746020a22604" data-theme="dark"></div>
            </div>

            <!-- Submit Button -->
            <div class="pt-4">
              <button type="submit" id="submit-btn" class="group relative w-full bg-gradient-to-r from-amber-400 via-amber-500 to-amber-600 hover:from-amber-500 hover:via-amber-600 hover:to-amber-700 text-black font-bold px-8 py-4 rounded-xl shadow-lg shadow-amber-500/30 transition-all duration-300 hover:scale-[1.02]">
                <span class="flex items-center justify-center gap-2">
                  <Send class="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                  <span>{text.send}</span>
                </span>
              </button>
            </div>
          </form>

          <!-- Success Message (hidden by default) -->
          <div id="success-message" class="hidden text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-500/20 border border-green-500/30 mb-4">
              <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">{text.success}</h3>
            <p class="text-white/70">{text.successMessage}</p>
          </div>
        </div>

        <!-- Response time note -->
        <p class="text-center text-white/50 text-sm mt-6 animate-fade-in-up" style="animation-delay: 0.2s;">
          {text.responseTime}
        </p>

      </div>
    </main>

    <Footer lang={currentLang} />
  </div>
</Layout>

<script is:inline>
  const form = document.getElementById('contact-form');
  const successMessage = document.getElementById('success-message');
  
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    
    const btn = document.getElementById('submit-btn');
    const originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin w-5 h-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>';
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    // Get hCaptcha token
    const hcaptchaResponse = document.querySelector('[name="h-captcha-response"]')?.value;
    if (!hcaptchaResponse) {
      alert('Please complete the captcha verification.');
      btn.disabled = false;
      btn.innerHTML = originalHTML;
      return;
    }
    data['h-captcha-response'] = hcaptchaResponse;
    
    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      
      if (!response.ok) throw new Error('Failed to send message');
      
      // Show success message
      form.classList.add('hidden');
      successMessage.classList.remove('hidden');
      
    } catch (error) {
      console.error('Contact form error:', error);
      alert('Failed to send message. Please try again or email us directly.');
      btn.disabled = false;
      btn.innerHTML = originalHTML;
    }
  });
</script>
