---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { ArrowLeft, RotateCcw } from 'lucide-astro';
import { getSupportedLocales, isValidLocale, type SupportedLocale } from '../../../lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  // Exclude 'en' - English legal pages are served at /legal/ without language prefix
  const locales = getSupportedLocales().filter(lang => lang !== 'en');
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;

const backText: Record<string, string> = {
  en: 'Back', sk: 'Späť', cs: 'Zpět', de: 'Zurück', fr: 'Retour', es: 'Volver',
  it: 'Indietro', pt: 'Voltar', nl: 'Terug', pl: 'Wróć', ru: 'Назад', ja: '戻る',
  zh: '返回', ko: '뒤로', sr: 'Nazad', hu: 'Vissza', ro: 'Înapoi', bg: 'Назад',
  uk: 'Назад', tr: 'Geri', ar: 'رجوع', hi: 'वापस', th: 'กลับ', vi: 'Quay lại',
  da: 'Tilbage', fi: 'Takaisin', no: 'Tilbake', sv: 'Tillbaka', el: 'Πίσω',
  hr: 'Natrag', sl: 'Nazaj', id: 'Kembali', bn: 'ফিরে যান', he: 'חזרה'
};
---

<Layout title="Refund Policy - Astralo" lang={currentLang} description="Astralo refund policy for digital horoscope products. Learn about refund eligibility and EU consumer protection rights.">
  <div class="min-h-screen flex flex-col relative z-10">
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={`/${currentLang}/`} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">{backText[currentLang] || 'Back'}</span>
          </a>
          <a href={`/${currentLang}/`}><img src="/logo.webp" alt="Astralo" class="h-9" style="aspect-ratio: 3.41;" /></a>
          <LanguageSwitcher lang={currentLang} />
        </div>
      </div>
    </header>

    <main class="flex-1 px-4 py-8 sm:py-12">
      <div class="max-w-4xl mx-auto" dir="ltr">
        <div class="glass-strong rounded-2xl p-6 sm:p-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-green-500/20 flex items-center justify-center">
              <RotateCcw class="w-6 h-6 text-green-400" />
            </div>
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-white">Refund Policy</h1>
              <p class="text-white/50 text-sm">Version 1.0 • Last updated: December 5, 2026</p>
            </div>
          </div>
          
          <div class="prose prose-invert max-w-none space-y-6 text-white/80 text-sm sm:text-base">
            
            <div class="bg-green-500/10 border border-green-500/20 rounded-xl p-4 mb-6">
              <p class="text-green-200 text-sm">
                <strong>EU Consumer Rights:</strong> This policy complies with EU consumer protection laws including the Consumer Rights Directive.
              </p>
            </div>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">1. Digital Products</h2>
              <p>
                Due to the digital and personalized nature of our horoscope products, refunds are handled on a case-by-case basis.
                Once a horoscope has been generated and delivered to your email, the service has been fully provided.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">2. When We Offer Refunds</h2>
              <p>We may offer a full refund if:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li>There was a <strong>technical error</strong> preventing delivery of your horoscope</li>
                <li>You did not receive your horoscope within 24 hours</li>
                <li>The horoscope was generated with clearly incorrect data due to a system error</li>
                <li>You request a refund before the horoscope has been generated</li>
              </ul>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">3. EU Right of Withdrawal</h2>
              <p>
                Under EU Consumer Rights Directive, you normally have 14 days to withdraw from online purchases.
                However, for digital content (like horoscopes), this right may be waived when:
              </p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li>You give explicit consent for immediate delivery</li>
                <li>You acknowledge the loss of withdrawal right upon delivery</li>
              </ul>
              <p class="mt-3">
                By completing your purchase, you consent to immediate delivery and acknowledge that your right of withdrawal 
                is forfeit once the horoscope is delivered.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">4. How to Request a Refund</h2>
              <p>To request a refund, please:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li>Email us at <strong>apollotechsro@gmail.com</strong></li>
                <li>Include your order confirmation email or order ID</li>
                <li>Explain the reason for your refund request</li>
              </ul>
              <p class="mt-3">
                We will review your request within <strong>48 hours</strong> and respond with our decision.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">5. Refund Processing</h2>
              <p>
                Approved refunds will be processed to your original payment method within 5-10 business days.
                The exact timing depends on your bank or card issuer.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">6. Contact</h2>
              <p>
                For refund requests or questions:<br />
                <strong>Email:</strong> apollotechsro@gmail.com<br />
                <strong>Company:</strong> Apollo Tech s.r.o., Slovakia
              </p>
            </section>

          </div>
        </div>
      </div>
    </main>

    <Footer lang={currentLang} />
  </div>
</Layout>
