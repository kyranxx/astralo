---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import LanguageSwitcher from '../../../components/LanguageSwitcher.astro';
import { ArrowLeft, Cookie } from 'lucide-astro';
import { getSupportedLocales, isValidLocale, type SupportedLocale } from '../../../lib/i18n';

export const prerender = true;

export function getStaticPaths() {
  // Exclude 'en' - English legal pages are served at /legal/ without language prefix
  const locales = getSupportedLocales().filter(lang => lang !== 'en');
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;

const backText: Record<string, string> = {
  en: 'Back', sk: 'Späť', cs: 'Zpět', de: 'Zurück', fr: 'Retour', es: 'Volver',
  it: 'Indietro', pt: 'Voltar', nl: 'Terug', pl: 'Wróć', ru: 'Назад', ja: '戻る',
  zh: '返回', ko: '뒤로', sr: 'Nazad', hu: 'Vissza', ro: 'Înapoi', bg: 'Назад',
  uk: 'Назад', tr: 'Geri', ar: 'رجوع', hi: 'वापस', th: 'กลับ', vi: 'Quay lại',
  da: 'Tilbage', fi: 'Takaisin', no: 'Tilbake', sv: 'Tillbaka', el: 'Πίσω',
  hr: 'Natrag', sl: 'Nazaj', id: 'Kembali', bn: 'ফিরে যান', he: 'חזרה'
};
---

<Layout title="Cookie Policy - Astralo" lang={currentLang} description="Cookie policy for Astralo. Learn about the cookies we use, including essential and analytics cookies, and how to manage them." noIndex={true}>
  <div class="min-h-screen flex flex-col relative z-10">
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={`/${currentLang}`} class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">{backText[currentLang] || 'Back'}</span>
          </a>
          <a href={`/${currentLang}`}><img src="/logo.webp" alt="Astralo" class="h-9" style="aspect-ratio: 3.41;" /></a>
          <LanguageSwitcher lang={currentLang} />
        </div>
      </div>
    </header>

    <main class="flex-1 px-4 py-8 sm:py-12">
      <div class="max-w-4xl mx-auto" dir="ltr">
        <div class="glass-strong rounded-2xl p-6 sm:p-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-orange-500/20 flex items-center justify-center">
              <Cookie class="w-6 h-6 text-orange-400" />
            </div>
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-white">Cookie Policy</h1>
              <p class="text-white/50 text-sm">Version 1.0 • Last updated: May 27, 2026</p>
            </div>
          </div>
          
          <div class="prose prose-invert max-w-none space-y-6 text-white/80 text-sm sm:text-base">

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">1. What Are Cookies?</h2>
              <p>
                Cookies are small text files stored on your device when you visit websites. 
                They help websites remember your preferences and improve your experience.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">2. Cookies We Use</h2>
              
              <h3 class="text-lg font-semibold text-white mt-4 mb-2">Essential Cookies</h3>
              <p>These are necessary for the website to function:</p>
              <ul class="list-disc pl-6 space-y-1 mt-2">
                <li>Session management</li>
                <li>Security features</li>
                <li>Language preferences</li>
              </ul>

              <h3 class="text-lg font-semibold text-white mt-4 mb-2">Analytics Cookies</h3>
              <p>We use Microsoft Clarity to understand how visitors use our site:</p>
              <ul class="list-disc pl-6 space-y-1 mt-2">
                <li>Page views and navigation</li>
                <li>Time spent on pages</li>
                <li>Click patterns (no personal data collected)</li>
              </ul>

              <h3 class="text-lg font-semibold text-white mt-4 mb-2">Payment Cookies</h3>
              <p>Stripe uses cookies to process payments securely.</p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">3. Managing Cookies</h2>
              <p>
                You can control cookies through your browser settings. 
                Most browsers allow you to:
              </p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li>View what cookies are stored</li>
                <li>Delete some or all cookies</li>
                <li>Block cookies from specific sites</li>
                <li>Block all cookies (may affect functionality)</li>
              </ul>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">4. Third-Party Cookies</h2>
              <p>Some cookies are set by third-party services:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li><strong>Stripe</strong> - Payment processing</li>
                <li><strong>Microsoft Clarity</strong> - Analytics</li>
              </ul>
              <p class="mt-2">
                These services have their own privacy policies that govern their use of cookies.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">5. Contact</h2>
              <p>
                For questions about our cookie policy:<br />
                <strong>Email:</strong> apollotechsro@gmail.com
              </p>
            </section>

          </div>
        </div>
      </div>
    </main>

    <Footer lang={currentLang} />
  </div>
</Layout>
