---
import ZodiacProductLandingPage from '../../../../components/ZodiacProductLandingPage.astro';
import { getSupportedLocales, isValidLocale, type SupportedLocale } from '../../../../lib/i18n';
import { isValidProductKey } from '../../../../lib/products';
import { isValidZodiacSign, zodiacSignSlugs } from '../../../../lib/zodiac';

export const prerender = true;

export function getStaticPaths() {
    return getSupportedLocales()
        .filter((lang) => lang !== 'en')
        .flatMap((lang) =>
            ['daily', 'weekly', 'monthly', 'partner'].flatMap((type) =>
                zodiacSignSlugs.map((sign) => ({
                    params: { lang, type, sign },
                })),
            ),
        );
}

const { lang, type, sign } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;

if (!type || !isValidProductKey(type) || !sign || !isValidZodiacSign(sign)) {
    return Astro.redirect(`/${currentLang}/`);
}
---

<ZodiacProductLandingPage lang={currentLang} type={type} sign={sign} />
