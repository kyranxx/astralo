---
import FreeHoroscopeLeadPage from '../../components/FreeHoroscopeLeadPage.astro';
import { getSupportedLocales, isValidLocale, type SupportedLocale } from '../../lib/i18n';

export const prerender = true;

export function getStaticPaths() {
    return getSupportedLocales()
        .filter((lang) => lang !== 'en')
        .map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;

if (currentLang === 'en') {
    return Astro.redirect('/free-horoscope', 301);
}
---

<FreeHoroscopeLeadPage lang={currentLang} />
