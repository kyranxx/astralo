---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import FAQ from '../../components/FAQ.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { Sparkles, Star, Heart, Calendar, TrendingUp, Zap, Clock, Sun, Moon, BookOpen, ArrowRight } from 'lucide-astro';
import { getSupportedLocales, isValidLocale, getTranslations, type SupportedLocale } from '../../lib/i18n';
import { getTestimonials } from '../../lib/testimonials';
import { getLatestArticleSlugs, getArticleTranslation, getArticleMeta, getBlogUiTranslations } from '../../lib/blog';
import { getProductPriceInEuros, getProductOriginalPriceInEuros, type ProductKey } from '../../lib/products';
import { buildFaqSchema, buildOfferCatalogSchema, buildWebPageSchema, getGeneralFaqEntries, getProductLandingPath, siteUrl } from '../../lib/seo';

export const prerender = true;

export function getStaticPaths() {
  // Exclude 'en' - English is served at root (/) without language prefix
  const locales = getSupportedLocales().filter(lang => lang !== 'en');
  return locales.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;
const currentLang = (isValidLocale(lang) ? lang : 'en') as SupportedLocale;
const t = getTranslations(currentLang);
const blogUi = getBlogUiTranslations(currentLang);
const pageSchema = [
  buildWebPageSchema({
    url: `${siteUrl}/${currentLang}`,
    title: t.meta.title,
    description: t.meta.description,
    lang: currentLang,
  }),
  buildOfferCatalogSchema(currentLang, t),
  buildFaqSchema(getGeneralFaqEntries(t)),
];

// Get latest blog articles for internal linking (SEO: prevents orphan pages)
const latestArticles = getLatestArticleSlugs(3).map(slug => {
  const translation = getArticleTranslation(slug, currentLang);
  const meta = getArticleMeta(slug);
  return { slug, translation, meta };
}).filter(a => a.translation && a.meta);

const horoscopeTypes = ([
  {
    id: "daily",
    icon: "Sun",
  },
  {
    id: "weekly",
    icon: "Calendar",
    popular: true,
  },
  {
    id: "monthly",
    icon: "Moon",
  },
  {
    id: "partner",
    icon: "Heart",
  },
] as const).map(type => ({
  ...type,
  name: t.products[type.id].name,
  description: t.products[type.id].description,
  price: getProductPriceInEuros(type.id as ProductKey),
  originalPrice: getProductOriginalPriceInEuros(type.id as ProductKey),
  wordCount: t.products[type.id].wordCount,
  benefits: t.products[type.id].benefits,
  landingPath: getProductLandingPath(currentLang, type.id as ProductKey)
}));

const iconMap = {
  Calendar,
  Star,
  Sparkles,
  Heart,
  Clock,
  TrendingUp,
  Zap,
  Sun,
  Moon,
};

// Get localized testimonials for current language
const testimonials = getTestimonials(currentLang);
---

<Layout 
  title={t.meta.title}
  lang={currentLang}
  schema={pageSchema}
>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Top Promo Banner -->
    <div class="bg-gradient-to-r from-amber-500 via-amber-400 to-amber-500 py-2 px-4 text-center">
      <div class="flex items-center justify-center gap-3 sm:gap-6 text-black/90 text-sm font-medium">
        <span class="flex items-center gap-2">
          <span class="animate-pulse">🔥</span>
          <span class="font-bold">50% OFF</span>
        </span>
        <span class="hidden sm:flex items-center gap-2">
          <span>⚡</span>
          <span>{t.promo.delivery}</span>
        </span>
        <span class="hidden md:flex items-center gap-2">
          <span>⭐</span>
          <span>{t.promo.customers}</span>
        </span>
        <span class="hidden lg:flex items-center gap-2 border-l border-black/20 pl-4">
          <span>🔒</span>
          <span>{t.promo.secure}</span>
          <img src="/stripe-logo.webp" alt="Stripe" class="h-5 ml-1" width="50" height="20" loading="eager" />
        </span>
      </div>
    </div>

    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href={`/${currentLang}/`} class="flex items-center">
            <img src="/logo.webp" alt="Astralo" width="756" height="222" class="h-9 sm:h-11 w-auto" fetchpriority="high" />
          </a>
          
          <div class="hidden lg:flex items-center gap-3">
            <div class="flex items-center gap-2 px-4 py-1.5 rounded-full bg-amber-500/10 border border-amber-400/20">
              <Sparkles class="w-4 h-4 text-amber-400" />
              <span class="text-white/80 text-sm">{t.header.badge}</span>
            </div>
          </div>
          
          <LanguageSwitcher lang={currentLang} />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-8 sm:py-12">
      <div class="max-w-7xl mx-auto">
        <!-- Hero Section -->
        <div class="text-center mb-10 sm:mb-12">
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4">
            {t.hero.title}
          </h1>
          <div class="animate-fade-in-up">
            <p class="text-xl sm:text-xl text-white/80 max-w-3xl mx-auto mb-4">
              {t.hero.subtitle}
            </p>
            <p class="text-white/60 text-base">
              {t.hero.features}
            </p>
          </div>
        </div>

        <!-- Horoscope Cards -->
        <div id="horoscopes" class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-12 sm:mb-16 max-w-5xl mx-auto">
          {horoscopeTypes.map((type, index) => {
            const Icon = iconMap[type.icon as keyof typeof iconMap];
            return (
              <a
                href={type.landingPath}
                class={`horoscope-card group block relative glass-strong rounded-2xl sm:rounded-3xl p-4 sm:p-6 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-amber-500/10 no-underline border border-white/10 hover:border-amber-400/30 overflow-hidden animate-on-load animate-delay-${index + 1}`}
              >
                {type.popular && (
                  <div class="absolute -top-1 -right-1 bg-gradient-to-br from-amber-400 to-amber-600 text-black text-[9px] sm:text-[10px] font-black px-2 sm:px-4 py-1 sm:py-1.5 rounded-bl-xl sm:rounded-bl-2xl shadow-lg z-20 uppercase tracking-tighter">
                    {t.cta.popular}
                  </div>
                )}
                
                <div class="flex flex-col h-full relative z-10">
                  {/* Icon & Title Area - Fixed height for alignment across cards */}
                  <div class="text-center mb-3 sm:mb-5 min-h-[6.5rem] sm:min-h-[8rem] flex flex-col justify-end">
                    <div class="relative w-12 h-12 sm:w-16 sm:h-16 mx-auto mb-2 sm:mb-4">
                      <div class="absolute inset-0 bg-amber-400/20 blur-xl rounded-full group-hover:bg-amber-400/30 transition-colors duration-500"></div>
                      <div class="relative flex items-center justify-center w-full h-full rounded-xl sm:rounded-2xl bg-gradient-to-br from-white/10 to-white/5 border border-white/10 group-hover:border-amber-400/50 transition-all duration-500">
                        <Icon class="w-6 h-6 sm:w-8 sm:h-8 text-amber-400 group-hover:scale-110 transition-transform duration-500" />
                      </div>
                    </div>
                    <h2 class="text-sm sm:text-2xl font-black text-white mb-0.5 sm:mb-1 group-hover:text-amber-400 transition-colors duration-300 leading-tight min-h-[3rem] sm:min-h-[4rem] flex items-center justify-center text-center px-0.5 break-words hyphens-auto">
                      {type.name}
                    </h2>
                    <p class="text-white/60 text-[10px] sm:text-[10px] font-medium uppercase tracking-widest">{type.wordCount}</p>
                  </div>

                  {/* Pricing Section */}
                  <div class="flex flex-col items-center mb-3 sm:mb-6 py-2 sm:py-4 border-y border-white/5 bg-white/[0.02] rounded-xl sm:rounded-2xl">
                    <div class="flex items-center gap-2 sm:gap-3">
                      <span class="text-2xl sm:text-3xl font-black text-white tracking-tighter">{type.price.toFixed(2)}€</span>
                      <div class="flex flex-col items-start leading-none">
                        <span class="text-xs sm:text-xs text-white/60 line-through">{type.originalPrice.toFixed(2)}€</span>
                        <span class="text-[10px] sm:text-[10px] font-bold text-amber-500 uppercase">-50%</span>
                      </div>
                    </div>
                  </div>

                  {/* Benefits List - Hidden on mobile for compact view, show on sm+ */}
                  <div class="hidden sm:block space-y-2 mb-6 min-h-[5.5rem]">
                    {type.benefits.slice(0, 4).map((benefit) => (
                      <div class="flex items-center gap-2 text-white/70 group-hover:text-white/90 transition-colors">
                        <span class="text-base flex-shrink-0">{benefit.split(' ')[0]}</span>
                        <span class="text-sm font-medium truncate">
                          {benefit.split(' ').slice(1).join(' ')}
                        </span>
                      </div>
                    ))}
                  </div>

                  {/* Mobile: Show only 2 benefits with larger text */}
                  <div class="sm:hidden space-y-2 mb-3 text-sm min-h-[2.5rem]">
                    {type.benefits.slice(0, 2).map((benefit) => (
                      <div class="flex items-center gap-1.5 text-white/70">
                        <span class="flex-shrink-0">{benefit.split(' ')[0]}</span>
                        <span class="truncate">{benefit.split(' ').slice(1).join(' ')}</span>
                      </div>
                    ))}
                  </div>

                  {/* Premium Button */}
                  <div class="mt-auto">
                    <div class="relative w-full overflow-hidden rounded-lg sm:rounded-xl bg-gradient-to-br from-amber-400 to-amber-600 p-[1px] group-hover:shadow-[0_0_20px_rgba(251,191,36,0.3)] transition-all duration-500">
                      <div class="flex items-center justify-center gap-1.5 sm:gap-2 rounded-[7px] sm:rounded-[11px] bg-amber-500 px-3 sm:px-4 py-2.5 sm:py-3.5 font-black text-black text-xs sm:text-sm uppercase tracking-tight group-hover:bg-amber-400 transition-colors active:scale-95 duration-200">
                        <Sparkles class="w-3.5 h-3.5 sm:w-4 sm:h-4 animate-pulse" />
                        <span>{t.cta.orderNow}</span>
                      </div>
                    </div>
                  </div>
                </div>
              </a>
            );
          })}
        </div>

        <!-- PDF Sample Preview Section -->
        <div class="glass-strong rounded-3xl p-6 sm:p-10 mb-12 sm:mb-16 max-w-5xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <div class="order-2 lg:order-1">
              <div class="flex items-center gap-2 mb-4">
                <span class="text-2xl">📄</span>
                <h2 class="text-xl sm:text-2xl font-bold text-white">{t.pdfPreview?.title || "What You'll Receive"}</h2>
              </div>
              <ul class="space-y-2 text-white/80 mb-4">
                <li class="flex items-center gap-2">
                  <span class="text-amber-400">✨</span>
                  <span>{t.pdfPreview?.portrait || 'Personal astrological portrait'}</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-amber-400">🍀</span>
                  <span>{t.pdfPreview?.lucky || 'Lucky numbers & colors'}</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-amber-400">💫</span>
                  <span>{t.pdfPreview?.predictions || 'Love, career & health insights'}</span>
                </li>
                <li class="flex items-center gap-2">
                  <span class="text-amber-400">🔮</span>
                  <span>{t.pdfPreview?.advice || 'Actionable cosmic guidance'}</span>
                </li>
              </ul>
              <p class="text-white/50 text-xs flex items-center gap-2">
                <span>⚡</span>
                {t.pdfPreview?.footer || 'Instant email delivery • Professional PDF'}
              </p>
            </div>
            <div class="order-1 lg:order-2 flex justify-center">
              <div class="relative">
                <div class="absolute -inset-4 bg-gradient-to-r from-amber-400/20 to-purple-500/20 blur-2xl rounded-3xl"></div>
                <img 
                  src="/pdf-sample-preview.webp" 
                  alt="Sample Horoscope PDF Preview" 
                  class="relative w-full max-w-sm rounded-2xl shadow-2xl border border-white/10"
                  loading="lazy"
                  decoding="async"
                  width="574"
                  height="574"
                />
                <div class="absolute -bottom-3 -right-3 bg-amber-400 text-black text-xs font-bold px-3 py-1.5 rounded-full shadow-lg">
                  Premium PDF
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Trust Indicators -->
        <div class="glass-strong rounded-2xl p-6 sm:p-8 mb-12 sm:mb-16">
          <div class="grid grid-cols-3 gap-4 sm:gap-8 text-center">
            <div>
              <div class="text-2xl sm:text-4xl font-bold text-amber-400 mb-1 sm:mb-2">50,000+</div>
              <p class="text-white/70 text-xs sm:text-sm">{t.trust.customers}</p>
            </div>
            <div>
              <div class="flex items-center justify-center gap-0.5 sm:gap-1 mb-1 sm:mb-2">
                {[...Array(5)].map(() => (
                  <Star class="w-4 h-4 sm:w-6 sm:h-6 text-amber-400 fill-amber-400" />
                ))}
              </div>
              <p class="text-white/70 text-xs sm:text-sm">{t.trust.rating}</p>
            </div>
            <div>
              <div class="text-2xl sm:text-4xl font-bold text-amber-400 mb-1 sm:mb-2">24/7</div>
              <p class="text-white/70 text-xs sm:text-sm">{t.trust.delivery}</p>
            </div>
          </div>
        </div>

        <!-- Testimonials -->
        <div class="mb-12 sm:mb-16">
          <h2 class="text-2xl sm:text-4xl font-bold text-white text-center mb-6 sm:mb-10">
            {t.testimonials.title}
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
            {testimonials.map((testimonial, index) => (
              <div 
                class={`glass rounded-2xl p-5 sm:p-6 hover:bg-white/5 transition-all duration-300 animate-on-load animate-delay-${index + 1}`}
              >
                <div class="flex items-center gap-1 mb-3 sm:mb-4">
                  {[...Array(testimonial.rating)].map(() => (
                    <Star class="w-3 h-3 sm:w-4 sm:h-4 text-amber-400 fill-amber-400" />
                  ))}
                </div>
                <p class="text-white/90 text-sm mb-4 leading-relaxed italic">
                  "{testimonial.text}"
                </p>
                <div>
                  <p class="text-white font-semibold text-sm">{testimonial.name}</p>
                  <p class="text-white/60 text-xs">{testimonial.location}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Why Choose Us -->
        <div class="glass-strong rounded-2xl p-6 sm:p-10 mb-8 text-center">
          <h2 class="text-xl sm:text-3xl font-bold text-white mb-6">
            {t.whyUs.title}
          </h2>
          <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-8">
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-amber-400/20 to-amber-600/20 mb-3 sm:mb-4">
                <Sparkles class="w-6 h-6 sm:w-7 sm:h-7 text-amber-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">{t.whyUs.technology.title}</h3>
              <p class="text-white/60 text-xs sm:text-sm">{t.whyUs.technology.description}</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-green-400/20 to-green-600/20 mb-3 sm:mb-4">
                <Zap class="w-6 h-6 sm:w-7 sm:h-7 text-green-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">{t.whyUs.instant.title}</h3>
              <p class="text-white/60 text-xs sm:text-sm">{t.whyUs.instant.description}</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-blue-400/20 to-blue-600/20 mb-3 sm:mb-4">
                <Star class="w-6 h-6 sm:w-7 sm:h-7 text-blue-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">{t.whyUs.professional.title}</h3>
              <p class="text-white/60 text-xs sm:text-sm">{t.whyUs.professional.description}</p>
            </div>
            <div>
              <div class="inline-flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 rounded-xl bg-gradient-to-br from-purple-400/20 to-purple-600/20 mb-3 sm:mb-4">
                <TrendingUp class="w-6 h-6 sm:w-7 sm:h-7 text-purple-400" />
              </div>
              <h3 class="text-white font-semibold text-sm sm:text-base mb-1 sm:mb-2">{t.whyUs.verified.title}</h3>
              <p class="text-white/60 text-xs sm:text-sm">{t.whyUs.verified.description}</p>
            </div>
          </div>
        </div>

        <!-- Latest Articles Section (SEO: Internal Linking) -->
        <div class="mb-12 sm:mb-16">
          <div class="flex items-center justify-between mb-6 sm:mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold text-white flex items-center gap-3">
              <BookOpen class="w-6 h-6 sm:w-8 sm:h-8 text-amber-400" />
              {blogUi.latestArticles || 'Latest Articles'}
            </h2>
            <a href={`/${currentLang}/blog/`} class="flex items-center gap-1 text-amber-400 hover:text-amber-300 transition-colors text-sm sm:text-base font-medium">
              {blogUi.viewAll || 'View All'}
              <ArrowRight class="w-4 h-4" />
            </a>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
            {latestArticles.map((article, index) => (
              <a 
                href={`/${currentLang}/blog/${article.slug}/`}
                class={`glass rounded-2xl p-5 sm:p-6 hover:bg-white/5 transition-all duration-300 group border border-white/10 hover:border-amber-400/30 animate-on-load animate-delay-${index + 1}`}
              >
                <div class="flex items-start gap-3 mb-3">
                  <span class="text-2xl">{article.meta?.emoji}</span>
                  <div class="flex-1">
                    <span class="text-xs text-amber-400 font-medium uppercase tracking-wider">{article.translation?.category}</span>
                    <h3 class="text-white font-semibold text-base sm:text-lg group-hover:text-amber-400 transition-colors line-clamp-2">
                      {article.translation?.displayTitle}
                    </h3>
                  </div>
                </div>
                <p class="text-white/60 text-sm line-clamp-2 mb-3">
                  {article.translation?.excerpt}
                </p>
                <div class="flex items-center gap-2 text-xs text-white/50">
                  <Clock class="w-3 h-3" />
                  <span>{article.meta?.readTime} {blogUi.minRead || 'min read'}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </main>

    <!-- FAQ Section -->
    <FAQ lang={currentLang} />

    <Footer lang={currentLang} />
  </div>
</Layout>

<style>
  /* Animation classes are now defined in global.css for consistency */
  /* Fallback ensures visibility even if animation fails */
</style>
