---
import ZodiacProductLandingPage from '../../../components/ZodiacProductLandingPage.astro';
import { getZodiacProductKeys, isValidProductKey } from '../../../lib/products';
import { isValidZodiacSign, zodiacSignSlugs } from '../../../lib/zodiac';

export const prerender = true;

export function getStaticPaths() {
    return getZodiacProductKeys().flatMap((type) =>
        zodiacSignSlugs.map((sign) => ({
            params: { type, sign },
        })),
    );
}

const { type, sign } = Astro.params;

if (!type || !isValidProductKey(type) || !sign || !isValidZodiacSign(sign)) {
    return Astro.redirect('/');
}
---

<ZodiacProductLandingPage lang="en" type={type} sign={sign} />
