---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import LanguageSwitcher from '../../components/LanguageSwitcher.astro';
import { ArrowLeft, Cookie } from 'lucide-astro';

export const prerender = true;
---

<Layout 
  title="Cookie Policy - Astralo"
  lang="en"
>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10 sticky top-0 z-50">
      <div class="max-w-5xl mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <a href="/" class="inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors group">
            <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" />
            <span class="text-sm">Back</span>
          </a>
          <a href="/"><img src="/logo.webp" alt="Astralo" class="h-9" width="123" height="36" /></a>
          <LanguageSwitcher lang="en" />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 px-4 py-8 sm:py-12">
      <div class="max-w-4xl mx-auto">
        <div class="glass-strong rounded-2xl p-6 sm:p-10">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-12 h-12 rounded-xl bg-orange-500/20 flex items-center justify-center">
              <Cookie class="w-6 h-6 text-orange-400" />
            </div>
            <div>
              <h1 class="text-2xl sm:text-3xl font-bold text-white">Cookie Policy</h1>
              <p class="text-white/50 text-sm">Version 1.0 • Last updated: December 5, 2024</p>
            </div>
          </div>
          
          <div class="prose prose-invert max-w-none space-y-6 text-white/80 text-sm sm:text-base">
            
            <div class="bg-orange-500/10 border border-orange-500/20 rounded-xl p-4 mb-6">
              <p class="text-orange-200 text-sm">
                <strong>EU ePrivacy Directive:</strong> This policy complies with EU cookie regulations. 
                We use cookies only with your consent for non-essential features.
              </p>
            </div>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">1. What Are Cookies?</h2>
              <p>
                Cookies are small text files stored on your device when you visit a website. 
                They help websites remember your preferences and improve your experience.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">2. Cookies We Use</h2>
              
              <h3 class="text-lg font-semibold text-white mt-4 mb-2">Essential Cookies (Always Active)</h3>
              <p>These are necessary for the website to function:</p>
              <div class="overflow-x-auto mt-3">
                <table class="w-full text-sm border border-white/10 rounded-lg">
                  <thead class="bg-white/5">
                    <tr>
                      <th class="text-left p-3 text-white">Cookie</th>
                      <th class="text-left p-3 text-white">Purpose</th>
                      <th class="text-left p-3 text-white">Duration</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/10">
                    <tr>
                      <td class="p-3">cookieConsent</td>
                      <td class="p-3">Stores your cookie preference</td>
                      <td class="p-3">1 year</td>
                    </tr>
                    <tr>
                      <td class="p-3">session</td>
                      <td class="p-3">Maintains your session during checkout</td>
                      <td class="p-3">Session</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h3 class="text-lg font-semibold text-white mt-6 mb-2">Payment Cookies (Stripe)</h3>
              <p>Set by our payment processor Stripe to process payments securely:</p>
              <div class="overflow-x-auto mt-3">
                <table class="w-full text-sm border border-white/10 rounded-lg">
                  <thead class="bg-white/5">
                    <tr>
                      <th class="text-left p-3 text-white">Cookie</th>
                      <th class="text-left p-3 text-white">Purpose</th>
                      <th class="text-left p-3 text-white">Duration</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/10">
                    <tr>
                      <td class="p-3">__stripe_mid</td>
                      <td class="p-3">Fraud prevention</td>
                      <td class="p-3">1 year</td>
                    </tr>
                    <tr>
                      <td class="p-3">__stripe_sid</td>
                      <td class="p-3">Payment session</td>
                      <td class="p-3">30 min</td>
                    </tr>
                  </tbody>
                </table>
              </div>

              <h3 class="text-lg font-semibold text-white mt-6 mb-2">Analytics Cookies (Optional)</h3>
              <p>With your consent, we may use analytics cookies to understand how visitors use our site:</p>
              <div class="overflow-x-auto mt-3">
                <table class="w-full text-sm border border-white/10 rounded-lg">
                  <thead class="bg-white/5">
                    <tr>
                      <th class="text-left p-3 text-white">Cookie</th>
                      <th class="text-left p-3 text-white">Purpose</th>
                      <th class="text-left p-3 text-white">Duration</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-white/10">
                    <tr>
                      <td class="p-3">_ga</td>
                      <td class="p-3">Google Analytics - visitor distinction</td>
                      <td class="p-3">2 years</td>
                    </tr>
                    <tr>
                      <td class="p-3">_gid</td>
                      <td class="p-3">Google Analytics - session tracking</td>
                      <td class="p-3">24 hours</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">3. Your Cookie Choices</h2>
              <p>When you first visit our site, you'll see a cookie banner where you can:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li><strong>Accept</strong> all cookies (including analytics)</li>
                <li><strong>Decline</strong> optional cookies (only essential cookies will be used)</li>
              </ul>
              <p class="mt-3">
                You can change your preference at any time by clearing your browser cookies and revisiting the site.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">4. Managing Cookies in Your Browser</h2>
              <p>You can also control cookies through your browser settings:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li><strong>Chrome:</strong> Settings → Privacy and Security → Cookies</li>
                <li><strong>Firefox:</strong> Settings → Privacy & Security → Cookies</li>
                <li><strong>Safari:</strong> Preferences → Privacy → Manage Website Data</li>
                <li><strong>Edge:</strong> Settings → Privacy → Cookies</li>
              </ul>
              <p class="mt-3 text-white/60">
                Note: Blocking essential cookies may prevent the website from functioning properly.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">5. Third-Party Cookies</h2>
              <p>Some cookies are set by third-party services we use:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li><strong>Stripe</strong> - Payment processing (<a href="https://stripe.com/privacy" target="_blank" rel="noopener" class="text-amber-400 hover:underline">Stripe Privacy</a>)</li>
                <li><strong>Google Analytics</strong> - Website analytics (if consented) (<a href="https://policies.google.com/privacy" target="_blank" rel="noopener" class="text-amber-400 hover:underline">Google Privacy</a>)</li>
              </ul>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">6. Local Storage</h2>
              <p>We also use browser local storage to:</p>
              <ul class="list-disc pl-6 space-y-2 mt-2">
                <li>Remember your cookie consent preference</li>
                <li>Store admin session (admin dashboard only)</li>
              </ul>
              <p class="mt-2">
                Local storage data remains until you clear your browser data.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">7. Updates to This Policy</h2>
              <p>
                We may update this Cookie Policy from time to time. Changes will be posted on this page 
                with an updated "Last updated" date.
              </p>
            </section>

            <section>
              <h2 class="text-xl font-bold text-white mt-6 mb-3">8. Contact</h2>
              <p>
                For questions about cookies:<br />
                <strong>Email:</strong> apollotechsro@gmail.com<br />
                <strong>Company:</strong> Apollo Tech s.r.o., Slovakia
              </p>
            </section>

          </div>
        </div>
      </div>
    </main>

    <Footer lang="en" />
  </div>
</Layout>
