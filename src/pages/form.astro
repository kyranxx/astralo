---
import Layout from '../layouts/Layout.astro';
import { ArrowLeft, Sparkles, User, Users } from 'lucide-astro';

const horoscopeTypes = [
  { id: "daily", name: "Denný Horoskop", price: 1.99 },
  { id: "weekly", name: "Týždenný Horoskop", price: 3.99 },
  { id: "monthly", name: "Mesačný Horoskop", price: 9.99 },
  { id: "partner", name: "Partnerský Horoskop", price: 14.99 },
];

const url = new URL(Astro.request.url);
const typeId = url.searchParams.get('type');
const selectedType = horoscopeTypes.find(t => t.id === typeId);

if (!selectedType) {
  return Astro.redirect('/');
}
---

<Layout title={`${selectedType.name} - Astralo`}>
  <div class="min-h-screen flex flex-col relative z-10">
    <!-- Header -->
    <header class="glass-strong border-b border-white/10">
      <div class="max-w-6xl mx-auto px-4 py-4 sm:py-5">
        <div class="flex items-center justify-center">
          <img src="/logo.png" alt="Astralo" class="h-12 sm:h-14" />
        </div>
      </div>
    </header>

    <!-- Main Content -->
    <main class="flex-1 flex items-center justify-center px-4 py-8 sm:py-12">
      <div class="w-full max-w-lg">
        <!-- Back Button -->
        <a 
          href="/" 
          class="inline-flex items-center gap-2 text-white/80 hover:text-white mb-6 transition-colors group"
        >
          <ArrowLeft class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
          <span>Späť</span>
        </a>

        <!-- Form Card -->
        <div class="glass-strong rounded-2xl p-6 sm:p-8 animate-fade-in-up">
          <!-- Title -->
          <div class="text-center mb-8">
            <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">
              {selectedType.name}
            </h1>
            <p class="text-white/60">Vyplňte vaše údaje</p>
          </div>

          <!-- Form -->
          <form id="payment-form" class="space-y-5">
            {selectedType.id === 'partner' ? (
              <>
                {/* Person 1 */}
                <div class="space-y-4 pb-6 border-b border-white/10">
                  <h3 class="text-lg font-semibold text-white flex items-center gap-2">
                    <User class="w-5 h-5 text-amber-400" />
                    Osoba 1
                  </h3>
                  
                  <div>
                    <label for="name1" class="block text-white/80 text-sm mb-2">Meno</label>
                    <input 
                      id="name1" 
                      name="name1" 
                      type="text" 
                      placeholder="Vaše meno" 
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthDate1" class="block text-white/80 text-sm mb-2">Dátum narodenia</label>
                    <input 
                      id="birthDate1" 
                      name="birthDate1" 
                      type="date" 
                      min="1900-01-01"
                      max="" 
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthTime1" class="block text-white/80 text-sm mb-2">Čas narodenia</label>
                    <input 
                      id="birthTime1" 
                      name="birthTime1" 
                      type="time" 
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthPlace1" class="block text-white/80 text-sm mb-2">Miesto narodenia</label>
                    <input 
                      id="birthPlace1" 
                      name="birthPlace1" 
                      type="text" 
                      placeholder="Mesto, krajina" 
                      required
                      class="input w-full"
                    />
                  </div>
                </div>

                {/* Person 2 */}
                <div class="space-y-4 pt-2">
                  <h3 class="text-lg font-semibold text-white flex items-center gap-2">
                    <Users class="w-5 h-5 text-amber-400" />
                    Osoba 2
                  </h3>
                  
                  <div>
                    <label for="name2" class="block text-white/80 text-sm mb-2">Meno</label>
                    <input 
                      id="name2" 
                      name="name2" 
                      type="text" 
                      placeholder="Meno partnera" 
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthDate2" class="block text-white/80 text-sm mb-2">Dátum narodenia</label>
                    <input 
                      id="birthDate2" 
                      name="birthDate2" 
                      type="date" 
                      min="1900-01-01"
                      max=""
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthTime2" class="block text-white/80 text-sm mb-2">Čas narodenia</label>
                    <input 
                      id="birthTime2" 
                      name="birthTime2" 
                      type="time" 
                      required
                      class="input w-full"
                    />
                  </div>

                  <div>
                    <label for="birthPlace2" class="block text-white/80 text-sm mb-2">Miesto narodenia</label>
                    <input 
                      id="birthPlace2" 
                      name="birthPlace2" 
                      type="text" 
                      placeholder="Mesto, krajina" 
                      required
                      class="input w-full"
                    />
                  </div>
                </div>
              </>
            ) : (
              <>
                <div>
                  <label for="name" class="block text-white/80 text-sm mb-2">Meno</label>
                  <input 
                    id="name" 
                    name="name" 
                    type="text" 
                    placeholder="Vaše meno" 
                    required
                    class="input w-full"
                  />
                </div>

                <div>
                  <label for="birthDate" class="block text-white/80 text-sm mb-2">Dátum narodenia</label>
                  <input 
                    id="birthDate" 
                    name="birthDate" 
                    type="date" 
                    min="1900-01-01"
                    max=""
                    required
                    class="input w-full"
                  />
                </div>

                <div>
                  <label for="birthTime" class="block text-white/80 text-sm mb-2">Čas narodenia</label>
                  <input 
                    id="birthTime" 
                    name="birthTime" 
                    type="time" 
                    required
                    class="input w-full"
                  />
                </div>

                <div>
                  <label for="birthPlace" class="block text-white/80 text-sm mb-2">Miesto narodenia</label>
                  <input 
                    id="birthPlace" 
                    name="birthPlace" 
                    type="text" 
                    placeholder="Mesto, krajina" 
                    required
                    class="input w-full"
                  />
                </div>
              </>
            )}

            {/* Submit Button */}
            <div class="pt-4">
              <button type="submit" class="btn-primary w-full">
                <Sparkles class="w-5 h-5" />
                Zaplatiť {selectedType.price.toFixed(2)}€
              </button>
            </div>

            {/* Trust Badges */}
            <div class="text-center pt-4 border-t border-white/10">
              <p class="text-white/60 text-sm">
                🔒 Bezpečná platba cez Stripe • Okamžité doručenie
              </p>
            </div>
          </form>
        </div>
      </div>
    </main>

    <!-- Footer -->
    <footer class="glass-strong border-t border-white/10 mt-auto">
      <div class="max-w-6xl mx-auto px-4 py-6 text-center">
        <p class="text-white/50 text-sm">
          © 2024 Astralo
        </p>
      </div>
    </footer>
  </div>
</Layout>

<script is:inline define:vars={{ typeId }}>
  // Set max date to today for all birth date inputs
  const today = new Date().toISOString().split('T')[0];
  document.querySelectorAll('input[type="date"]').forEach(input => {
    input.setAttribute('max', today);
  });

  const form = document.getElementById('payment-form');
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    
    const submitButton = event.target.querySelector('button[type="submit"]');
    const originalHTML = submitButton.innerHTML;
    submitButton.disabled = true;
    submitButton.innerHTML = '<svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Spracovávam...</span>';
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    try {
      const response = await fetch('/api/checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productKey: typeId, ...data }),
      });
      
      const { url } = await response.json();
      if (url) {
        window.location.href = url;
      }
    } catch (error) {
      console.error(error);
      submitButton.disabled = false;
      submitButton.innerHTML = originalHTML;
      alert('Chyba pri spracovaní platby. Prosím, skúste to znova.');
    }
  });
</script>
