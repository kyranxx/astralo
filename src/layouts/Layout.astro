---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent.astro';
import CosmicAd from '../components/CosmicAd.astro';
import EmailCapture from '../components/EmailCapture.astro';
import FeedbackWidget from '../components/FeedbackWidget.astro';
import { productCatalog, supportedLocaleCodes } from '../lib/agent-ready';
import { getTranslations, isValidLocale, type SupportedLocale } from '../lib/i18n';
import type { ProductKey } from '../lib/products';
import {
    brandName,
    buildAlternateLanguageUrls,
    buildOrganizationSchema,
    buildWebSiteSchema,
    defaultOgImage,
    getHomePath,
    isRtlLocale,
    normalizeCanonicalUrl,
    ogLocaleMap,
    siteUrl,
} from '../lib/seo';
import '@fontsource/outfit/300.css';
import '@fontsource/outfit/400.css';
import '@fontsource/outfit/500.css';
import '@fontsource/outfit/600.css';
import '@fontsource/outfit/700.css';
import '@fontsource/outfit/800.css';

interface Props {
    title: string;
    backgroundImage?: string;
    lang?: string;
    canonicalUrl?: string;
    alternateLanguageUrls?: Array<{ code: SupportedLocale; hreflang: string; href: string }>;
    description?: string;
    keywords?: string;
    noIndex?: boolean;
    ogType?: 'website' | 'article';
    ogImage?: string;
    publishedTime?: string;
    modifiedTime?: string;
    schema?: Record<string, any>[];
    floatingProductKey?: ProductKey;
}

const {
    title,
    backgroundImage = '/background5.webp',
    lang = 'en',
    canonicalUrl,
    alternateLanguageUrls: providedAlternateLanguageUrls,
    description,
    keywords,
    noIndex = false,
    ogType = 'website',
    ogImage = defaultOgImage,
    publishedTime,
    modifiedTime,
    schema = [],
    floatingProductKey,
} = Astro.props;

const currentLang = isValidLocale(lang) ? (lang as SupportedLocale) : 'en';
const t = getTranslations(currentLang);
const currentDescription = description || t.meta.description;
const currentKeywords = keywords || t.meta.keywords;
const currentPath = Astro.url.pathname;
const cleanPath = currentPath === '/' ? '/' : currentPath.replace(/\/$/, '');
const isLocaleHomePath = /^\/[a-z]{2}$/.test(cleanPath);
const isCommercePath = cleanPath === '/'
    || isLocaleHomePath
    || /^\/(?:[a-z]{2}\/)?(?:form|horoscope|free-horoscope)(?:\/|$)/.test(cleanPath);
const showFeedbackWidget = !isCommercePath;
const computedCanonicalUrl = normalizeCanonicalUrl(canonicalUrl || `${siteUrl}${cleanPath}`);
const alternateLanguageUrls = noIndex ? [] : (providedAlternateLanguageUrls || buildAlternateLanguageUrls(currentPath));
const defaultAlternateUrl = alternateLanguageUrls.find(({ code }) => code === 'en')?.href || siteUrl;
const dir = isRtlLocale(currentLang) ? 'rtl' : 'ltr';
const homeLink = getHomePath(currentLang);
const pageSchema = [
    buildWebSiteSchema(currentDescription),
    buildOrganizationSchema(currentDescription),
    ...schema,
];
const webMcpConfig = {
    locales: supportedLocaleCodes,
    products: Object.values(productCatalog).map((product) => ({
        slug: product.slug,
        path: product.path,
        name: product.name,
    })),
    blogPath: '/blog',
};
const backgroundImageType = backgroundImage.endsWith('.png')
    ? 'image/png'
    : backgroundImage.endsWith('.jpg') || backgroundImage.endsWith('.jpeg')
        ? 'image/jpeg'
        : 'image/webp';
---

<!doctype html>
<html lang={currentLang} dir={dir} prefix="og: https://ogp.me/ns#">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{title}</title>
        <meta name="title" content={title} />
        <meta name="description" content={currentDescription} />
        <meta name="keywords" content={currentKeywords} />
        <meta name="author" content={brandName} />
        <meta
            name="robots"
            content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'}
        />
        <meta name="google-site-verification" content="nnTYdANVVkW6nOtVRWJ0xIVe-u5DRY4yK5QZ3nQLUdQ" />
        <link rel="canonical" href={computedCanonicalUrl} />

        <meta property="og:type" content={ogType} />
        <meta property="og:site_name" content={brandName} />
        <meta property="og:url" content={computedCanonicalUrl} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={currentDescription} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:url" content={ogImage} />
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={`${brandName} astrology reading preview`} />
        <meta property="og:locale" content={ogLocaleMap[currentLang] || 'en_US'} />
        {alternateLanguageUrls.filter(({ code }) => code !== currentLang).map(({ code }) => (
            <meta property="og:locale:alternate" content={ogLocaleMap[code] || 'en_US'} />
        ))}
        {publishedTime && <meta property="article:published_time" content={publishedTime} />}
        {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={computedCanonicalUrl} />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={currentDescription} />
        <meta name="twitter:image" content={ogImage} />

        {alternateLanguageUrls.map(({ hreflang, href }) => (
            <link rel="alternate" hreflang={hreflang} href={href} />
        ))}
        {!noIndex && <link rel="alternate" hreflang="x-default" href={defaultAlternateUrl} />}
        <link rel="alternate" type="application/rss+xml" title={`${brandName} Blog`} href={`${siteUrl}/rss.xml`} />

        <link rel="preload" href="/logo.webp" as="image" type="image/webp" fetchpriority="high" />
        <link rel="preload" href={backgroundImage} as="image" type={backgroundImageType} fetchpriority="high" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="apple-touch-icon" sizes="180x180" href="/og-image.png" />

        <meta name="generator" content={Astro.generator} />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <meta name="theme-color" content="#0a0a1a" />

        {pageSchema.map((entry) => (
            <script is:inline type="application/ld+json" set:html={JSON.stringify(entry)} />
        ))}

        <style is:inline>
            *,*::before,*::after{box-sizing:border-box}
            body{margin:0;background:#0a0a1a;color:#fff;font-family:'Outfit',ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,'Helvetica Neue',Arial,sans-serif;font-weight:400;line-height:1.5;-webkit-font-smoothing:antialiased}
            img{max-width:100%;height:auto;display:block}
            a{color:inherit;text-decoration:none}
            h1,h2,h3,h4{margin:0;font-weight:700}
            .cosmic-bg{position:fixed;top:0;left:0;width:100%;height:100%;background:linear-gradient(135deg,#0a0a1a 0%,#1a0f2e 50%,#0f1729 100%);z-index:-2}
            .cosmic-overlay{position:fixed;top:0;left:0;width:100%;height:100%;object-fit:cover;opacity:.28;z-index:-1;mix-blend-mode:normal;filter:brightness(.72) saturate(.82)}
            .glass-strong{background:rgba(12,10,18,.74);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px);border:1px solid rgba(255,255,255,.11)}
            .min-h-screen{min-height:100vh}
            .flex{display:flex}
            .flex-col{flex-direction:column}
            .items-center{align-items:center}
            .justify-between{justify-content:space-between}
            .text-center{text-align:center}
            .text-white{color:#fff}
            .text-amber-400{color:#fbbf24}
            .animate-on-load{opacity:1}
            .animate-delay-1,.animate-delay-2,.animate-delay-3,.animate-delay-4{opacity:1}
        </style>
        <script is:inline>
            (function () {
                function getGaClientIdFromCookie() {
                    var match = document.cookie.match(/(?:^|;\s*)_ga=([^;]+)/);
                    if (!match) return '';

                    var value = decodeURIComponent(match[1]);
                    var gaMatch = value.match(/^GA\d+\.\d+\.(.+)$/);
                    return gaMatch ? gaMatch[1] : value;
                }

                window.dataLayer = window.dataLayer || [];
                window.gtag = window.gtag || function () {
                    window.dataLayer.push(arguments);
                };
                window.astraloGetGaClientId = window.astraloGetGaClientId || getGaClientIdFromCookie;
                window.astraloTrack = window.astraloTrack || function (eventName, params) {
                    if (!eventName) return;

                    try {
                        window.gtag('event', eventName, params || {});
                    } catch (error) {
                        console.warn('GA4 tracking failed', error);
                    }
                };
            })();
        </script>
    </head>
    <body>
        <div class="sticky top-0 z-[60] bg-amber-500/95 py-1.5 px-4 text-center shadow-sm">
            <div class="flex items-center justify-center gap-2 sm:gap-4 text-black text-[11px] sm:text-xs font-bold uppercase tracking-wider">
                <span>{t.promo.delivery}</span>
                <span class="hidden sm:inline opacity-30">|</span>
                <a href={`${homeLink}#horoscopes`} class="underline hover:opacity-80 transition-opacity">
                    {t.promo.secure}
                </a>
            </div>
        </div>

        <div class="cosmic-bg"></div>
        {backgroundImage && (
            <img
                src={backgroundImage}
                alt="Cosmic background"
                class="cosmic-overlay"
                width="1920"
                height="1080"
                fetchpriority="high"
                role="presentation"
                aria-hidden="true"
            />
        )}

        <slot />

        {floatingProductKey && <CosmicAd type="floating" productKey={floatingProductKey} lang={currentLang} />}
        {showFeedbackWidget && <FeedbackWidget lang={currentLang} />}
        <CookieConsent lang={currentLang} />
        <EmailCapture lang={currentLang} />

        <script is:inline>
            (function () {
                function loadClarity() {
                    (function(c,l,a,r,i,t,y){
                        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
                        t=l.createElement(r);t.async=1;t.src='https://www.clarity.ms/tag/'+i;
                        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
                    })(window, document, 'clarity', 'script', 'uq8y5sm9rv');
                }

                if ('requestIdleCallback' in window) {
                    requestIdleCallback(loadClarity, { timeout: 3000 });
                } else {
                    setTimeout(loadClarity, 5000);
                }
            })();
        </script>

        <script is:inline>
            (function () {
                function loadGA() {
                    var script = document.createElement('script');
                    script.async = true;
                    script.src = 'https://www.googletagmanager.com/gtag/js?id=G-M4VCEJ31XV';
                    document.head.appendChild(script);

                    window.gtag('js', new Date());
                    window.gtag('config', 'G-M4VCEJ31XV');
                }

                if ('requestIdleCallback' in window) {
                    requestIdleCallback(loadGA, { timeout: 3000 });
                } else {
                    setTimeout(loadGA, 4000);
                }
            })();
        </script>

        <script is:inline>
            (function () {
                var storageKey = 'astralo_attribution';
                var campaignKeys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content', 'gclid', 'fbclid', 'msclkid'];

                try {
                    var params = new URLSearchParams(window.location.search);
                    var existing = JSON.parse(localStorage.getItem(storageKey) || '{}');
                    var next = Object.assign({}, existing);
                    var now = new Date().toISOString();
                    var hasCampaignParams = false;

                    for (var i = 0; i < campaignKeys.length; i++) {
                        var key = campaignKeys[i];
                        var value = params.get(key);
                        if (value) {
                            next[key] = value;
                            hasCampaignParams = true;
                        }
                    }

                    var referrer = document.referrer && document.referrer.indexOf(window.location.origin) !== 0
                        ? document.referrer
                        : '';

                    if (!existing.firstSeenAt) {
                        next.firstSeenAt = now;
                        next.landingPath = window.location.pathname;
                    }

                    if (referrer && (!existing.referrer || hasCampaignParams)) {
                        next.referrer = referrer;
                    }

                    if (hasCampaignParams || !existing.lastSeenAt) {
                        next.lastSeenAt = now;
                        next.lastPath = window.location.pathname;
                    }

                    localStorage.setItem(storageKey, JSON.stringify(next));
                } catch (error) {
                    console.warn('Failed to persist attribution data', error);
                }
            })();
        </script>

        <script is:inline define:vars={{ webMcpConfig }}>
            (function () {
                var modelContext = typeof navigator !== 'undefined' ? navigator.modelContext : undefined;
                if (!modelContext) return;

                var controller = new AbortController();

                function localizePath(path, locale) {
                    return locale && locale !== 'en' ? '/' + locale + path : path;
                }

                function navigate(path) {
                    window.location.href = path;
                    return { ok: true, url: new URL(path, window.location.origin).toString() };
                }

                function buildTool(config) {
                    if (config.name === 'open_horoscope_product') {
                        return {
                            name: config.name,
                            description: config.description,
                            inputSchema: config.inputSchema,
                            execute: async function (input) {
                                var locale = input && input.locale ? input.locale : 'en';
                                var product = input && input.product ? input.product : 'daily';
                                var productConfig = webMcpConfig.products.find(function (item) {
                                    return item.slug === product;
                                });

                                if (!productConfig) {
                                    return { ok: false, error: 'Unknown product.' };
                                }

                                return navigate(localizePath(productConfig.path, locale));
                            }
                        };
                    }

                    if (config.name === 'switch_language_home') {
                        return {
                            name: config.name,
                            description: config.description,
                            inputSchema: config.inputSchema,
                            execute: async function (input) {
                                var locale = input && input.locale ? input.locale : 'en';
                                return navigate(localizePath('', locale) || '/');
                            }
                        };
                    }

                    return {
                        name: config.name,
                        description: config.description,
                        inputSchema: config.inputSchema,
                        execute: async function () {
                            return navigate(webMcpConfig.blogPath);
                        }
                    };
                }

                var toolConfigs = [
                    {
                        name: 'open_horoscope_product',
                        description: 'Open one of Astralo\'s horoscope product pages.',
                        inputSchema: {
                            type: 'object',
                            properties: {
                                product: {
                                    type: 'string',
                                    enum: webMcpConfig.products.map(function (item) { return item.slug; })
                                },
                                locale: {
                                    type: 'string',
                                    enum: webMcpConfig.locales
                                }
                            },
                            required: ['product']
                        }
                    },
                    {
                        name: 'switch_language_home',
                        description: 'Open the Astralo homepage in a supported locale.',
                        inputSchema: {
                            type: 'object',
                            properties: {
                                locale: {
                                    type: 'string',
                                    enum: webMcpConfig.locales
                                }
                            },
                            required: ['locale']
                        }
                    },
                    {
                        name: 'open_blog_index',
                        description: 'Open the Astralo blog index.',
                        inputSchema: {
                            type: 'object',
                            properties: {}
                        }
                    }
                ];

                var tools = toolConfigs.map(buildTool);

                try {
                    if (typeof modelContext.provideContext === 'function') {
                        modelContext.provideContext({ tools: tools }, { signal: controller.signal });
                        return;
                    }
                } catch (error) {
                    console.warn('WebMCP provideContext failed', error);
                }

                try {
                    if (typeof modelContext.registerTools === 'function') {
                        modelContext.registerTools(tools, { signal: controller.signal });
                        return;
                    }
                } catch (error) {
                    console.warn('WebMCP registerTools failed', error);
                }

                if (typeof modelContext.registerTool === 'function') {
                    tools.forEach(function (tool) {
                        try {
                            modelContext.registerTool(tool, { signal: controller.signal });
                        } catch (error) {
                            try {
                                modelContext.registerTool(tool);
                            } catch (innerError) {
                                console.warn('WebMCP registerTool failed', innerError);
                            }
                        }
                    });
                }

                window.addEventListener('pagehide', function () {
                    controller.abort();
                }, { once: true });
            })();
        </script>
    </body>
</html>
